					</span>
					<p class="text-sm leading-relaxed text-slate-700">{{ 'SDG 9: Industry, Innovation and Infrastructure'|t }}</p>
				</li>
				<li class="flex gap-3">
					<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
