{#
/**
 * @file
 * Secondary presentation template for CUD Sustainability pages.
 */
#}

<section class="mx-auto max-w-7xl px-4 pb-12 pt-8 sm:px-6 sm:pt-10 lg:px-8 lg:pb-16 lg:pt-14" data-mode="{{ mode }}">

  <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-stretch">
    <div class="rounded-3xl bg-[linear-gradient(135deg,#9a3412_0%,#ea580c_52%,#fb923c_100%)] p-6 text-white shadow-[0_24px_60px_rgba(124,45,18,0.22)] sm:p-8 lg:p-10">
      <p class="text-xs font-semibold uppercase tracking-[0.34em] text-orange-100">Sustainability Page</p>
      <h1 class="mt-4 text-3xl font-semibold leading-tight sm:text-4xl lg:text-5xl">{{ title }}</h1>
      <p class="mt-5 max-w-2xl text-sm leading-7 text-orange-50 sm:text-base">
        This alternate content section sits inside the same responsive sustainability shell, giving secondary pages a distinct tone without duplicating the global frame.
      </p>
    </div>

    <aside class="rounded-3xl border border-orange-200 bg-white p-6 shadow-[0_14px_35px_rgba(194,65,12,0.10)] sm:p-7">
      <p class="text-xs font-semibold uppercase tracking-[0.32em] text-orange-700">Page Details</p>
      <ul class="mt-5 space-y-3 text-sm text-slate-700">
        <li><span class="font-semibold text-slate-900">Template:</span> Secondary</li>
        <li><span class="font-semibold text-slate-900">Scope:</span> Content section only</li>
        <li><span class="font-semibold text-slate-900">Layout shell:</span> page--cud-sustainability.html.twig</li>
      </ul>
    </aside>
  </div>

  {% if carousel_items %}
  <div class="relative mt-6 overflow-hidden rounded-3xl shadow-[0_20px_45px_rgba(194,65,12,0.12)]" data-cud-carousel>
    <div class="flex transition-transform duration-500 ease-in-out will-change-transform" data-cud-carousel-track>
      {% for item in carousel_items %}
      <div class="relative min-w-full" data-cud-carousel-slide>
        {% if item.image %}
        <div class="cud-sustainability-carousel__frame aspect-[16/7] overflow-hidden bg-orange-50">
          {{ item.image }}
        </div>
        {% endif %}
        {% if item.overlay %}
        <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/65 via-black/20 to-transparent">
          <div class="w-full p-6 text-white sm:p-8 lg:p-10">{{ item.overlay }}</div>
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% if carousel_items|length > 1 %}
    <button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/85 p-2 shadow-md backdrop-blur-sm transition hover:bg-white focus:outline-none focus:ring-2 focus:ring-orange-400 sm:left-5" data-cud-carousel-prev aria-label="Previous slide">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-800" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
    </button>
    <button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/85 p-2 shadow-md backdrop-blur-sm transition hover:bg-white focus:outline-none focus:ring-2 focus:ring-orange-400 sm:right-5" data-cud-carousel-next aria-label="Next slide">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-800" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
    </button>
    <div class="absolute bottom-4 left-1/2 z-10 flex -translate-x-1/2 gap-2">
      {% for item in carousel_items %}
      <button class="h-2 rounded-full transition-all focus:outline-none focus:ring-2 focus:ring-white{% if loop.first %} w-8 bg-white{% else %} w-2 bg-white/50 hover:bg-white/80{% endif %}" data-cud-carousel-dot="{{ loop.index0 }}" aria-label="Go to slide {{ loop.index }}"></button>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  {% if sections %}
  <div class="mt-6 space-y-6">
    {% for section in sections %}
    <div class="rounded-3xl border border-orange-200 bg-white px-6 py-8 shadow-[0_14px_35px_rgba(194,65,12,0.08)] sm:px-8 lg:px-10 lg:py-10 [&_a]:text-orange-600 [&_a:hover]:underline [&_h1]:text-3xl [&_h1]:font-semibold [&_h2]:text-2xl [&_h2]:font-semibold [&_h3]:text-xl [&_h3]:font-semibold [&_h4]:text-lg [&_h4]:font-semibold [&_ul]:list-disc [&_ul]:pl-5 [&_ol]:list-decimal [&_ol]:pl-5 [&_p]:leading-7 [&_blockquote]:border-l-4 [&_blockquote]:border-orange-300 [&_blockquote]:pl-4 [&_blockquote]:italic [&_img]:max-w-full [&_img]:rounded-xl">
      {{ section }}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="mt-6 rounded-3xl border border-orange-200 bg-white p-6 shadow-[0_20px_45px_rgba(194,65,12,0.12)] sm:p-8 lg:p-10">
    {{ content }}
  </div>
</section>
