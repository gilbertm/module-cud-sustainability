{#
/**
 * @file
 * Inner-page template for /sustainability/our-commitment/governance.
 *
 * Variables:
 * - title: Page title string.
 * - content: Rendered node content (full view mode).
 * - carousel_items: Optional list of carousel slides.
 * - sections: Optional list of processed-text sections.
 * - primary_nav: Primary navigation array.
 * - secondary_nav: Secondary navigation array.
 * - mode: Display mode string ('main' or 'secondary').
 */
#}

{% set carousel_slides = carousel_items|default([]) %}

{% if carousel_slides %}
	<section class="carousel group relative mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Governance carousel'|t }}">
		<div class="w-full relative overflow-hidden">
			<div class="w-full flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Governance') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}
						<div class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>
					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>
					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}

{# ── Page Header with Breadcrumb ─────────────────────────────────────────────── #}
<section class="bg-white" aria-label="{{ 'Page header'|t }}">
	<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
		<nav class="mb-3 flex items-center gap-1.5 text-xs text-slate-500" aria-label="{{ 'Breadcrumb'|t }}">
			{% for link in breadcrumb %}
				{% if not loop.first %}
					<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
				{% endif %}
				{% if link.url %}
					<a href="{{ link.url }}" class="hover:text-slate-700 transition-colors">{{ link.text }}</a>
				{% else %}
					<span>{{ link.text }}</span>
				{% endif %}
			{% endfor %}
			{% if breadcrumb is not empty %}
				<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
			{% endif %}
			<span class="font-medium text-slate-700">{{ title }}</span>
		</nav>
		<div class="flex items-center gap-3">
			<h1 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{{ title }}</h1>
			{% if edit_url %}
				<a href="{{ edit_url }}" class="shrink-0 rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700" title="{{ 'Edit node'|t }}" aria-label="{{ 'Edit'|t }}">
					<i class="fa-solid fa-pen-to-square text-sm" aria-hidden="true"></i>
				</a>
			{% endif %}
		</div>
	</div>
</section>

{# ── Shared sub-nav data ──────────────────────────────────────────────────────── #}

{# Icon map for all seeded primary nav children, keyed by URL #}
{% set icon_map = {
	'/sustainability/social-responsibility/edi': 'fa-handshake',
	'/sustainability/social-responsibility/people-of-determination': 'fa-universal-access',
} %}

{# Derive sub_items from the matching top-level primary nav parent #}
{% set active_nav_parent = null %}
{% for item in primary_nav %}
	{% if item.children and (current_path == item.url or current_path starts with (item.url ~ '/')) %}
		{% set active_nav_parent = item %}
	{% endif %}
{% endfor %}
{% set sub_items = active_nav_parent ? active_nav_parent.children : [] %}

{# ── Mobile / tablet sub-nav strip (hidden on lg+) ───────────────────────────── #}
<div class="lg:hidden border-b border-slate-100 bg-white px-4 sm:px-6">
	<nav class="flex gap-1.5 overflow-x-auto py-2.5 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" aria-label="{{ 'Our Commitment navigation'|t }}">
		{% for sub in sub_items %}
			<a href="{{ sub.url }}" class="inline-flex flex-none items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium transition-colors{% if current_path == sub.url %} bg-slate-900 text-white{% else %} text-slate-600 hover:bg-slate-100 hover:text-slate-900{% endif %}">
				<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }}" aria-hidden="true"></i>
				{{ sub.title }}
			</a>
		{% endfor %}
	</nav>
</div>

{# ── Main Content (full-width) ────────────────────────────────────────────────── #}
<section class="mx-auto max-w-7xl px-4 lg:px-8 !bg-white" id="main-content" aria-label="{{ title }}" data-mode="{{ mode }}">
	<div
		class="min-w-0 space-y-5">


		{# ── Community and Outreach Activities ───────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-community-outreach">
			<h2 id="heading-community-outreach" class="text-md md:text-xl font-semibold cud-color-blue mb-3">{{ 'Community and Outreach Activities'|t }}</h2>
			<p class="text-slate-600 text-sm mb-4">CUD's campus boasts modern teaching and event facilities — classrooms, auditoriums, labs, studios, sports areas — that are in some cases opened up to external organizations and community initiatives:</p>

			<h3 class="text-base font-semibold text-slate-800 mt-4 mb-2">
				<a href="//global-citizen.com/uncategorized/summit/brand-me-summit-2025-partners-with-unhcr-to-champion-refugee-education-and-empower-global-leaders/"
				   class="inline-flex items-center gap-1.5 transition-colors hover:text-[#b13634]"
				   target="_blank" rel="noopener noreferrer">
					{{ 'Championing Refugee Education'|t }}
					<i class="fa-solid fa-arrow-up-right-from-square cud-red" aria-hidden="true"></i>
				</a>
			</h3>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'As part of our commitment to global empowerment, CUD has partnered with UNHCR, the UN Refugee Agency, and the Brand Me Summit 2025 to champion access to higher education for displaced individuals. With only 9% of the world\'s refugees currently able to access higher education, CUD took direct action by contributing 50 full scholarships for refugee students. Alongside this initiative, CUD is fostering future leaders by hosting a university-wide entrepreneurship competition, which provides winning students with essential funding and incubation support through the CUD Innovation Hub. This collaboration reflects our core belief, as expressed by CUD President and Vice-Chancellor Professor Karim Chelli: "When aligned with compassion and purpose, education has no borders. Together with UNHCR and Brand Me Summit, we\'re shaping a future where knowledge becomes a bridge to opportunity".'|t }}</p>
			
			<h3 class="text-base font-semibold text-slate-800 mt-4 mb-2">{{ 'Joint Educational Programs'|t }}</h3>
			<p class="text-slate-700 text-sm leading-relaxed">Through partnerships, CUD sometimes offers its
				<a href="//www.cud.ac.ae/research/partnerships" class="font-semibold text-sky-700 hover:underline">labs and resources to partner institutions</a>. For instance, CUD's engineering labs (e.g. for robotics, multimedia, or science) have been used in collaboration with competitions like UAE Robotics competitions or
				<a href="//www.cud.ac.ae/events/ai-sustainability-hackathon-2026" class="text-sky-700 hover:underline">hackathons</a>, where non-CUD students participate on campus. Similarly, art studios and exhibition spaces at CUD have hosted inter-university design showcases. In providing these facilities, CUD supports practical learning for the broader academic community.
				<b>Supporting external researchers</b>
				is also part of this mandate — e.g., a researcher from another university might gain
				<b>free on-site access to a specialized lab or library archive at CUD to conduct their research</b>, through formal approval. While not a public drop-in service, CUD has indicated willingness to
				<a href="//www.cud.ac.ae/research/partnerships" class="font-semibold text-sky-700 hover:underline">support researchers from outside</a>
				by granting them access to equipment or research materials upon request, especially if it's a collaborative project or benefits &ldquo;wider society&rdquo;. This is in line with CUD's research partnerships and its contribution to UAE's innovation ecosystem.</p>


			<h3 class="text-base font-semibold text-slate-800 mt-4 mb-2">{{ 'Community Services on Campus'|t }}</h3>
			<p class="text-slate-700 text-sm leading-relaxed">CUD's campus facilities are occasionally used for
				<strong>community service initiatives</strong>. For example, the university's Health Clinic (primarily for student health) may partner with public health authorities to run
				<span class="font-medium">free health screening camps or blood donation drives</span>
				open to the public on campus. The Sports facilities (gym, courts) have been used for inter-school sports tournaments or charity games involving outside teams. The availability of resources like
				<strong>internet access, computers, printers</strong>
				is extended to guests during such events (e.g., media personnel at a conference can use the campus Wi-Fi; school teams visiting a computer science competition at CUD can use the PC labs and printing services for their materials). All these illustrate how CUD's tangible resources (classrooms, labs, equipment) are offered to
				<strong>various external channels</strong>, from educational to cultural to charitable, either free (if under community outreach) or on a cost-recovery basis.</p>
		</div>



		{# ── Past Events ─────────────────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-past-events">
			<h2 id="heading-past-events" class="text-md md:text-xl font-semibold cud-color-blue mb-4">{{ 'Past Events'|t }}</h2>
			<div class="grid gap-6 sm:grid-cols-2">
				<div class="flex flex-col gap-3 rounded-xl border border-slate-200 p-5 shadow-sm">
					<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/event-edi-dome-of-inclusion.jpg' }}" alt="{{ 'Dome of Inclusion — Dubai Design Week'|t }}" class="tc-lightbox w-full h-auto max-h-60 rounded-lg object-cover aspect-video"/>
					<h3 class="text-sm font-semibold text-slate-800">
						<a href="//www.cud.ac.ae/news/canadian-university-dubai-students-unveil-dome-inclusion-during-dubai-design-week" class="hover:underline text-slate-800" target="_blank" rel="noopener">
							{{ 'CUD students unveil Dome of Inclusion during Dubai Design Week'|t }}
						</a>
					</h3>
					<p class="text-sm text-slate-600 leading-relaxed">Canadian University Dubai has joined forces with Dubai Holding Entertainment (DHE) and ImInclusive to champion equality and accessibility through the power of design. The collaborative installation, known as the Dome of Inclusion, was officially presented at Dubai Design Week. Developed as a space where creativity, design, and accessibility converge, the Dome of Inclusion is composed of interlocking hexagons and pentagons that symbolize unity through diversity.</p>
				</div>
				<div class="flex flex-col gap-3 rounded-xl border border-slate-200 p-5 shadow-sm">
					<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/event-edi-media-z-initiative.jpg' }}" alt="{{ 'Dubai Media Academy — Media Z Initiative'|t }}" class="tc-lightbox w-full h-auto max-h-60 rounded-lg object-cover aspect-video"/>
					<h3 class="text-sm font-semibold text-slate-800">
						<a href="//www.cud.ac.ae/news/dubai-media-academy-launches-media-z-initiative-collaboration-canadian-university-dubai" class="hover:underline text-slate-800" target="_blank" rel="noopener">
							{{ 'Dubai Media Academy launches \'Media Z\' initiative in collaboration with CUD'|t }}
						</a>
					</h3>
					<p class="text-sm text-slate-600 leading-relaxed">Dubai Media Academy, part of Dubai Media Incorporated, concluded the Media Z event, organised in collaboration with CUD, as part of its support for the Year of the Family and national efforts to empower young people. Hosted by the university, the event brought together media and education leaders, experts, specialists and academics, alongside students from universities across the UAE.</p>
				</div>
				<div class="flex flex-col gap-3 rounded-xl border border-slate-200 p-5 shadow-sm">
					<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/event-edi-summer-camp.jpg' }}" alt="{{ 'CUD Summer Camp for High School Students'|t }}" class="tc-lightbox w-full h-auto max-h-60 rounded-lg object-cover aspect-video"/>
					<h3 class="text-sm font-semibold text-slate-800">
						<a href="//www.cud.ac.ae/news/cud-empowers-high-school-students-3-day-summer-camp-inspiring-education-community" class="hover:underline text-slate-800" target="_blank" rel="noopener">
							{{ 'CUD Empowers High School Students with a 3-day Summer Camp | Inspiring Education for the Community'|t }}
						</a>
					</h3>
					<p class="text-sm text-slate-600 leading-relaxed">The Summer Camp was exclusively designed for high school students, aligning with CUD's commitment to driving education within the community. The Summer Camp offered an interactive learning setting, facilitating six practical workshops for the students to actively participate in.</p>
				</div>
				<div class="flex flex-col gap-3 rounded-xl border border-slate-200 p-5 shadow-sm">
					<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/event-edi-cultural-day.jpg' }}" alt="{{ 'CUD International Cultural Day Celebration'|t }}" class="tc-lightbox w-full h-auto max-h-60 rounded-lg object-cover aspect-video"/>
					<h3 class="text-sm font-semibold text-slate-800">
						<a href="//www.cud.ac.ae/news/embracing-diversity-look-cud-communitys-international-cultural-day-celebration" class="hover:underline text-slate-800" target="_blank" rel="noopener">
							{{ 'Embracing Diversity | A Look into the CUD Community\'s International Cultural Day Celebration'|t }}
						</a>
					</h3>
							<p class="text-sm text-slate-600 leading-relaxed">The event brought together students from 16 countries to exhibit their unique cultures, traditions, and customs. International Cultural Day at CUD provided an opportunity for students and the wider community to unite to celebrate dynamic cultural backgrounds by showcasing their cultures, traditions, and customs. Students were able to share their unique perspectives and foster a greater understanding and appreciation for one another's countries.</p>
						</div>
					</div>



					{# ── More Events ──────────────────────────────────────────────────── #}
					<div class="mt-6">
						<p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400 mb-3">{{ 'More Events'|t }}</p>
				<ul class="flex flex-col gap-2">
					<li>
						<a href="//www.cud.ac.ae/events/climate-summit-2025-june-3-4-2025" class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-[#b13634]">
							<span class="flex items-center gap-2.5">
								<i class="fa-solid fa-calendar-days w-4 text-center text-slate-400 group-hover:text-[#b13634] transition-colors" aria-hidden="true"></i>
								Climate Summit 2025
								<span class="font-normal text-slate-400 group-hover:text-[#b13634]/70">(June 3–4, 2025)</span>
							</span>
							<i class="fa-solid fa-arrow-right text-xs text-slate-300 group-hover:text-[#b13634] transition-all group-hover:translate-x-0.5" aria-hidden="true"></i>
						</a>
					</li>
					<li>
						<a href="//www.cud.ac.ae/events/fireside-chat-book-signing-dr-adil-alzarooni" class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-[#b13634]">
							<span class="flex items-center gap-2.5">
								<i class="fa-solid fa-microphone w-4 text-center text-slate-400 group-hover:text-[#b13634] transition-colors" aria-hidden="true"></i>
								Fireside Chat &amp; Book Signing with Dr. Adil Alzarooni
							</span>
							<i class="fa-solid fa-arrow-right text-xs text-slate-300 group-hover:text-[#b13634] transition-all group-hover:translate-x-0.5" aria-hidden="true"></i>
						</a>
					</li>
					<li>
						<a href="//www.cud.ac.ae/news/brand-me-summit-returns-groundbreaking-second-edition-canadian-university-dubai" class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-[#b13634]">
							<span class="flex items-center gap-2.5">
								<i class="fa-solid fa-star w-4 text-center text-slate-400 group-hover:text-[#b13634] transition-colors" aria-hidden="true"></i>
								Brand Me Summit returns for a groundbreaking second edition at CUD
							</span>
							<i class="fa-solid fa-arrow-right text-xs text-slate-300 group-hover:text-[#b13634] transition-all group-hover:translate-x-0.5" aria-hidden="true"></i>
						</a>
					</li>
					<li>
						<a href="//www.cud.ac.ae/news/cud-and-deloitte-spearhead-sustainability-training-greener-future" class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-[#b13634]">
							<span class="flex items-center gap-2.5">
								<i class="fa-solid fa-leaf w-4 text-center text-slate-400 group-hover:text-[#b13634] transition-colors" aria-hidden="true"></i>
								CUD and Deloitte Spearhead Sustainability Training for a Greener Future
							</span>
							<i class="fa-solid fa-arrow-right text-xs text-slate-300 group-hover:text-[#b13634] transition-all group-hover:translate-x-0.5" aria-hidden="true"></i>
						</a>
					</li>
				</ul>
			</div>
		</div>

		{% if content %}
			<div class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-sky-700 prose-a:no-underline hover:prose-a:underline">
				{{ content }}
			</div>
		{% endif %}

		{% if sections %}
			<div class="mt-8 space-y-6">
				{% for section in sections %}
					<div class="prose prose-slate max-w-none">{{ section }}</div>
				{% endfor %}
			</div>
		{% endif %}
		
	</div>
</section>

{# ── Desktop floating contextual nav (hidden on mobile/tablet) ───────────────── #}
<section class="hidden lg:block fixed right-0 top-1/2 -translate-y-1/2 z-40 group" aria-label="{{ 'Our Commitment navigation'|t }}">
	<div
		class="flex items-stretch">

		{# Expanded panel — slides in from right edge on hover #}
		<div class="flex flex-col justify-center overflow-hidden bg-white border-y border-l border-slate-200 rounded-l-2xl shadow-xl w-0 opacity-0 group-hover:w-56 group-hover:opacity-100 transition-all duration-300 ease-out">
			<div class="min-w-[14rem] px-4 py-5">
				<p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400 whitespace-nowrap">{{ active_nav_parent ? active_nav_parent.title : 'Navigation'|t }}</p>
				<ul class="space-y-0.5">
					{% for sub in sub_items %}
						<li>
							<a href="{{ sub.url }}" class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors whitespace-nowrap{% if current_path == sub.url %} bg-slate-100 font-semibold text-slate-900{% else %} text-slate-600 hover:bg-slate-50 hover:text-slate-900{% endif %}">
								<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }} w-4 text-center text-xs{% if current_path == sub.url %} text-[#b13634]{% else %} text-slate-400{% endif %}" aria-hidden="true"></i>
								{{ sub.title }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>

		{# Tab strip — always visible on right edge, collapses border-radius on hover #}
		<div class="flex flex-col items-center justify-center gap-2.5 bg-[#b13634] rounded-l-2xl group-hover:rounded-l-none shadow-lg shadow-[#b13634]/30 px-2.5 py-5 min-w-[2.75rem] transition-all duration-300 cursor-default select-none">
			<i class="fa-solid fa-layer-group text-white/90 text-md" aria-hidden="true"></i>
			<div class="w-px h-2 bg-white/30 rounded-full"></div>
			{% for sub in sub_items %}
				<div class="rounded-full transition-colors {% if current_path == sub.url %}w-2 h-2 bg-white{% else %}w-1.5 h-1.5 bg-white/40 hover:bg-white/70{% endif %}" title="{{ sub.title }}"></div>
			{% endfor %}
		</div>

	</div>
</section>