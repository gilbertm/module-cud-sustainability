									Dr. Aseel Takshe
									<span class="ml-2 inline-flex items-center rounded-full bg-[#b13634] px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-white">{{ 'Chair'|t }}</span>
								</td>
								<td class="px-4 py-3.5 text-slate-500">Acting Dean, School of Health Sciences and Psychology</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3.5 font-medium text-slate-800">Dr. Adam Fenech</td>
								<td class="px-4 py-3.5 text-slate-500">Canada Research Chair, Culture of Work Committee Member</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3.5 font-medium text-slate-800">Dr. Abir Hamze</td>
								<td class="px-4 py-3.5 text-slate-500">Assistant Professor, School of Health Sciences and Psychology</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
