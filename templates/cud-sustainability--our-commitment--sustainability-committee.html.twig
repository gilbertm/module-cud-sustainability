							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3.5 font-medium text-slate-800">Chloe Bennett</td>
								<td class="px-4 py-3.5 text-slate-500">Assistant Professor of Practice, Faculty of Communication, Arts and Sciences</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3.5 font-medium text-slate-800">Dr. Chureerat Haq</td>
