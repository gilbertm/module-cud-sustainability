{#
/**
 * @file
 * Inner-page template for /sustainability/our-commitment/governance.
 *
 * Variables:
 * - title: Page title string.
 * - content: Rendered node content (full view mode).
 * - carousel_items: Optional list of carousel slides.
 * - sections: Optional list of processed-text sections.
 * - primary_nav: Primary navigation array.
 * - secondary_nav: Secondary navigation array.
 * - mode: Display mode string ('main' or 'secondary').
 */
#}

{% set carousel_slides = carousel_items|default([]) %}

{% if carousel_slides %}
	<section class="carousel group relative mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Governance carousel'|t }}">
		<div class="w-full relative overflow-hidden">
			<div class="w-full flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Governance') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}
						<div class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>
					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>
					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}

{# ── Page Header with Breadcrumb ─────────────────────────────────────────────── #}
<section class="bg-white" aria-label="{{ 'Page header'|t }}">
	<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
		<nav class="mb-3 flex items-center gap-1.5 text-xs text-slate-500" aria-label="{{ 'Breadcrumb'|t }}">
			{% for link in breadcrumb %}
				{% if not loop.first %}
					<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
				{% endif %}
				{% if link.url %}
					<a href="{{ link.url }}" class="hover:text-slate-700 transition-colors">{{ link.text }}</a>
				{% else %}
					<span>{{ link.text }}</span>
				{% endif %}
			{% endfor %}
			{% if breadcrumb is not empty %}
				<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
			{% endif %}
			<span class="font-medium text-slate-700">{{ title }}</span>
		</nav>
		<div class="flex items-center gap-3">
			<h1 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{{ title }}</h1>
			{% if edit_url %}
				<a href="{{ edit_url }}" class="shrink-0 rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700" title="{{ 'Edit node'|t }}" aria-label="{{ 'Edit'|t }}">
					<i class="fa-solid fa-pen-to-square text-sm" aria-hidden="true"></i>
				</a>
			{% endif %}
		</div>
	</div>
</section>

{# ── Shared sub-nav data ──────────────────────────────────────────────────────── #}

{# Icon map for all seeded primary nav children, keyed by URL #}
{% set icon_map = {
	'/sustainability/our-commitment/governance': 'fa-landmark',
	'/sustainability/our-commitment/sustainability-committee': 'fa-users',
	'/sustainability/our-commitment/institutional-policies': 'fa-file-lines',
	'/sustainability/our-commitment/impact-reporting': 'fa-chart-bar',
	'/sustainability/our-commitment/un-sustainable-development-goals': 'fa-leaf',
	'/sustainability/our-commitment/ethical-compliance': 'fa-gavel'
} %}

{# Derive sub_items from the matching top-level primary nav parent #}
{% set active_nav_parent = null %}
{% for item in primary_nav %}
	{% if item.children and (current_path == item.url or current_path starts with (item.url ~ '/')) %}
		{% set active_nav_parent = item %}
	{% endif %}
{% endfor %}
{% set sub_items = active_nav_parent ? active_nav_parent.children : [] %}

{# ── Mobile / tablet sub-nav strip (hidden on lg+) ───────────────────────────── #}
<div class="lg:hidden border-b border-slate-100 bg-white px-4 sm:px-6">
	<nav class="flex flex-wrap gap-1.5 py-2.5" aria-label="{{ 'Our Commitment navigation'|t }}">
		{% for sub in sub_items %}
			<a href="{{ sub.url }}" class="inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium transition-colors{% if current_path == sub.url %} bg-slate-900 text-white{% else %} text-slate-600 hover:bg-slate-100 hover:text-slate-900{% endif %}">
				<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }} shrink-0" aria-hidden="true"></i>
				{{ sub.title }}
			</a>
		{% endfor %}
	</nav>
</div>

{# ── Main Content (full-width) ────────────────────────────────────────────────── #}
<section class="mx-auto max-w-7xl px-4 lg:px-8 !bg-white" id="main-content" aria-label="{{ title }}" data-mode="{{ mode }}">
	<div
		class="min-w-0 space-y-5">
		{# ── Role of the Committee ─────────────────────────────────────────────── #}
		<div
			class="space-y-5">

			{# ── Purpose ── #}
			<div class="block-common-content" aria-labelledby="heading-purpose">
				<h2 id="heading-purpose" class="text-md md:text-xl font-semibold cud-color-blue">{{ 'Role of the Committee'|t }}</h2>
				<h3 id="subheading-purpose" class="mb-2 text-md md:text-lg cud-color-blue">{{ 'Purpose'|t }}</h3>
				<p class="text-sm text-slate-700">The CUD Sustainability Committee supports Canadian University Dubai's efforts to improve how sustainability is considered across the institution. It provides guidance and input on initiatives related to campus operations, academic activities, and community engagement, with the aim of encouraging responsible use of resources and increased awareness of sustainability practices. The Committee also helps ensure alignment with UAE sustainability priorities, including Net Zero 2050, as well as relevant international frameworks.</p>
			</div>

			{# ── Term of Reference ── #}
			<section aria-labelledby="heading-tor">
				<div class="block-common-content" aria-labelledby="heading-tor">
					<h2 id="heading-tor" class="text-md md:text-xl font-semibold cud-color-blue">{{ 'Term of Reference'|t }}</h2>
					<p class="text-sm text-slate-700">The CUD Sustainability Committee shall:</p>
				</div>

				<div class="overflow-hidden">
					<ul class="space-y-1.5" role="list">
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Provide advice on aligning university practices with UAE sustainability priorities (including Net Zero 2050) and relevant international standards.</p>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Recommend practical initiatives to improve sustainability across campus operations, including areas such as energy use, water consumption, and waste management.</p>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Contribute to the development of sustainability-related policies, guidelines, and action plans where needed.</p>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Review available data on resource use and suggest areas where improvements can be made.</p>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Provide input on how sustainability concepts can be incorporated into academic programs, research activities, and student projects.</p>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Encourage collaboration between departments on sustainability-related activities and projects.</p>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Support awareness campaigns, events, and student-led initiatives that encourage more sustainable practices within the university community.</p>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Help strengthen connections with external stakeholders, including industry, government entities, and community partners.</p>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Attend meetings regularly, review shared materials in advance, and provide constructive input.</p>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Ensure that quorum includes representation from both academic and administration units.</p>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Maintain confidentiality of discussions and any sensitive information shared within the Committee.</p>
						</li>
						<li class="flex gap-3">
							<span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[#b13634]/10">
								<span class="h-1.5 w-1.5 rounded-full bg-[#b13634]"></span>
							</span>
							<p class="text-sm leading-relaxed text-slate-700">Members must disclose any conflict of interest and recuse themselves from related discussions or decisions.</p>
						</li>
					</ul>
				</div>
			</section>

			{# ── Frequency of Meetings ── #}
			<div class="block-common-content" aria-labelledby="heading-meetings">
				<h2 id="heading-meetings" class="text-md md:text-xl font-semibold cud-color-blue">{{ 'Frequency of Meetings'|t }}</h2>
				<p class="text-sm text-slate-700">The CUD Sustainability Committee shall meet at least once per semester, with additional meetings convened as required. The Chair is responsible for ensuring the meetings are scheduled. An agenda shall be circulated in advance, and minutes shall be recorded, approved, and maintained. A copy of the minutes shall be submitted to the Dean of Institutional Research and Planning for record-keeping and reference.</p>
			</div>

			{# ── Committee Members ── #}
			<section aria-labelledby="heading-members">

				<div class="block-common-content mb-3" aria-labelledby="heading-members">
					<h2 id="heading-members" class="text-md md:text-xl font-semibold cud-color-blue">{{ 'Committee Members'|t }}</h2>
					<p class="text-sm text-slate-700">The membership of the CUD Sustainability Committee includes representatives from across the university:</p>
