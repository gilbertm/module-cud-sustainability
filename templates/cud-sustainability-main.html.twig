									<span class="relative flex h-8 w-1.5 items-end rounded-[2px] bg-slate-100" role="gridcell" tabindex="0" aria-label="{{ point.year }}: Sustainability output {{ point.count }}">
										<span class="block w-full bg-[#b13634] transition-opacity duration-200 group-hover/bar:opacity-85" style="height: {{ point.pct }}%;" title="Sustainability output {{ point.year }}: {{ point.count }}"></span>
									</span>
									{% if loop.first or loop.last %}
										<span class="text-[8px] font-medium leading-none text-slate-500">{{ point.year }}</span>
									{% else %}
										<span class="h-[0.5rem]" aria-hidden="true"></span>
									{% endif %}
								</div>
							{% endfor %}
						</div>
					</div>
				{% endif %}
			</article>
		{% endfor %}
	</div>
</section>



