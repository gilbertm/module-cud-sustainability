						<div class="mt-3 flex flex-wrap gap-2">
							{% for tag in researcher.expertise %}
								<a href="{{ research_link_sdg }}" class="inline-flex rounded-full border border-slate-200 px-3 py-1 text-xs font-semibold tracking-[0.08em] text-slate-700 transition-colors hover:border-sky-500 hover:text-sky-700">{{ tag }}</a>
							{% endfor %}
						</div>
					{% endif %}
