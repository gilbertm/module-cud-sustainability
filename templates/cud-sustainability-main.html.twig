							<span class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-900">
								<i class="fa-solid fa-circle text-[7px] text-amber-500" aria-hidden="true"></i>
								SDG 11 ● Sustainable Cities
							</span>
						</a>
					</li>
					<li>
						<a href="#" class="flex rounded-[25px] border border-slate-200 px-4 py-2 transition-colors duration-300 hover:border-teal-500/70 hover:shadow-[0_12px_28px_rgba(15,23,42,0.06)]">
