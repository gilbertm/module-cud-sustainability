{#
/**
 * @file
 * Main presentation template for CUD Sustainability pages.
 */
#}

{% set carousel_slides = carousel_items|default([]) %}
{% set research_link_overview = research_home_url|default('/') %}
{% set research_link_strategy = (secondary_nav|default([])|length > 0) ? secondary_nav[0].url : research_link_overview %}
{% set research_link_publications = (primary_nav|default([])|length > 2) ? primary_nav[2].url : research_link_overview %}
{% set research_link_clusters = (primary_nav|default([])|length > 1) ? primary_nav[1].url : research_link_overview %}
{% set research_link_researchers = (secondary_nav|default([])|length > 1) ? secondary_nav[1].url : research_link_overview %}
{% set research_link_sdg = (secondary_nav|default([])|length > 2) ? secondary_nav[2].url : research_link_overview %}
{% set research_link_calendar = research_link_overview %}

{% if carousel_slides %}
	<section class="carousel group relative mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Sustainability highlights carousel'|t }}">
		<div class="relative overflow-hidden">
			<div class="flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame aspect-[2.6/1] min-h-[360px] overflow-hidden sm:min-h-[420px] lg:min-h-[500px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame aspect-[2.6/1] min-h-[360px] overflow-hidden sm:min-h-[420px] lg:min-h-[500px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Sustainability highlight') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}

						<div
							class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>
						
					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>

					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>

					<div class="absolute bottom-3 left-1/2 z-10 flex w-[min(92vw,680px)] -translate-x-1/2 items-center gap-2 sm:bottom-6">
						<div class="flex min-w-0 flex-1 items-center gap-3 rounded-full bg-black/35 px-3 py-2 text-white backdrop-blur-md">
							<div class="flex min-w-[2.75rem] justify-end text-xs font-semibold tracking-wider" data-cud-carousel-count>1 /
								{{ carousel_slides|length }}</div>
							<div class="h-1.5 flex-1 overflow-hidden rounded-full bg-white/30">
								<span class="block h-full w-0 rounded-full bg-white" data-cud-carousel-progress-bar></span>
							</div>
							<div class="flex items-center gap-2">
								{% for item in carousel_slides %}
									<button class="h-2 rounded-full transition-all focus:outline-none focus:ring-2 focus:ring-white{% if loop.first %} w-8 bg-white{% else %} w-2 bg-white/50 hover:bg-white/80{% endif %}" data-cud-carousel-dot="{{ loop.index0 }}" aria-label="{{ 'Go to slide @num'|t({'@num': loop.index}) }}"></button>
								{% endfor %}
							</div>
						</div>
						<button class="flex h-9 w-9 flex-none items-center justify-center rounded-full bg-black/35 text-white/70 backdrop-blur-md transition-colors hover:bg-white/15 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50" data-cud-carousel-toggle aria-label="{{ 'Pause carousel'|t }}" aria-pressed="false">
							<i class="fa-solid fa-pause h-3.5 w-3.5" data-icon-pause aria-hidden="true"></i>
							<i class="fa-solid fa-play h-3.5 w-3.5 hidden" data-icon-play aria-hidden="true"></i>
						</button>
					</div>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}


<section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-4 lg:py-6" data-mode="{{ mode }}">
	<div class="mb-6 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
		<h2 class="text-2xl font-semibold tracking-tight cud-color-blue sm:text-3xl">Priority Sustainability Themes</h2>
		<a href="{{ research_link_clusters }}" class="inline-flex w-fit items-center rounded-md px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:border-sky-600 hover:text-sky-700 cud-red">Explore All Themes <i class="mx-2 cud-red fa-solid fa-arrow-right-long h-3.5 w-3.5" aria-hidden="true"></i></a>
	</div>

	<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5">
		<article class="group relative overflow-hidden rounded-2xl border-b border-slate-200 bg-white p-5 shadow-[0_10px_28px_rgba(15,23,42,0.07)] transition-shadow duration-300 hover:shadow-[0_16px_30px_rgba(15,23,42,0.10)] lg:p-6">
			<div class="-mx-5 -mt-5 mb-4 overflow-hidden border-x border-t border-slate-200 sm:-mx-6 sm:-mt-6">
				<img src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=1200&q=80" alt="Artificial intelligence and data science sustainability" loading="lazy" class="h-44 w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]">
			</div>
			<h3 class="mt-3 text-lg font-semibold text-slate-900">Artificial Intelligence and Data Science</h3>
			<p class="mt-2 text-sm leading-6 text-slate-600">Sustainability on machine learning, predictive analytics, responsible AI, and decision intelligence for industry and public impact.</p>
		</article>

		<article class="group relative overflow-hidden rounded-2xl border-b border-slate-200 bg-white p-5 shadow-[0_10px_28px_rgba(15,23,42,0.07)] transition-shadow duration-300 hover:shadow-[0_16px_30px_rgba(15,23,42,0.10)] lg:p-6">
			<div class="-mx-5 -mt-5 mb-4 overflow-hidden border-x border-t border-slate-200 sm:-mx-6 sm:-mt-6">
				<img src="https://images.unsplash.com/photo-1473448912268-2022ce9509d8?auto=format&fit=crop&w=1200&q=80" alt="Sustainability and environmental studies sustainability" loading="lazy" class="h-44 w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]">
			</div>
			<h3 class="mt-3 text-lg font-semibold text-slate-900">Sustainability and Environmental Studies</h3>
			<p class="mt-2 text-sm leading-6 text-slate-600">Cross-disciplinary work addressing climate adaptation, resource efficiency, renewable transitions, and resilient ecological systems.</p>
		</article>

		<article class="group relative overflow-hidden rounded-2xl border-b border-slate-200 bg-white p-5 shadow-[0_10px_28px_rgba(15,23,42,0.07)] transition-shadow duration-300 hover:shadow-[0_16px_30px_rgba(15,23,42,0.10)] lg:p-6">
			<div class="-mx-5 -mt-5 mb-4 overflow-hidden border-x border-t border-slate-200 sm:-mx-6 sm:-mt-6">
				<img src="https://images.unsplash.com/photo-1518773553398-650c184e0bb3?auto=format&fit=crop&w=1200&q=80" alt="Cybersecurity and digital resilience sustainability" loading="lazy" class="h-44 w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]">
			</div>
			<h3 class="mt-3 text-lg font-semibold text-slate-900">Cybersecurity and Digital Resilience</h3>
			<p class="mt-2 text-sm leading-6 text-slate-600">Focused sustainability on secure systems, privacy engineering, critical infrastructure protection, and resilient digital operations.</p>
		</article>
	</div>
</section>

<section class="mx-auto max-w-7xl px-4 py-8  lg:mb-8 sm:px-6 sm:py-10 lg:px-4 lg:py-6" aria-label="{{ 'Sustainability Navigation'|t }}" data-mode="{{ mode }}">
	<div class="mb-6 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
		<h2 class="text-2xl font-semibold tracking-tight cud-color-blue sm:text-3xl">{{ 'Explore Our Sustainability'|t }}</h2>
	</div>
	<div class="grid gap-4 sm:grid-cols-2">

			{% set nav_links = [
				{ number: '01', label: 'Mission',                  sub: 'Our sustainability purpose and values',           url: research_link_overview },
				{ number: '02', label: 'Sustainability Strategy',        sub: 'Priorities, focus areas and roadmap',       url: research_link_strategy },
				{ number: '03', label: 'Sustainability Overview',        sub: 'Scope, scale and key statistics',           url: research_link_overview },
				{ number: '04', label: 'Sustainability Governance',      sub: 'Committees, policies and accountability',   url: research_link_overview },
				{ number: '05', label: 'Sustainability Policies',        sub: 'Ethics, compliance and guidelines',         url: research_link_overview },
				{ number: '06', label: 'Sustainability Events',          sub: 'Seminars, workshops and conferences',       url: research_link_calendar },
				{ number: '07', label: 'Sustainability Projects',        sub: 'Active and completed projects',             url: research_link_clusters },
				{ number: '08', label: 'Publications',             sub: 'Journals, books and conference papers',     url: research_link_publications },
				{ number: '09', label: 'CUD Sustainabilityers Profiles', sub: 'Faculty researchers and their work',        url: research_link_researchers },
				{ number: '10', label: 'Sustainability Labs and Units',  sub: 'Specialised facilities and centres',        url: research_link_clusters },
				{ number: '11', label: 'Sustainability Partnerships',    sub: 'Industry and academic collaborations',      url: research_link_overview },
				{ number: '12', label: 'Contact',                  sub: 'Get in touch with our sustainability office',     url: research_link_overview }
			] %}

			{% for col_links in nav_links|batch(6) %}
				<ul class="list bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
					{% for item in col_links %}
						<li class="list-row group border-b border-slate-100 last:border-b-0 transition-colors duration-150 hover:bg-slate-50">
							<a href="{{ item.url }}" class="flex w-full items-center gap-4 px-5 py-4 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#b13634]">
								<div class="text-3xl font-thin tabular-nums text-slate-300 group-hover:text-[#b13634] transition-colors duration-150 shrink-0 w-10 text-right">{{ item.number }}</div>
								<div class="list-col-grow min-w-0">
									<div class="text-sm font-semibold text-slate-800 group-hover:text-[#172550] truncate">{{ item.label }}</div>
									<div class="text-xs font-medium uppercase tracking-wide text-slate-400 truncate">{{ item.sub }}</div>
								</div>
								<div class="shrink-0 text-slate-300 group-hover:text-[#b13634] transition-colors duration-150">
									<i class="fa-solid fa-arrow-right-long" aria-hidden="true"></i>
								</div>
							</a>
						</li>
					{% endfor %}
				</ul>
			{% endfor %}

	</div>
</section>


