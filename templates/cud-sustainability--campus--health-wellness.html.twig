{#
/**
 * @file
 * Inner-page template for /sustainability/our-commitment/governance.
 *
 * Variables:
 * - title: Page title string.
 * - content: Rendered node content (full view mode).
 * - carousel_items: Optional list of carousel slides.
 * - sections: Optional list of processed-text sections.
 * - primary_nav: Primary navigation array.
 * - secondary_nav: Secondary navigation array.
 * - mode: Display mode string ('main' or 'secondary').
 */
#}

{% set carousel_slides = carousel_items|default([]) %}

{% if carousel_slides %}
	<section class="carousel group relative mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Governance carousel'|t }}">
		<div class="w-full relative overflow-hidden">
			<div class="w-full flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Governance') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}
						<div class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>
					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>
					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}

{# ── Page Header with Breadcrumb ─────────────────────────────────────────────── #}
<section class="bg-white" aria-label="{{ 'Page header'|t }}">
	<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
		<nav class="mb-3 flex items-center gap-1.5 text-xs text-slate-500" aria-label="{{ 'Breadcrumb'|t }}">
			{% for link in breadcrumb %}
				{% if not loop.first %}
					<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
				{% endif %}
				{% if link.url %}
					<a href="{{ link.url }}" class="hover:text-slate-700 transition-colors">{{ link.text }}</a>
				{% else %}
					<span>{{ link.text }}</span>
				{% endif %}
			{% endfor %}
			{% if breadcrumb is not empty %}
				<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
			{% endif %}
			<span class="font-medium text-slate-700">{{ title }}</span>
		</nav>
		<div class="flex items-center gap-3">
			<h1 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{{ title }}</h1>
			{% if edit_url %}
				<a href="{{ edit_url }}" class="shrink-0 rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700" title="{{ 'Edit node'|t }}" aria-label="{{ 'Edit'|t }}">
					<i class="fa-solid fa-pen-to-square text-sm" aria-hidden="true"></i>
				</a>
			{% endif %}
		</div>
	</div>
</section>

{# ── Shared sub-nav data ──────────────────────────────────────────────────────── #}

{# Icon map for all seeded primary nav children, keyed by URL #}
{% set icon_map = {
	'/sustainability/campus/health-wellness': 'fa-heart-pulse',
	'/sustainability/campus/sustainable-infrastructure': 'fa-solar-panel',
	'/sustainability/campus/path-to-net-zero': 'fa-seedling'
} %}

{# Derive sub_items from the matching top-level primary nav parent #}
{% set active_nav_parent = null %}
{% for item in primary_nav %}
	{% if item.children and (current_path == item.url or current_path starts with (item.url ~ '/')) %}
		{% set active_nav_parent = item %}
	{% endif %}
{% endfor %}
{% set sub_items = active_nav_parent ? active_nav_parent.children : [] %}

{# ── Mobile / tablet sub-nav strip (hidden on lg+) ───────────────────────────── #}
<div class="lg:hidden border-b border-slate-100 bg-white px-4 sm:px-6">
	<nav class="flex gap-1.5 overflow-x-auto py-2.5 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" aria-label="{{ 'Our Commitment navigation'|t }}">
		{% for sub in sub_items %}
			<a href="{{ sub.url }}" class="inline-flex flex-none items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium transition-colors{% if current_path == sub.url %} bg-slate-900 text-white{% else %} text-slate-600 hover:bg-slate-100 hover:text-slate-900{% endif %}">
				<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }}" aria-hidden="true"></i>
				{{ sub.title }}
			</a>
		{% endfor %}
	</nav>
</div>

{# ── Main Content (full-width) ────────────────────────────────────────────────── #}
<section class="mx-auto max-w-7xl px-4 lg:px-8 !bg-white" id="main-content" aria-label="{{ title }}" data-mode="{{ mode }}">
	<div
		class="min-w-0 space-y-5">


		{# ── Health and Wellness Intro ────────────────────────────────────────── #}
		<div class="block-common-content">

			<ul class="grid gap-3 grid-cols-1 md:grid-cols-2 lg:grid-cols-3 mb-4 lg:mb-8" role="list">
				<li>
					<a href="/sustainability/campus/health-wellness#mental-health-support-main" class="flex items-center gap-3 rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-700 transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-slate-900 group/link">
						<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600 transition-colors group-hover/link:bg-[#b13634]/10 group-hover/link:text-[#b13634]">
							<i class="fa-solid fa-brain text-[#b13634] text-base shrink-0" aria-hidden="true"></i>
						</span>
						<span class="leading-snug">{{ 'Mental Health Support'|t }}</span>
						<i class="fa-solid fa-chevron-right ml-auto text-[10px] text-slate-300 transition-colors group-hover/link:text-[#b13634]" aria-hidden="true"></i>
					</a>

				</li>
				<li>
					<a href="/sustainability/campus/health-wellness#sexual-reproductive-health" class="flex items-center gap-3 rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-700 transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-slate-900 group/link">
						<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600 transition-colors group-hover/link:bg-[#b13634]/10 group-hover/link:text-[#b13634]">
							<i class="fa-solid fa-venus-mars text-[#b13634] text-base shrink-0" aria-hidden="true"></i>
						</span>
						<span class="leading-snug">{{ 'Sexual and Reproductive Health-Care'|t }}</span>
						<i class="fa-solid fa-chevron-right ml-auto text-[10px] text-slate-300 transition-colors group-hover/link:text-[#b13634]" aria-hidden="true"></i>
					</a>

				</li>			
				<li>

					<a href="/sustainability/campus/health-wellness#affordable-healthy-food-on-campus" class="flex items-center gap-3 rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-700 transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-slate-900 group/link">
						<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600 transition-colors group-hover/link:bg-[#b13634]/10 group-hover/link:text-[#b13634]">
							<i class="fa-solid fa-apple-whole text-[#b13634] text-base shrink-0" aria-hidden="true"></i>
						</span>
						<span class="leading-snug">{{ 'Affordable and Healthy Food Options on Campus'|t }}</span>
						<i class="fa-solid fa-chevron-right ml-auto text-[10px] text-slate-300 transition-colors group-hover/link:text-[#b13634]" aria-hidden="true"></i>
					</a>

				</li>

				<li>

					<a href="/sustainability/campus/health-wellness#physical-fitness" class="flex items-center gap-3 rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-700 transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-slate-900 group/link">
						<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600 transition-colors group-hover/link:bg-[#b13634]/10 group-hover/link:text-[#b13634]">
							<i class="fa-solid fa-dumbbell text-[#b13634] text-base shrink-0" aria-hidden="true"></i>
						</span>
						<span class="leading-snug">{{ 'On-Campus Physical Fitness'|t }}</span>
						<i class="fa-solid fa-chevron-right ml-auto text-[10px] text-slate-300 transition-colors group-hover/link:text-[#b13634]" aria-hidden="true"></i>
					</a>

				</li>
				<li>

					<a href="/sustainability/campus/health-wellness#health-awareness-initiatives-main" class="flex items-center gap-3 rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-[#b13634]">
						<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-[#b13634]/10 text-[#b13634] transition-colors group-hover:bg-[#b13634] group-hover:text-white">
							<i class="fa-solid fa-heart-pulse text-base shrink-0" aria-hidden="true"></i>
						</span>
						<span class="leading-snug">{{ 'Health Awareness Initiatives and Education'|t }}</span>
						<i class="fa-solid fa-chevron-right ml-auto text-[10px] text-slate-300 transition-colors group-hover:text-[#b13634]" aria-hidden="true"></i>
					</a>

				</li>

			</ul>


			<p class="text-slate-700 text-sm leading-relaxed">{{ 'Canadian University Dubai supports the health and wellbeing of its community through on campus health services, personal counselling, and health promotion initiatives. CUD also boasts a wide range of facilities and services for its community – including affordable and healthy food options on and around campus in City Walk, and a well-equipped free-access Gym in the HUB Building on campus.'|t }}</p>
			<p class="text-slate-700 text-sm leading-relaxed">{{ 'In addition, CUD provides medical and life insurance coverage for faculty and staff, including access to a broad range of healthcare services and, in exceptional cases, further support beyond standard coverage based on individual circumstances and institutional approval.'|t }}</p>

		</div>

		{# ── CUD Health Centre ────────────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-health-centre">
			<h2 id="heading-health-centre" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'CUD Health Centre'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'The CUD Health Centre provides primary healthcare support for students, faculty and staff, including first aid, care for minor illnesses and injuries, health education, disease prevention guidance, emergency referral support, and information on health insurance benefits, coverage and networks. Health Centre services are available free of charge, and the University also promotes wellbeing through counselling, awareness activities, and community health campaigns that contribute to a safe, supportive and health-conscious campus environment. These activities are shared with Student Affairs and HR department.'|t }}</p>

			{# Health Centre image placeholder #}
			<div class="lazy-loading relative w-full mb-3">
				<span class="image-loader absolute inset-0 flex items-center justify-center bg-white/60 z-10">
					<i class="fa-solid fa-arrow-rotate-right animate-spin text-green-700 text-3xl" aria-hidden="true"></i>
				</span>
				<img src="//www.cud.ac.ae/sites/default/files/general/2016/health-centre-1920x1080.jpg" alt="{{ 'CUD Health Centre'|t }}" class="w-full h-auto object-cover rounded-lg shadow" loading="lazy" onload="this.previousElementSibling.style.display='none'"/>
			</div>

			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'Canadian University Dubai provides free-of-charge medical services to all students.'|t }}</p>
			<ul class="space-y-2 mb-0">
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'On-Campus Health Centre:'|t }}</strong>
						{{ 'Licensed nurses provide first-aid, medical consultations, and vital signs monitoring at no cost to the student body.'|t }}</span>
				</li>
				
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Chronic Condition Management:'|t }}</strong>
						{{ 'Students and staff with chronic illnesses or physical disabilities can submit medical reports to the Health Centre to arrange specialized on-campus assistance, including the safe storage of medications and emergency care coordination.'|t }}</span>
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Physical Accessibility:'|t }}</strong>
						{{ 'The Health Centre is strategically located on the ground floor of the CUD Hub, ensuring it is readily reachable for all students, including those with limited mobility.'|t }}</span>
				</li>
			</ul>
		</div>

			
		{# ── Sexual and Reproductive Health-Care Guide ─────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="sexual-reproductive-health">
			<h2 id="sexual-reproductive-health" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Sexual and Reproductive Health-Care Guide'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'The licensed nurses are able to provide guidance and advice where appropriate for students and staff who wish to avail to the services.'|t }}</p>
		</div>

		{# ── Mental Health Support ─────────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="mental-health-support-main">
			<h2 id="mental-health-support-main" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Mental Health Support'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'CUD recognizes that mental wellbeing is a cornerstone of social sustainability and academic success. Staff and faculty are also offered mental wellbeing support throughout their entire CUD career.'|t }}</p>
			<ul class="space-y-2 mb-4">
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Professional Counselling:'|t }}</strong>
						{{ 'The university employs a dedicated Student Counsellor who provides confidential one-on-one sessions to address personal, psychological, or learning needs.'|t }}</span>
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Minority Support:'|t }}</strong>
						{{ 'Our counselling framework explicitly addresses "Minority Concerns," ensuring that students from diverse ethnic and cultural backgrounds have a safe space to discuss unique challenges.'|t }}</span>
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Confidentiality Protocols:'|t }}</strong>
						{{ 'All counselling and medical interactions are governed by strict confidentiality policies to ensure student and staff&rsquo;s safety and privacy.'|t }}</span>
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Medical Insurance Coverage for External Support:'|t }}</strong>
						{{ 'Eligible employees may access mental health and counselling support through CUD&rsquo;s medical insurance coverage, in accordance with the terms and benefits of the applicable plan. This complements the University&rsquo;s broader mental health support services available to the CUD community.'|t }}</span>
				</li>
			</ul>
			<p class="text-slate-700 text-sm leading-relaxed mb-2">{{ 'Beyond clinical care and mental wellbeing support, CUD fosters resilience and life skills through the'|t }}
				<strong>{{ 'Student Success Centre (SSC)'|t }}</strong>.</p>
			<ul class="space-y-2">
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Holistic Development:'|t }}</strong>
						{{ 'The SSC hosts regular workshops focused on confidence-building, time management, and study skills to help students overcome learning hurdles.'|t }}</span>
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Confidentiality and Safety:'|t }}</strong>
						{{ 'All medical and psychological records are maintained with the highest standards of privacy, ensuring a safe space for students to seek help.'|t }}</span>
				</li>
			</ul>
		</div>

		{# ── Food and Exercise ─────────────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-food-exercise">
			<h1 id="heading-food-exercise" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Food and Exercise'|t }}</h1>
			<p class="text-slate-700 text-sm leading-relaxed mb-4">{{ 'At Canadian University Dubai, we recognize that healthy and affordable access to food and fitness is essential for a thriving academic community. Our provisions ensure that maintaining a balanced lifestyle is both convenient and financially accessible for all students and staff.'|t }}</p>

			<h2 id="affordable-healthy-food-on-campus" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Affordable and Healthy Food Options on Campus'|t }}</h2>

			<h3 class="text-base font-semibold text-slate-800 mt-4 mb-2">{{ 'CUD Café'|t }}</h3>

			{# ── Café Gallery ── #}
			<div class="mb-4 flex flex-wrap justify-center gap-3 sm:gap-4" aria-label="{{ 'CUD Café Gallery'|t }}">
				{% for i in 1..4 %}
					<figure class="group overflow-hidden rounded-xl ring-1 ring-slate-900/5 shadow-sm bg-white w-[calc(50%-0.375rem)] lg:w-[calc(25%-0.75rem)]">
						<div class="overflow-hidden lazy-loading relative">
							<span class="image-loader absolute inset-0 flex items-center justify-center bg-white/60 z-10">
								<i class="fa-solid fa-arrow-rotate-right animate-spin text-green-700 text-3xl" aria-hidden="true"></i>
							</span>
							<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/health-wellness/cafe-0' ~ i ~ '.jpg' }}"
								 alt="{{ 'CUD Café photo'|t }} {{ i }}"
								 class="tc-lightbox w-full h-48 sm:h-56 object-cover transition-transform duration-300 group-hover:scale-105"
								 loading="lazy"
								 onload="this.previousElementSibling.style.display='none'">
						</div>
					</figure>
				{% endfor %}
			</div>

			<p class="text-slate-700 text-sm leading-relaxed mb-2">{{ 'The CUD Café serves as our primary on-campus dining facility, prioritized for affordability and environmental responsibility.'|t }}</p>
			<ul class="space-y-2 mb-4">
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Affordable Pricing:'|t }}</strong>
						{{ 'The Café offers a menu priced significantly lower than surrounding outlets in the City Walk district, ensuring that nutritious meals are accessible to the entire student body.'|t }}</span>
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Eco-Conscious Materials:'|t }}</strong>
						{{ 'In line with our circular economy goals, the Café exclusively utilizes sustainably sourced materials, including biodegradable straws and takeaway containers.'|t }}</span>
				</li>
			</ul>

			<h3 class="text-base font-semibold text-slate-800 mt-4 mb-2">{{ 'CUDeals'|t }}</h3>
			<p class="text-slate-700 text-sm leading-relaxed mb-2">{{ 'We extend the affordability of the Dubai lifestyle through the CUDeals program, an exclusive loyalty initiative for the CUD community.'|t }}
				<strong>{{ 'For all CUDeals, visit'|t }}
					<a href="https://www.cud.ac.ae/cudeals" class="text-sky-700 hover:underline">https://www.cud.ac.ae/cudeals</a>
				</strong>.</p>
			<ul class="space-y-2 mb-4">
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Widespread Discounts:'|t }}</strong>
						{{ 'Students and staff can access discounts of up to'|t }}
						<strong>50%</strong>
						{{ 'at a wide array of partner restaurants, cafés, and daily supply outlets.'|t }}</span>
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Holistic Lifestyle Support:'|t }}</strong>
						{{ 'The program also covers non-food services, including entertainment, professional services, and health and wellness providers, helping to reduce the overall cost of living.'|t }}</span>
				</li>
			</ul>

			<h2 id="physical-fitness" class="text-base font-semibold text-slate-800 mt-4 mb-2">{{ 'On-Campus Physical Fitness'|t }}</h2>

			{# ── Gym Gallery ── #}
			<div class="mb-4 lg:mb-8 flex flex-wrap justify-center gap-3 sm:gap-4" aria-label="{{ 'CUD Gym Gallery'|t }}">
				{% for i in 1..4 %}
					<figure class="group overflow-hidden rounded-xl ring-1 ring-slate-900/5 shadow-sm bg-white w-[calc(50%-0.375rem)] lg:w-[calc(25%-0.75rem)]">
						<div class="overflow-hidden lazy-loading relative">
							<span class="image-loader absolute inset-0 flex items-center justify-center bg-white/60 z-10">
								<i class="fa-solid fa-arrow-rotate-right animate-spin text-green-700 text-3xl" aria-hidden="true"></i>
							</span>
							<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/health-wellness/gym-0' ~ i ~ '.jpg' }}"
								 alt="{{ 'CUD Gym photo'|t }} {{ i }}"
								 class="tc-lightbox w-full h-48 sm:h-56 object-cover transition-transform duration-300 group-hover:scale-105"
								 loading="lazy"
								 onload="this.previousElementSibling.style.display='none'">
						</div>
					</figure>
				{% endfor %}
			</div>

		
			<p class="text-slate-700 text-sm leading-relaxed mb-2">{{ 'Physical wellbeing is supported by our modern, on-campus fitness infrastructure.'|t }}</p>
			<ul class="space-y-2">
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Free Access:'|t }}</strong>
						{{ 'The CUD Gym is entirely free for all members of the CUD community to use, removing financial barriers to physical activity.'|t }}</span>
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-circle-check mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					<span>
						<strong>{{ 'Convenient Location:'|t }}</strong>
						{{ 'The facility is strategically located on the ground floor of the Hub Building, providing easy, barrier-free access for students and employees between classes or shifts.'|t }}</span>
				</li>
			</ul>
		</div>

		{# ── Health Awareness Initiatives and Education ────────────────────────── #}
		<div class="block-common-content" aria-labelledby="health-awareness-initiatives-main">
			<h2 id="health-awareness-initiatives-main" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Health Awareness Initiatives and Education'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'CUD supports the health and wellbeing of its community through on campus health services, counselling, health education, and preventive awareness initiatives.'|t }}</p>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'The CUD Health Centre provides primary healthcare support for students, faculty and staff, including first aid, care for minor illnesses and injuries, health education, disease prevention guidance, and referral support where needed.'|t }}</p>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'CUD also promotes wellbeing through personal counselling and health awareness activities delivered across the academic year.'|t }}</p>
			<p class="text-slate-700 text-sm leading-relaxed mb-4">{{ 'As part of its health awareness and education efforts, CUD has organised campaigns and sessions in collaboration with healthcare partners, including breast cancer and prostate cancer awareness initiatives, alongside free health checks offered during awareness activities for students, faculty and staff. For eligible employees, CUD also provides medical insurance benefits that include maternity coverage, supporting access to reproductive healthcare through the University&rsquo;s health benefits framework.'|t }}</p>

			<div class="mt-2">
				<p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400 mb-3">{{ 'Related Links'|t }}</p>
				<ul class="flex flex-col gap-2">
					<li>
						<a href="//www.cud.ac.ae/student-affairs/health-centre" class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-[#b13634]">
							<span class="flex items-center gap-2.5">
								<i class="fa-solid fa-heart-pulse w-4 text-center text-slate-400 group-hover:text-[#b13634] transition-colors" aria-hidden="true"></i>
								{{ 'CUD Student Affairs — Health Centre'|t }}
							</span>
							<i class="fa-solid fa-arrow-right text-xs text-slate-300 group-hover:text-[#b13634] transition-all group-hover:translate-x-0.5" aria-hidden="true"></i>
						</a>
					</li>
					<li>
						<a href="//www.cud.ac.ae/news/cud-joins-cancer-awareness-campaign" class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-[#b13634]">
							<span class="flex items-center gap-2.5">
								<i class="fa-solid fa-ribbon w-4 text-center text-slate-400 group-hover:text-[#b13634] transition-colors" aria-hidden="true"></i>
								{{ 'CUD joins Cancer Awareness Campaign'|t }}
							</span>
							<i class="fa-solid fa-arrow-right text-xs text-slate-300 group-hover:text-[#b13634] transition-all group-hover:translate-x-0.5" aria-hidden="true"></i>
						</a>
					</li>
					<li>
						<a href="//www.cud.ac.ae/news/world-mental-health-day-canadian-university-dubai" class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-[#b13634]">
							<span class="flex items-center gap-2.5">
								<i class="fa-solid fa-brain w-4 text-center text-slate-400 group-hover:text-[#b13634] transition-colors" aria-hidden="true"></i>
								{{ 'World Mental Health Day at Canadian University Dubai'|t }}
							</span>
							<i class="fa-solid fa-arrow-right text-xs text-slate-300 group-hover:text-[#b13634] transition-all group-hover:translate-x-0.5" aria-hidden="true"></i>
						</a>
					</li>
					<li>
						<a href="//www.cud.ac.ae/news/canadian-university-dubai-promotes-student-happiness-wellness-wednesdays" class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-[#b13634]">
							<span class="flex items-center gap-2.5">
								<i class="fa-solid fa-star w-4 text-center text-slate-400 group-hover:text-[#b13634] transition-colors" aria-hidden="true"></i>
								{{ 'CUD promotes Student Happiness — Wellness Wednesdays'|t }}
							</span>
							<i class="fa-solid fa-arrow-right text-xs text-slate-300 group-hover:text-[#b13634] transition-all group-hover:translate-x-0.5" aria-hidden="true"></i>
						</a>
					</li>
					<li>
						<a href="//www.cud.ac.ae/events/blood-donation-drive-2" class="group flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-[#b13634]">
							<span class="flex items-center gap-2.5">
								<i class="fa-solid fa-droplet w-4 text-center text-slate-400 group-hover:text-[#b13634] transition-colors" aria-hidden="true"></i>
								{{ 'Blood Donation Drive'|t }}
							</span>
							<i class="fa-solid fa-arrow-right text-xs text-slate-300 group-hover:text-[#b13634] transition-all group-hover:translate-x-0.5" aria-hidden="true"></i>
						</a>
					</li>
				</ul>
			</div>
		</div>

		{# ── Sports ───────────────────────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-sports">
			<h2 id="heading-sports" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Sports'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'At CUD we recognize that importance of staying healthy and active and offer a number of sporting activities to our students on campus.'|t }}</p>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'Students are encouraged to take part as an active role in sports at university can help them develop practical skills like team work, discipline, sportsmanship, cooperation, dedication and decision making, supporting both their physical and personality development, and helping them progress in the future.'|t }}</p>
			<p class="text-slate-700 text-sm leading-relaxed mb-4">{{ 'Our dedicated Sports Program offers students the opportunity for regular training and practices, intra and inter-mural competitions, and our sports teams play matches in tournaments and events across the UAE.'|t }}</p>

			<h3 class="text-base font-semibold text-slate-800 mt-2 mb-2">{{ 'Our sports programs include:'|t }}</h3>
			<ul class="space-y-1 mb-4">
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-futbol mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					{{ 'Football training'|t }}
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-basketball mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					{{ 'Basketball team training'|t }}
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-volleyball mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					{{ 'Volleyball training'|t }}
				</li>
			</ul>

			<h3 class="text-base font-semibold text-slate-800 mt-2 mb-2">{{ 'We also have teams representing the university in:'|t }}</h3>
			<ul class="space-y-1 mb-4">
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-table-tennis-paddle-ball mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					{{ 'Table tennis'|t }}
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-person-running mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					{{ 'Track and Field'|t }}
				</li>
				<li class="flex gap-2.5 text-sm text-slate-700">
					<i class="fa-solid fa-chess mt-0.5 w-4 shrink-0 text-[#b13634]" aria-hidden="true"></i>
					{{ 'Chess'|t }}
				</li>
			</ul>

			<div class="rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-5 sm:p-6 shadow-sm">
				<div class="flex items-start gap-4">
					<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#b13634]/10 text-[#b13634]">
						<i class="fa-solid fa-envelope text-lg" aria-hidden="true"></i>
					</div>
					<div class="min-w-0 flex-1">
						<p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400 mb-1">{{ 'Sports Program Contact'|t }}</p>
						<p class="text-sm font-semibold text-slate-900 mb-0">{{ 'Mr. Dusan Popovic'|t }}</p>
						<div class="mt-2 flex flex-col gap-1.5 text-sm">
							<div class="flex items-center gap-2.5 text-slate-700">
								<i class="fa-solid fa-envelope w-4 text-center text-[#b13634]" aria-hidden="true"></i>
								<a href="mailto:sports@cud.ac.ae" class="hover:text-[#b13634] transition-colors underline underline-offset-2">sports@cud.ac.ae</a>
							</div>
							<div class="flex items-center gap-2.5 text-slate-700">
								<i class="fa-solid fa-link w-4 text-center text-[#b13634]" aria-hidden="true"></i>
								<a href="https://www.cud.ac.ae/life-on-campus/sports" class="hover:text-[#b13634] transition-colors underline underline-offset-2">www.cud.ac.ae/life-on-campus/sports</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		{% if content %}
			<div class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-sky-700 prose-a:no-underline hover:prose-a:underline">
				{{ content }}
			</div>
		{% endif %}

		{% if sections %}
			<div class="mt-8 space-y-6">
				{% for section in sections %}
					<div class="prose prose-slate max-w-none">{{ section }}</div>
				{% endfor %}
			</div>
		{% endif %}

	</div>
