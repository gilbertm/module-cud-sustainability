				</article>
				<article class="flex flex-col items-center rounded-xl border border-slate-200 bg-white p-4 shadow-sm text-center w-[8rem] md:w-[14rem] max-w-xs" itemscope itemtype="https://schema.org/ListItem">
					<img src="/modules/custom/cud_sustainability/assets/images/sdgs/E-WEB-Goal-13.png" alt="SDG 13: Take urgent action to combat climate change and its impacts (United Nations Sustainable Development Goal 13 icon)" class=" mb-2" loading="lazy" decoding="async" itemprop="image" />
