{#
/**
 * @file
 * Responsive page shell for CUD Sustainability routes.
 *
 * This template owns the route-level header/footer and only delegates the page
 * body to page.content.
 *
 * Optional Drupal page regions available to enable later by uncommenting:
 *
 * <div class="sustainability-region sustainability-region--header">{{ page.header }}</div>
 * <div class="sustainability-region sustainability-region--primary-menu">{{ page.primary_menu }}</div>
 * <div class="sustainability-region sustainability-region--secondary-menu">{{ page.secondary_menu }}</div>
 * <div class="sustainability-region sustainability-region--highlighted">{{ page.highlighted }}</div>
 * <div class="sustainability-region sustainability-region--breadcrumb">{{ page.breadcrumb }}</div>
 * <div class="sustainability-region sustainability-region--help">{{ page.help }}</div>
 * <div class="sustainability-region sustainability-region--sidebar-first">{{ page.sidebar_first }}</div>
 * <div class="sustainability-region sustainability-region--sidebar-second">{{ page.sidebar_second }}</div>
 * <div class="sustainability-region sustainability-region--footer">{{ page.footer }}</div>
 */
#}

{{ attach_library('cud_sustainability/page') }}

{% set is_secondary = research_mode == 'secondary' %}
{% set accent_bg = is_secondary ? 'bg-orange-50' : 'bg-slate-50' %}
{% set accent_border = is_secondary ? 'border-orange-200' : 'border-slate-200' %}
{% set accent_text = is_secondary ? 'text-orange-700' : 'text-sky-700' %}
{% set footer_bg = is_secondary ? 'bg-orange-950 text-orange-100' : 'bg-[#414c55] text-slate-100' %}
{% set footer_link = is_secondary ? 'text-orange-200 hover:text-white' : 'text-sky-300 hover:text-white' %}
{% set logo_bg = is_secondary ? 'bg-orange-600' : 'bg-slate-900' %}
{% set page_primary_nav = primary_nav|default([]) %}
{% set page_secondary_nav = secondary_nav|default([]) %}
<script type="application/ld+json">
	{
				  "@context": "https://schema.org",
				  "@type": "EducationalOrganization",
				  "name": "Canadian University Dubai",
				  "url": "https://www.cud.ac.ae",
				  "logo": "https://www.cud.ac.ae/themes/indicud/media/logo/bigger/logo.png",
					"description": "CUD holds the prestigious Five-Star status as per the Quacquarelli Symonds (QS) Star University Rating System. The QS ranking system is recognized among the world's most respected university rankings.",
				  "address": {
				    "@type": "PostalAddress",
				    "addressLocality": "Dubai",
				    "addressCountry": "UAE"
				  },
				  "knowsAbout": [
				    "Sustainable Urban Systems",
				    "Secure & Ethical AI",
				    "Next-Gen Health Equity",
				    "Quantum Information Science"
				  ],
					"award": [
						"QS World University 5 Star Rating",
						"#1 Ranked University in Dubai for the fifth consecutive year (QS World University Rankings 2026)",
						"#4 for International Faculty Worldwide (QS World University Rankings 2025)",
						"#6 for International Students Worldwide (QS World University Rankings 2025)",
						"#21 in the Arab Region (QS Arab Region Rankings 2026)",
						"#22 among Private Universities Across Asia (AppliedHE ALL ASIA Private University Ranking 2026)",
						"#523 University Worldwide (QS World University Rankings 2025)"
					]
				}
</script>

<div class="cud-sustainability-page-layout min-h-screen {{ accent_bg }} text-slate-900">
	<a class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-slate-900 focus:px-4 focus:py-2 focus:text-white" href="#main-content">Skip to content</a>

	<header class="border-b {{ accent_border }} bg-white/90 backdrop-blur z-100" data-sustainability-sticky data-header-variant="daisyui">
		<div id="logo-navigation-daisyui" class="mx-auto flex max-w-7xl gap-5 px-4 py-4 sm:px-6 lg:px-8">
		<a class="sustainability-logo-link flex min-h-[60px] sm:min-h-[80px] items-center gap-4" href="{{ research_home_url }}">
			{% if research_logo_url %}
				<img alt="{{ research_site_name }}" class="h-[60px] max-h-[60px] sm:h-[80px] sm:max-h-[80px] w-auto object-contain" src="{{ research_logo_url }}">
				{% else %}
					<div class="min-w-0">
						<p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] {{ accent_text }}">CUD Sustainability</p>
						<p class="truncate text-base font-semibold text-slate-900 sm:text-lg">{{ research_site_name ?: 'Sustainability Hub' }}</p>
					</div>
				{% endif %}
			</a>

			<button type="button" class="sustainability-nav-toggle btn btn-square btn-ghost rounded-none" data-sustainability-nav-toggle aria-controls="sustainability-nav-panels-daisyui" aria-expanded="false">
				<span class="sr-only">{{ 'Toggle navigation'|t }}</span>
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" fill="currentColor" class="h-5 w-5" aria-hidden="true">
					<path d="M0 96C0 78.3 14.3 64 32 64H416c17.7 0 32 14.3 32 32s-14.3 32-32 32H32C14.3 128 0 113.7 0 96zM0 256c0-17.7 14.3-32 32-32H416c17.7 0 32 14.3 32 32s-14.3 32-32 32H32c-17.7 0-32-14.3-32-32zM448 416c0 17.7-14.3 32-32 32H32c-17.7 0-32-14.3-32-32s14.3-32 32-32H416c17.7 0 32 14.3 32 32z"/>
				</svg>
			</button>

			<div id="sustainability-nav-panels-daisyui" class="sustainability-nav-panels flex flex-col gap-3 items-end" data-sustainability-nav-panels>
				<div
					class="secondary-nav flex items-center gap-4 w-full justify-end">
					{# % if page_secondary_nav % }
											<nav class="sustainability-nav-list flex flex-wrap items-center gap-x-1 gap-y-2 rounded-2xl border-none" aria-label="{{ 'CUD Sustainability Secondary'|t }}">
												{% for item in page_secondary_nav %}
													{% set item_title = item.title|default(item.text|default('')) %}
													{% set item_url = item.url|default('#') %}
													{% set item_active = item.active|default(false) %}
													<a href="{{ item_url }}" class="rounded-full px-3.5 py-1 text-[12px] font-medium transition-colors{% if item_active %} bg-slate-700 text-[#858585] shadow-sm{% else %} text-[#858585] hover:text-[#757575]{% endif %}">{{ item_title }}</a>
												{% endfor %}
											</nav>
										{ % endif % #}
					<div id="disability-accessibility-daisyui" class="sustainability-a11y-toolbar" role="toolbar" aria-label="{{ 'Accessibility tools'|t }}">
						<button type="button" data-sustainability-font="increase" title="{{ 'Increase font size'|t }}" aria-label="{{ 'Increase font size'|t }}">
							<span aria-hidden="true">A<sup>+</sup>
							</span>
						</button>
						<button type="button" data-sustainability-font="decrease" title="{{ 'Decrease font size'|t }}" aria-label="{{ 'Decrease font size'|t }}">
							<span aria-hidden="true">A<sup>−</sup>
							</span>
						</button>
						<button type="button" data-sustainability-font="reset" title="{{ 'Reset font size'|t }}" aria-label="{{ 'Reset font size'|t }}">
							<span aria-hidden="true">A</span>
						</button>
					</div>
					<div class="inline-flex items-center border-0 px-3.5 py-1 text-sm font-medium text-slate-700">
						<span class="mr-1.5 inline-flex h-4 w-4 items-center justify-center" aria-hidden="true">
							<img src="/themes/indicud/media/icons/ca.svg" alt="Canada icon" class="h-3 w-auto object-contain">
						</span>
						<span class="text-sm">English</span>
					</div>
				</div>

				<div class="primary-navigation primary-nav flex w-full flex-col gap-2 lg:flex-row lg:items-center lg:justify-end">
					{% if page_primary_nav %}
						<nav class="sustainability-nav-list sustainability-primary-nav w-full lg:min-w-0 lg:flex-1" aria-label="{{ 'CUD Sustainability Primary (DaisyUI)'|t }}">
							<ul class="flex w-full flex-col gap-x-0.5 gap-y-2 rounded-2xl border-0 p-0 lg:flex-row lg:items-start lg:justify-end lg:flex-nowrap">
								{% for item in page_primary_nav %}
									{% set item_title = item.title|default(item.text|default('')) %}
									{% set item_url = item.url|default('#') %}
									{% set item_children = item.children|default(item.below|default([])) %}
									{% if item_children %}
										<li class="sustainability-primary-item dropdown dropdown-end dropdown-hover">
										<button tabindex="0" class="sustainability-primary-item__link rounded-full px-1 py-1 pb-3 text-sm font-medium transition-colors text-[#858585] hover:text-[#757575] flex flex-wrap items-center justify-center gap-x-1 !leading-5 whitespace-normal lg:w-[7rem] text-center lg:text-xs">
											<span class="whitespace-normal text-center">{{ item_title }}</span>
												<i class="fa-solid fa-chevron-down text-[8px]" aria-hidden="true"></i>
											</button>
											<ul tabindex="0" class="dropdown-content menu bg-white rounded-lg shadow-xl p-0 w-80 lg:w-auto z-50">
												<li role="presentation" class="menu-title hidden">
													<span class="px-3.5 py-2 text-sm font-semibold">{{ item_title }}</span>
												</li>
												{% for child in item_children %}
													{% set child_title = child.title|default(child.text|default('')) %}
													{% set child_url = child.url|default('#') %}
													<li
														role="presentation" class="hover:bg-slate-100">
														{# <a href="{{ child.url }}" class="px-3.5 py-2 text-sm{% if child.active %} active{% endif %}">{{ child.title }}</a> } #}
														<a href="{{ child_url }}" class="px-3.5 py-2 text-sm text-[#757575]">{{ child_title }}</a>
													</li>
												{% endfor %}
											</ul>
										</li>
									{% else %}
										<li class="sustainability-primary-item">
											<a href="{{ item_url }}" class="sustainability-primary-item__link rounded-full px-1 py-1 pb-3 text-sm font-medium transition-colors text-[#858585] hover:text-[#757575] block !leading-5 whitespace-normal text-center lg:w-[7rem] lg:text-xs">{{ item_title }}</a>
										</li>
									{% endif %}
								{% endfor %}
							</ul>
						</nav>
					{% endif %}
				</div>
			</div>
		</div>
	</header>

	<main class="sustainability-main-content" id="main-content">
		{{ page.content }}
	</main>

	<footer class="border-t border-slate-800/70 {{ footer_bg }}">
		<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-12">
			<div class="grid gap-8 lg:grid-cols-[1.2fr_1fr_1fr_1fr] lg:gap-10">
				<div class="space-y-5">
					<a href="https://www.cud.ac.ae/about/accreditation" class="inline-block" target="_blank" rel="noopener noreferrer">
						<img alt="Canadian University Dubai" class="h-14 w-auto object-contain" src="{{ base_path ~ 'modules/custom/cud_sustainability/assets/images/logo-footer-qs-2024.png' }}">
					</a>
					<a class="inline-flex items-center rounded-full border-2 border-[#d5202a] px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-[#d5202a]" href="https://cudportal.cud.ac.ae/apply?utm_source=Organic_channel&amp;utm_medium=search_engine&amp;utm_campaign=not_applicable" target="_blank" rel="noopener noreferrer">Apply online</a>

					<ul class="flex flex-wrap gap-3 mt-1">
						<li>
							<a href="http://www.youtube.com/user/webcud" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="flex h-8 w-8 items-center justify-center rounded-full text-slate-300 transition-colors hover:bg-white/10 hover:text-white">
								<i class="fa-brands fa-youtube text-lg" aria-hidden="true"></i>
							</a>
						</li>
						<li>
							<a href="https://twitter.com/@cuduae" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter" class="flex h-8 w-8 items-center justify-center rounded-full text-slate-300 transition-colors hover:bg-white/10 hover:text-white">
								<i class="fa-brands fa-x-twitter text-lg" aria-hidden="true"></i>
							</a>
						</li>
						<li>
							<a href="http://instagram.com/canadianuniversitydubai" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="flex h-8 w-8 items-center justify-center rounded-full text-slate-300 transition-colors hover:bg-white/10 hover:text-white">
								<i class="fa-brands fa-instagram text-lg" aria-hidden="true"></i>
							</a>
						</li>
						<li>
							<a href="http://www.facebook.com/CanadianUniversityDubai" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="flex h-8 w-8 items-center justify-center rounded-full text-slate-300 transition-colors hover:bg-white/10 hover:text-white">
								<i class="fa-brands fa-facebook-f text-lg" aria-hidden="true"></i>
							</a>
						</li>
						<li>
							<a href="https://www.linkedin.com/school/canadian-university-dubai" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="flex h-8 w-8 items-center justify-center rounded-full text-slate-300 transition-colors hover:bg-white/10 hover:text-white">
								<i class="fa-brands fa-linkedin-in text-lg" aria-hidden="true"></i>
							</a>
						</li>
						<li>
							<a href="https://api.whatsapp.com/send?phone=97180069283" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="flex h-8 w-8 items-center justify-center rounded-full text-slate-300 transition-colors hover:bg-white/10 hover:text-white">
								<i class="fa-brands fa-whatsapp text-lg" aria-hidden="true"></i>
							</a>
						</li>
						<li>
							<a href="https://www.tiktok.com/@canadianuniversitydubai" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="flex h-8 w-8 items-center justify-center rounded-full text-slate-300 transition-colors hover:bg-white/10 hover:text-white">
								<i class="fa-brands fa-tiktok text-lg" aria-hidden="true"></i>
							</a>
						</li>
					</ul>
				</div>


				<div>
					<h3 class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-white">Quick Links</h3>
					<ul class="space-y-2 text-sm">
						<li>
							<a class="{{ footer_link }}" href="/about">About CUD</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="https://careers.cud.ac.ae/" target="_blank" rel="noopener noreferrer">Careers</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="/programs">Programs</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="/about/mission-and-vision">Mission and Vision</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="/why-cud">Why choose us?</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="https://lrc.cud.ac.ae/home" target="_blank" rel="noopener noreferrer">Learning Resource Centre</a>
						</li>
					</ul>
				</div>

				<div>
					<h3 class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-white">Get In Touch</h3>
					<ul class="space-y-2 text-sm">
						<li>
							<a class="{{ footer_link }}" href="/contact">Contact us</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="/downloads/location-map">Location map</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="/contact/university-timings">Timings</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="/sitemap">Sitemap</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="/legal-information">Terms and conditions</a>
						</li>
					</ul>
				</div>

				<div>
					<h3 class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-white">Study In Canada</h3>
					<ul class="space-y-2 text-sm">
						<li>
							<a class="{{ footer_link }}" href="/international-education/study-canada">Overview</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="/transfer-canada/">Transfer Partners</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="/transfer-canada/">Study Abroad Options</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="/about/accreditation">Accreditation</a>
						</li>
						<li>
							<a class="{{ footer_link }}" href="/fees">Fees</a>
						</li>
					</ul>
				</div>
			</div>

			<div class="mt-8 grid grid-cols-1 gap-6 border-t border-white/15 pt-6 lg:grid-cols-3 lg:items-start">
				<div class="space-y-5 lg:col-span-1">
					<div class="overflow-hidden rounded-xl border border-white/15">
						<iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d14439.48283549347!2d55.2644333!3d25.2075823!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x5cc89b41e81e0384!2sCanadian%20University%20Dubai!5e0!3m2!1sen!2sae!4v1635854321675!5m2!1sen!2sae" width="100%" height="220" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
					</div>

					<div class="text-sm leading-6 text-slate-200">
						<p class="font-semibold text-white">Canadian University Dubai</p>
						<p>City Walk, Dubai, United Arab Emirates</p>
						<p>
							<a class="{{ footer_link }}" href="tel:80069283">800 69283</a>
						</p>
					</div>
				</div>
				<div class="hidden lg:block" aria-hidden="true"></div>
				<div class="inspiring-minds lg:justify-self-end lg:self-start">
					<img alt="Canadian University Dubai" class="h-14 w-auto object-contain" src="{{ base_path ~ 'modules/custom/cud_sustainability/assets/images/slogan-inspiring-minds-transforming-lives.png' }}">
				</div>
			</div>

			<div class="mt-10 border-t border-white/15 pt-6">
				<div class="flex flex-col gap-4 text-sm text-slate-300 md:flex-row md:items-center md:justify-between">
					<p>©{{ "now"|date("Y") }}
						Canadian University Dubai. All rights reserved.</p>
				</div>
				<p class="mt-5 text-xs leading-6 text-slate-400">
					Canadian University Dubai, a duly licensed and accredited higher education institution by the Ministry of Higher Education and Scientific Sustainability, United Arab Emirates, confirms that its sole legal and physical campus is in the Emirate of Dubai. All admission, registration, payment and official communication are conducted only through authorized university channels and the contact details listed at www.cud.ac.ae. Report suspicious contact to info@cud.ac.ae.
				</p>
			</div>
		</div>
	</footer>
</div>
