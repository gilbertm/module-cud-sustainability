{#
/**
 * @file
 * Inner-page template for /sustainability/campus/sustainable-infrastructure.
 *
 * Variables:
 * - title: Page title string.
 * - content: Rendered node content (full view mode).
 * - carousel_items: Optional list of carousel slides.
 * - sections: Optional list of processed-text sections.
 * - primary_nav: Primary navigation array.
 * - secondary_nav: Secondary navigation array.
 * - mode: Display mode string ('main' or 'secondary').
 */
#}

{% set carousel_slides = carousel_items|default([]) %}

{% if carousel_slides %}
	<section class="carousel group relative mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Governance carousel'|t }}">
		<div class="w-full relative overflow-hidden">
			<div class="w-full flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Governance') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}
						<div class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>
					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>
					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}

{# ── Page Header with Breadcrumb ─────────────────────────────────────────────── #}
<section class="bg-white" aria-label="{{ 'Page header'|t }}">
	<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
		<nav class="mb-3 flex items-center gap-1.5 text-xs text-slate-500" aria-label="{{ 'Breadcrumb'|t }}">
			{% for link in breadcrumb %}
				{% if not loop.first %}
					<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
				{% endif %}
				{% if link.url %}
					<a href="{{ link.url }}" class="hover:text-slate-700 transition-colors">{{ link.text }}</a>
				{% else %}
					<span>{{ link.text }}</span>
				{% endif %}
			{% endfor %}
			{% if breadcrumb is not empty %}
				<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
			{% endif %}
			<span class="font-medium text-slate-700">{{ title }}</span>
		</nav>
		<div class="flex items-center gap-3">
			<h1 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{{ title }}</h1>
			{% if edit_url %}
				<a href="{{ edit_url }}" class="shrink-0 rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700" title="{{ 'Edit node'|t }}" aria-label="{{ 'Edit'|t }}">
					<i class="fa-solid fa-pen-to-square text-sm" aria-hidden="true"></i>
				</a>
			{% endif %}
		</div>
	</div>
</section>

{# ── Shared sub-nav data ──────────────────────────────────────────────────────── #}

{# Icon map for all seeded primary nav children, keyed by URL #}
{% set icon_map = {
	'/sustainability/campus/health-wellness': 'fa-heart-pulse',
	'/sustainability/campus/sustainable-infrastructure': 'fa-solar-panel',
	'/sustainability/campus/path-to-net-zero': 'fa-seedling'
} %}
{# Derive sub_items from the matching top-level primary nav parent #}
{% set active_nav_parent = null %}
{% for item in primary_nav %}
	{% if item.children and (current_path == item.url or current_path starts with (item.url ~ '/')) %}
		{% set active_nav_parent = item %}
	{% endif %}
{% endfor %}
{% set sub_items = active_nav_parent ? active_nav_parent.children : [] %}

{# ── Mobile / tablet sub-nav strip (hidden on lg+) ───────────────────────────── #}
<div class="lg:hidden border-b border-slate-100 bg-white px-4 sm:px-6">
	<nav class="flex gap-1.5 overflow-x-auto py-2.5 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" aria-label="{{ 'Our Commitment navigation'|t }}">
		{% for sub in sub_items %}
			<a href="{{ sub.url }}" class="inline-flex flex-none items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium transition-colors{% if current_path == sub.url %} bg-slate-900 text-white{% else %} text-slate-600 hover:bg-slate-100 hover:text-slate-900{% endif %}">
				<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }}" aria-hidden="true"></i>
				{{ sub.title }}
			</a>
		{% endfor %}
	</nav>
</div>

{# ── Main Content (full-width) ────────────────────────────────────────────────── #}
<section class="mx-auto max-w-7xl px-4 lg:px-8 !bg-white" id="main-content" aria-label="{{ title }}" data-mode="{{ mode }}">
	<div
		class="min-w-0 space-y-5">

		{# ── Sustainability on Campus Intro ───────────────────────────────────── #}
		<div class="block-common-content">
			<p class="text-slate-700 text-sm leading-relaxed">{{ 'Canadian University Dubai is committed to transforming our physical campus into a living laboratory for environmental stewardship. By integrating smart technology and resource efficiency into our modern City Walk facility, we aim to significantly reduce our operational footprint while fostering a sustainable campus culture.'|t }}</p>
		</div>

		{# ── Campus KPI Snapshot ──────────────────────────────────────────────── #}
		<div class="block-common-content">
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-3 lg:grid-cols-5 mb-4">
				<article class="group overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm text-center">
					<p class="text-2xl font-bold cud-color-blue">22,753 m²</p>
					<p class="mt-1 text-xs text-slate-500">{{ 'Total Campus Buildup'|t }}</p>
				</article>
				<article class="group overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm text-center">
					<p class="text-2xl font-bold cud-color-blue">{{ '2,673 tCO₂e annually'|t }}</p>
					<p class="mt-1 text-xs text-slate-500">{{ 'Total Utilities Emissions 2025'|t }}</p>
				</article>
				<article class="group overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm text-center">
					<p class="text-2xl font-bold cud-color-blue">3,645</p>
					<p class="mt-1 text-xs text-slate-500">{{ 'Total Campus Population'|t }}</p>
				</article>
				<article class="group overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm text-center">
					<p class="text-2xl font-bold cud-color-blue">{{ '117.5 kgCO₂e'|t }}</p>
					<p class="mt-1 text-xs text-slate-500">{{ 'Area-Based Emissions'|t }}</p>
					<p class="mt-0.5 text-[10px] text-slate-400">{{ 'per m² per year'|t }}</p>
				</article>
				<article class="group overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm text-center">
					<p class="text-2xl font-bold cud-color-blue">{{ '0.73 tCO₂e'|t }}</p>
					<p class="mt-1 text-xs text-slate-500">{{ 'Per Capita Emissions'|t }}</p>
					<p class="mt-0.5 text-[10px] text-slate-400">{{ 'per person per year'|t }}</p>
				</article>
			</div>
		</div>

		{# ── Powering a Smarter, Greener Campus ──────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-smarter-campus">
			<h2 id="heading-smarter-campus" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Powering a Smarter, Greener Campus'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'At Canadian University Dubai, sustainability is not a concept, it is embedded in how our campus operates every day.'|t }}</p>
			<p class="text-slate-700 text-sm leading-relaxed">{{ 'We are actively transforming our infrastructure into a smart, energy-efficient environment through a series of high-impact initiatives designed to reduce consumption, enhance performance, and support a more sustainable future.'|t }}</p>
		</div>

		{# ── What We Are Delivering ──────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-delivering">
			<h2 id="heading-delivering" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'What We Are Delivering'|t }}</h2>

			<div class="grid gap-3 sm:grid-cols-2">
				<div class="flex items-start gap-3 rounded-xl border border-slate-200 bg-white p-4 transition-colors hover:border-emerald-200 hover:bg-emerald-50/40">
					<div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-emerald-50">
						<i class="fa-solid fa-temperature-low text-xs text-emerald-600" aria-hidden="true"></i>
					</div>
					<div>
						<p class="text-sm font-semibold text-slate-800">{{ 'Smart Climate Control'|t }}</p>
						<p class="mt-1 text-xs leading-relaxed text-slate-600">{{ 'We are upgrading our air conditioning systems and deploying smart thermostats across campus to intelligently regulate temperature, minimize energy waste, and ensure comfort is delivered only where and when it is needed.'|t }}</p>
					</div>
				</div>
				<div class="flex items-start gap-3 rounded-xl border border-slate-200 bg-white p-4 transition-colors hover:border-sky-200 hover:bg-sky-50/40">
					<div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-sky-50">
						<i class="fa-solid fa-building text-xs text-sky-600" aria-hidden="true"></i>
					</div>
					<div>
						<p class="text-sm font-semibold text-slate-800">{{ 'Intelligent Building Systems (BMS)'|t }}</p>
						<p class="mt-1 text-xs leading-relaxed text-slate-600">{{ 'Through the implementation of a centralized Building Management System, we are enabling real-time monitoring and control of key building operations, turning data into action and efficiency into a measurable outcome.'|t }}</p>
					</div>
				</div>
				<div class="flex items-start gap-3 rounded-xl border border-slate-200 bg-white p-4 transition-colors hover:border-violet-200 hover:bg-violet-50/40">
					<div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-violet-50">
						<i class="fa-solid fa-gears text-xs text-violet-600" aria-hidden="true"></i>
					</div>
					<div>
						<p class="text-sm font-semibold text-slate-800">{{ 'Optimized Infrastructure Performance'|t }}</p>
						<p class="mt-1 text-xs leading-relaxed text-slate-600">{{ 'Our comprehensive MEP enhancement program is designed to eliminate hidden inefficiencies, restore system performance, and unlock immediate energy savings across campus operations.'|t }}</p>
					</div>
				</div>
				<div class="flex items-start gap-3 rounded-xl border border-slate-200 bg-white p-4 transition-colors hover:border-amber-200 hover:bg-amber-50/40">
					<div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-amber-50">
						<i class="fa-solid fa-solar-panel text-xs text-amber-600" aria-hidden="true"></i>
					</div>
					<div>
						<p class="text-sm font-semibold text-slate-800">{{ 'Solar Energy Transition (In Progress)'|t }}</p>
						<p class="mt-1 text-xs leading-relaxed text-slate-600">{{ 'In collaboration with our landlord, we are advancing a solar panel project on the HUB building — targeting up to 30% reduction in annual energy consumption and marking a major step toward renewable energy adoption.'|t }}</p>
					</div>
				</div>
			</div>
		</div>

		{# ── A Campus Designed for the Future ────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-campus-future">
			<h2 id="heading-campus-future" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'A Campus Designed for the Future'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'These initiatives reflect our commitment to creating a campus that is not only efficient and innovative, but also environmentally responsible.'|t }}</p>
			<p class="text-slate-700 text-sm leading-relaxed">{{ 'At CUD, we are building more than facilities, we are building a sustainable future.'|t }}</p>
		</div>

		{# ── Recycling Stations ──────────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-recycling">
			<h2 id="heading-recycling" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Recycling Stations'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-4">{{ 'We promote a culture of sustainability across campus by implementing dedicated recycling stations that enable the segregation of paper, plastic, and cans, supporting responsible waste management and advancing our commitment to environmental stewardship.'|t }}</p>

			{# ── Recycling Stations Gallery ───────────────────────────────────── #}
			<div class="mb-4 flex flex-wrap justify-center gap-3 sm:gap-4" aria-label="{{ 'CUD Recycling Stations Gallery'|t }}">
				{% for i in 1..3 %}
					<figure class="group overflow-hidden rounded-xl ring-1 ring-slate-900/5 shadow-sm bg-white w-[calc(50%-0.375rem)] lg:w-[calc(25%-0.75rem)]">
						<div class="overflow-hidden lazy-loading relative">
							<span class="image-loader absolute inset-0 flex items-center justify-center bg-white/60 z-10">
								<i class="fa-solid fa-arrow-rotate-right animate-spin text-green-700 text-3xl" aria-hidden="true"></i>
							</span>
							<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/accessibility/hub-accessibility-feature-0' ~ i ~ '.jpeg' }}"
								 alt="{{ 'CUD Accessibility Hub photo'|t }} {{ i }}"
								 class="tc-lightbox w-full h-48 sm:h-56 object-cover transition-transform duration-300 group-hover:scale-105"
								 loading="lazy"
								 onload="this.previousElementSibling.style.display='none'">
						</div>
					</figure>
				{% endfor %}
			</div>

		</div>

		{# ── Emissions Inventory and Reporting ───────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-emissions">
			<h2 id="heading-emissions" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Emissions Inventory and Reporting'|t }}</h2>

			<div class="flex flex-col items-center gap-4 rounded-xl border border-slate-200 bg-slate-50 px-6 py-5 shadow-sm">
				<div class="flex w-full items-center gap-4">
					<i class="fa-solid fa-file-pdf text-3xl text-[#b13634]" aria-hidden="true"></i>
					<div class="flex-1">
						<p class="font-medium text-slate-800">{{ 'Download Our Energy Consumption Report 2022 - 2025'|t }}</p>
					</div>
					<a href="/modules/custom/cud_sustainability/assets/pdfs/CUD_Emissions_By_Year_v2.pdf" class="inline-flex items-center gap-2 rounded-lg bg-[#b13634] px-4 py-2 text-sm font-medium text-white hover:bg-[#922c2a] transition-colors">
						<i class="fa-solid fa-download" aria-hidden="true"></i>
						{{ 'Download'|t }}
					</a>
				</div>
			</div>
		</div>

		{% if content %}
			<div class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-sky-700 prose-a:no-underline hover:prose-a:underline">
				{{ content }}
			</div>
		{% endif %}

		{% if sections %}
			<div class="mt-8 space-y-6">
				{% for section in sections %}
					<div class="prose prose-slate max-w-none">{{ section }}</div>
				{% endfor %}
			</div>
		{% endif %}

	</div>
</section>

{# ── Desktop floating contextual nav (hidden on mobile/tablet) ───────────────── #}
<section class="hidden lg:block fixed right-0 top-1/2 -translate-y-1/2 z-40 group" aria-label="{{ 'Our Commitment navigation'|t }}">
	<div
		class="flex items-stretch">

		{# Expanded panel — slides in from right edge on hover #}
		<div class="flex flex-col justify-center overflow-hidden bg-white border-y border-l border-slate-200 rounded-l-2xl shadow-xl w-0 opacity-0 group-hover:w-56 group-hover:opacity-100 transition-all duration-300 ease-out">
			<div class="min-w-[14rem] px-4 py-5">
				<p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400 whitespace-nowrap">{{ active_nav_parent ? active_nav_parent.title : 'Navigation'|t }}</p>
				<ul class="space-y-0.5">
					{% for sub in sub_items %}
						<li>
							<a href="{{ sub.url }}" class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors whitespace-nowrap{% if current_path == sub.url %} bg-slate-100 font-semibold text-slate-900{% else %} text-slate-600 hover:bg-slate-50 hover:text-slate-900{% endif %}">
								<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }} w-4 text-center text-xs{% if current_path == sub.url %} text-[#b13634]{% else %} text-slate-400{% endif %}" aria-hidden="true"></i>
								{{ sub.title }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>

		{# Tab strip — always visible on right edge, collapses border-radius on hover #}
		<div class="flex flex-col items-center justify-center gap-2.5 bg-[#b13634] rounded-l-2xl group-hover:rounded-l-none shadow-lg shadow-[#b13634]/30 px-2.5 py-5 min-w-[2.75rem] transition-all duration-300 cursor-default select-none">
			<i class="fa-solid fa-layer-group text-white/90 text-md" aria-hidden="true"></i>
			<div class="w-px h-2 bg-white/30 rounded-full"></div>
			{% for sub in sub_items %}
				<div class="rounded-full transition-colors {% if current_path == sub.url %}w-2 h-2 bg-white{% else %}w-1.5 h-1.5 bg-white/40 hover:bg-white/70{% endif %}" title="{{ sub.title }}"></div>
			{% endfor %}
		</div>

	</div>
</section>
