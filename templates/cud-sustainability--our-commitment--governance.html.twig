				<button role="tab" id="tab-bot" aria-controls="panel-bot" aria-selected="true" data-cud-tab="bot" class="cud-tab-btn group relative flex items-center gap-1.5 lg:gap-2 px-3 py-2.5 lg:px-5 lg:py-3.5 text-xs lg:text-sm font-semibold text-[#b13634] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[#b13634]/50 focus-visible:ring-offset-2">
					<i class="fa-solid fa-people-group text-sm lg:text-xl" aria-hidden="true"></i>
					{{ 'Board of Trustees'|t }}
					<span class="absolute inset-x-0 bottom-0 h-0.5 rounded-full bg-[#b13634] transition-opacity"></span>
				</button>

				<button role="tab" id="tab-senate" aria-controls="panel-senate" aria-selected="false" data-cud-tab="senate" class="cud-tab-btn group relative flex items-center gap-1.5 lg:gap-2 px-3 py-2.5 lg:px-5 lg:py-3.5 text-xs lg:text-sm font-semibold text-slate-500 transition-colors hover:text-slate-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#b13634]/50 focus-visible:ring-offset-2">
					<i class="fa-solid fa-landmark text-sm lg:text-xl" aria-hidden="true"></i>
					{{ 'Senate'|t }}
					<span class="absolute inset-x-0 bottom-0 h-0.5 rounded-full bg-[#b13634] opacity-0 transition-opacity"></span>
				</button>


				<button role="tab" id="tab-academic-council" aria-controls="panel-academic-council" aria-selected="false" data-cud-tab="academic-council" class="cud-tab-btn group relative flex items-center gap-1.5 lg:gap-2 px-3 py-2.5 lg:px-5 lg:py-3.5 text-xs lg:text-sm font-semibold text-slate-500 transition-colors hover:text-slate-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#b13634]/50 focus-visible:ring-offset-2">
