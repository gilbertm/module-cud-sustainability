						<i class="fa-solid fa-people-group text-sm lg:text-xl" aria-hidden="true"></i>
						{{ 'Board of Trustees'|t }}
						<span class="absolute inset-x-0 bottom-0 h-0.5 rounded-full bg-[#b13634] transition-opacity"></span>
					</button>

