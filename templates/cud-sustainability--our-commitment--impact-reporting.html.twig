{#
/**
 * @file
 * Inner-page template for /sustainability/our-commitment/governance.
 *
 * Variables:
 * - title: Page title string.
 * - content: Rendered node content (full view mode).
 * - carousel_items: Optional list of carousel slides.
 * - sections: Optional list of processed-text sections.
 * - primary_nav: Primary navigation array.
 * - secondary_nav: Secondary navigation array.
 * - mode: Display mode string ('main' or 'secondary').
 */
#}

{% set carousel_slides = carousel_items|default([]) %}

{% if carousel_slides %}
	<section class="carousel group relative mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Governance carousel'|t }}">
		<div class="w-full relative overflow-hidden">
			<div class="w-full flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Governance') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}
						<div class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>
					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>
					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}

{# ── Page Header with Breadcrumb ─────────────────────────────────────────────── #}
<section class="bg-white" aria-label="{{ 'Page header'|t }}">
	<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
		<nav class="mb-3 flex items-center gap-1.5 text-xs text-slate-500" aria-label="{{ 'Breadcrumb'|t }}">
			{% for link in breadcrumb %}
				{% if not loop.first %}
					<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
				{% endif %}
				{% if link.url %}
					<a href="{{ link.url }}" class="hover:text-slate-700 transition-colors">{{ link.text }}</a>
				{% else %}
					<span>{{ link.text }}</span>
				{% endif %}
			{% endfor %}
			{% if breadcrumb is not empty %}
				<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
			{% endif %}
			<span class="font-medium text-slate-700">{{ title }}</span>
		</nav>
		<div class="flex items-center gap-3">
			<h1 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{{ title }}</h1>
			{% if edit_url %}
				<a href="{{ edit_url }}" class="shrink-0 rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700" title="{{ 'Edit node'|t }}" aria-label="{{ 'Edit'|t }}">
					<i class="fa-solid fa-pen-to-square text-sm" aria-hidden="true"></i>
				</a>
			{% endif %}
		</div>
	</div>
</section>

{# ── Shared sub-nav data ──────────────────────────────────────────────────────── #}

{# Icon map for all seeded primary nav children, keyed by URL #}
{% set icon_map = {
	'/sustainability/our-commitment/governance': 'fa-landmark',
	'/sustainability/our-commitment/sustainability-committee': 'fa-users',
	'/sustainability/our-commitment/institutional-policies': 'fa-file-lines',
	'/sustainability/our-commitment/impact-reporting': 'fa-chart-bar',
	'/sustainability/our-commitment/sdgs': 'fa-leaf',
	'/sustainability/programs-in-sustainability/sustainability-focused-programs': 'fa-chalkboard',
	'/sustainability/programs-in-sustainability/student-led-sustainability': 'fa-users-between-lines',
	'/sustainability/research-in-sustainability/center-for-sustainability-and-innovation': 'fa-flask-vial',
	'/sustainability/research-in-sustainability/research-projects': 'fa-diagram-project',
	'/sustainability/researchers-in-sustainability/list-of-researchers': 'fa-id-card',
	'/sustainability/social-responsibility/edi': 'fa-handshake',
	'/sustainability/social-responsibility/people-of-determination': 'fa-universal-access',
	'/sustainability/partnerships-on-sustainability/list-of-institutions': 'fa-building',
	'/sustainability/campus/health-wellness': 'fa-heart-pulse',
	'/sustainability/campus/sustainable-infrastructure': 'fa-solar-panel',
	'/sustainability/campus/path-to-net-zero': 'fa-seedling',
	'/sustainability/activities-and-news/academia': 'fa-book',
	'/sustainability/activities-and-news/extracurricular-activities-on-sustainability': 'fa-person-biking',
	'/sustainability/activities-and-news/news': 'fa-newspaper'
} %}

{# Derive sub_items from the matching top-level primary nav parent #}
{% set active_nav_parent = null %}
{% for item in primary_nav %}
	{% if item.children and (current_path == item.url or current_path starts with (item.url ~ '/')) %}
		{% set active_nav_parent = item %}
	{% endif %}
{% endfor %}
{% set sub_items = active_nav_parent ? active_nav_parent.children : [] %}

{# ── Mobile / tablet sub-nav strip (hidden on lg+) ───────────────────────────── #}
<div class="lg:hidden border-b border-slate-100 bg-white px-4 sm:px-6">
	<nav class="flex flex-wrap gap-1.5 py-2.5" aria-label="{{ 'Our Commitment navigation'|t }}">
		{% for sub in sub_items %}
			<a href="{{ sub.url }}" class="inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium transition-colors{% if current_path == sub.url %} bg-slate-900 text-white{% else %} text-slate-600 hover:bg-slate-100 hover:text-slate-900{% endif %}">
				<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }} shrink-0" aria-hidden="true"></i>
				{{ sub.title }}
			</a>
		{% endfor %}
	</nav>
</div>

{# ── Main Content (full-width) ────────────────────────────────────────────────── #}
<section class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8 !bg-white" id="main-content" aria-label="{{ title }}" data-mode="{{ mode }}">
	<div
		class="min-w-0 space-y-6 lg:space-y-10">

		{# ── Impact Reporting ─────────────────────────────────────────────────── #}

			{# ── UN PRME Reports ── #}
			<div class="block-common-content" aria-labelledby="heading-prme">
				<h2 id="heading-prme" class="text-md md:text-xl font-semibold cud-color-blue">{{ 'UN PRME Reports'|t }}</h2>
				<p class="text-slate-700">CUD is a proud partner of the United Nations Principles for Responsible Management Education (UN PRME), committed to sustainability, ethics, and social responsibility; aiming to empower a generation of change-makers. Together with UN PRME, CUD is shaping the future of business and management education. Read the reports below:</p>
			</div>

			<div class="grid gap-6 sm:grid-cols-2">
				<div class="flex flex-col items-center gap-3 rounded-xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
					<img src="/modules/custom/cud_sustainability/assets/images/our-commitment/impact-reporting-01.png" alt="Sharing Information on Progress (SIP) Report 2023" class="w-full h-auto max-h-80 rounded-lg object-contain aspect-video" />
					<span class="text-2xl font-bold cud-color-blue">2023</span>
					<span class="text-sm text-slate-500">{{ 'Sharing Information on Progress (SIP) Report'|t }}</span>
					<a href="#" class="mt-auto inline-flex items-center gap-2 rounded-lg bg-[#b13634] px-4 py-2 text-sm font-medium text-white hover:bg-[#922c2a] transition-colors">
						<i class="fa-solid fa-file-pdf" aria-hidden="true"></i>
						{{ 'Download Report'|t }}
					</a>
				</div>
				<div class="flex flex-col items-center gap-3 rounded-xl border border-slate-200 bg-slate-50 p-6 shadow-sm">
					<img src="/modules/custom/cud_sustainability/assets/images/our-commitment/impact-reporting-02.png" alt="Sharing Information on Progress (SIP) Report 2025" class="w-full h-auto max-h-80 rounded-lg object-contain aspect-video" />
					<span class="text-2xl font-bold cud-color-blue">2025</span>
					<span class="text-sm text-slate-500">{{ 'Sharing Information on Progress (SIP) Report'|t }}</span>
					<a href="#" class="mt-auto inline-flex items-center gap-2 rounded-lg bg-[#b13634] px-4 py-2 text-sm font-medium text-white hover:bg-[#922c2a] transition-colors">
						<i class="fa-solid fa-file-pdf" aria-hidden="true"></i>
						{{ 'Download Report'|t }}
					</a>
				</div>
			</div>

			{# ── CUD Facilities Carbon Performance and Sustainability Roadmap ── #}
			<div class="block-common-content" aria-labelledby="heading-roadmap">
				<h2 id="heading-roadmap" class="text-md md:text-xl font-semibold cud-color-blue">{{ 'CUD Facilities Carbon Performance and Sustainability Roadmap: 2026'|t }}</h2>
			</div>

			<div class="flex flex-col items-center gap-4 rounded-xl border border-slate-200 bg-slate-50 px-6 py-5 shadow-sm">
				<img src="/modules/custom/cud_sustainability/assets/images/our-commitment/impact-reporting-03.png" alt="CUD Facilities Carbon Performance and Sustainability Roadmap: 2026" class="w-full h-auto max-w-4xl mx-auto rounded-lg object-contain aspect-[2.4/1]" />
				<div class="flex w-full items-center gap-4">

					<i class="fa-solid fa-file-pdf text-3xl text-[#b13634]" aria-hidden="true"></i>
					<div class="flex-1">
						<p class="font-medium text-slate-800">{{ 'CUD Facilities Carbon Performance and Sustainability Roadmap'|t }}</p>
						<p class="text-sm text-slate-500">2026</p>
					</div>
					<a href="#" class="inline-flex items-center gap-2 rounded-lg bg-[#b13634] px-4 py-2 text-sm font-medium text-white hover:bg-[#922c2a] transition-colors">
						<i class="fa-solid fa-download" aria-hidden="true"></i>
						{{ 'Download'|t }}
					</a>
				</div>
			</div>

			{# ── CUD Publications on UN SDGs ── #}
			<section aria-labelledby="heading-sdgs">
				<div class="block-common-content" aria-labelledby="heading-sdgs">
					<h2 id="heading-sdgs" class="text-md md:text-xl font-semibold cud-color-blue">{{ 'CUD Publications on UN SDGs'|t }}</h2>
				</div>

				<div class="overflow-hidden rounded-xl ring-1 ring-slate-900/5 shadow-sm">
					<table class="w-full border-collapse text-sm">
						<thead>
							<tr class="bg-slate-50 border-b border-slate-200">
								<th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">{{ 'SDG'|t }}</th>
								<th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wide text-slate-500">{{ 'Publications'|t }}</th>
								<th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 border-l border-slate-200">{{ 'SDG'|t }}</th>
								<th scope="col" class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wide text-slate-500">{{ 'Publications'|t }}</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-slate-100 bg-white">
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3 text-slate-700">{{ 'Goal 1: No poverty'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">16</td>
								<td class="px-4 py-3 text-slate-700 border-l border-slate-100">{{ 'Goal 10: Reduced inequalities'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">51</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3 text-slate-700">{{ 'Goal 2: Zero hunger'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">9</td>
								<td class="px-4 py-3 text-slate-700 border-l border-slate-100">{{ 'Goal 11: Sustainable cities and communities'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">40</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3 text-slate-700">{{ 'Goal 3: Good health and well-being'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">112</td>
								<td class="px-4 py-3 text-slate-700 border-l border-slate-100">{{ 'Goal 12: Responsible consumption and production'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">112</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3 text-slate-700">{{ 'Goal 4: Quality education'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">73</td>
								<td class="px-4 py-3 text-slate-700 border-l border-slate-100">{{ 'Goal 13: Climate action'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">55</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3 text-slate-700">{{ 'Goal 5: Gender equality'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">24</td>
								<td class="px-4 py-3 text-slate-700 border-l border-slate-100">{{ 'Goal 14: Life below water'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">2</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3 text-slate-700">{{ 'Goal 6: Clean water and sanitation'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">12</td>
								<td class="px-4 py-3 text-slate-700 border-l border-slate-100">{{ 'Goal 15: Life on land'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">17</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3 text-slate-700">{{ 'Goal 7: Affordable and clean energy'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">74</td>
								<td class="px-4 py-3 text-slate-700 border-l border-slate-100">{{ 'Goal 16: Peace, justice and strong institutions'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">44</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3 text-slate-700">{{ 'Goal 8: Decent work and economic growth'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">124</td>
								<td class="px-4 py-3 text-slate-700 border-l border-slate-100">{{ 'Goal 17: Partnerships for the goals'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">91</td>
							</tr>
							<tr class="hover:bg-slate-50/70 transition-colors">
								<td class="px-4 py-3 text-slate-700">{{ 'Goal 9: Industry, innovation and infrastructure'|t }}</td>
								<td class="px-4 py-3 text-center font-medium text-slate-800">155</td>
								<td class="px-4 py-3 border-l border-slate-100"></td>
								<td class="px-4 py-3"></td>
							</tr>
						</tbody>
					</table>
				</div>

				<div class="mt-5 rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-4 sm:p-5">
					<div class="flex items-start gap-4">
						<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#b13634]/10 text-[#b13634]">
							<i class="fa-solid fa-database text-xl" aria-hidden="true"></i>
						</div>
						<div class="min-w-0 flex-1">
							<p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">{{ 'Scopus Indexed Source'|t }}</p>
							<p class="mt-1 text-sm leading-relaxed text-slate-700">{{ 'Explore the complete publication list indexed on Scopus for CUD SDG-related research outputs.'|t }}</p>
							<a href="https://www.scopus.com/pages/organization/60105484#tab=sdgs" class="mt-3 inline-flex items-center gap-2 rounded-lg border border-[#b13634] bg-white px-4 py-2 text-sm font-semibold text-[#b13634] transition-colors hover:bg-[#b13634] hover:text-white" target="_blank" rel="noopener noreferrer">
								<i class="fa-solid fa-graduation-cap" aria-hidden="true"></i>
								{{ 'Open Scopus (login required)'|t }}
								<i class="fa-solid fa-arrow-up-right-from-square text-xs" aria-hidden="true"></i>
							</a>
						</div>
					</div>
				</div>
			</section>

		{# ── /Impact Reporting ────────────────────────────────────────────────── #}

		{% if sections %}
			<div class="mt-8 space-y-6">
				{% for section in sections %}
					<div class="prose prose-slate max-w-none">{{ section }}</div>
				{% endfor %}
			</div>
		{% endif %}

		{% if content %}
			<div class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-sky-700 prose-a:no-underline hover:prose-a:underline">
				{{ content }}
			</div>
		{% endif %}

	</div>
</section>

{# ── Desktop floating contextual nav (hidden on mobile/tablet) ───────────────── #}
<div class="hidden lg:block fixed right-0 top-1/2 -translate-y-1/2 z-40 group" aria-label="{{ 'Our Commitment navigation'|t }}">
	<div
		class="flex items-stretch">

		{# Expanded panel — slides in from right edge on hover #}
		<div class="flex flex-col justify-center overflow-hidden bg-white border-y border-l border-slate-200 rounded-l-2xl shadow-xl w-0 opacity-0 group-hover:w-56 group-hover:opacity-100 transition-all duration-300 ease-out">
			<div class="min-w-[14rem] px-4 py-5">
				<p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400 whitespace-nowrap">{{ active_nav_parent ? active_nav_parent.title : 'Navigation'|t }}</p>
				<ul class="space-y-0.5">
					{% for sub in sub_items %}
						<li>
							<a href="{{ sub.url }}" class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors whitespace-nowrap{% if current_path == sub.url %} bg-slate-100 font-semibold text-slate-900{% else %} text-slate-600 hover:bg-slate-50 hover:text-slate-900{% endif %}">
								<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }} w-4 text-center text-xs{% if current_path == sub.url %} text-[#b13634]{% else %} text-slate-400{% endif %}" aria-hidden="true"></i>
								{{ sub.title }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>

		{# Tab strip — always visible on right edge, collapses border-radius on hover #}
		<div class="flex flex-col items-center justify-center gap-2.5 bg-[#b13634] rounded-l-2xl group-hover:rounded-l-none shadow-lg shadow-[#b13634]/30 px-2.5 py-5 min-w-[2.75rem] transition-all duration-300 cursor-default select-none">
			<i class="fa-solid fa-layer-group text-white/90 text-md" aria-hidden="true"></i>
			<div class="w-px h-2 bg-white/30 rounded-full"></div>
			{% for sub in sub_items %}
				<div class="rounded-full transition-colors {% if current_path == sub.url %}w-2 h-2 bg-white{% else %}w-1.5 h-1.5 bg-white/40 hover:bg-white/70{% endif %}" title="{{ sub.title }}"></div>
			{% endfor %}
		</div>

	</div>
</div>