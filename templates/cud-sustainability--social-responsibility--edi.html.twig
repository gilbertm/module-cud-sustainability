{#
/**
 * @file
 * Inner-page template for /sustainability/our-commitment/governance.
 *
 * Variables:
 * - title: Page title string.
 * - content: Rendered node content (full view mode).
 * - carousel_items: Optional list of carousel slides.
 * - sections: Optional list of processed-text sections.
 * - primary_nav: Primary navigation array.
 * - secondary_nav: Secondary navigation array.
 * - mode: Display mode string ('main' or 'secondary').
 */
#}

{% set carousel_slides = carousel_items|default([]) %}

{% if carousel_slides %}
	<section class="carousel group relative mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Governance carousel'|t }}">
		<div class="w-full relative overflow-hidden">
			<div class="w-full flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Governance') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}
						<div class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>
					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>
					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}

{# ── Page Header with Breadcrumb ─────────────────────────────────────────────── #}
<section class="bg-white" aria-label="{{ 'Page header'|t }}">
	<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
		<nav class="mb-3 flex items-center gap-1.5 text-xs text-slate-500" aria-label="{{ 'Breadcrumb'|t }}">
			{% for link in breadcrumb %}
				{% if not loop.first %}
					<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
				{% endif %}
				{% if link.url %}
					<a href="{{ link.url }}" class="hover:text-slate-700 transition-colors">{{ link.text }}</a>
				{% else %}
					<span>{{ link.text }}</span>
				{% endif %}
			{% endfor %}
			{% if breadcrumb is not empty %}
				<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
			{% endif %}
			<span class="font-medium text-slate-700">{{ title }}</span>
		</nav>
		<div class="flex items-center gap-3">
			<h1 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{{ title }}</h1>
			{% if edit_url %}
				<a href="{{ edit_url }}" class="shrink-0 rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700" title="{{ 'Edit node'|t }}" aria-label="{{ 'Edit'|t }}">
					<i class="fa-solid fa-pen-to-square text-sm" aria-hidden="true"></i>
				</a>
			{% endif %}
		</div>
	</div>
</section>

{# ── Shared sub-nav data ──────────────────────────────────────────────────────── #}

{# Icon map for all seeded primary nav children, keyed by URL #}
{% set icon_map = {
	'/sustainability/social-responsibility/edi': 'fa-handshake',
	'/sustainability/social-responsibility/people-of-determination': 'fa-universal-access',
} %}

{# Derive sub_items from the matching top-level primary nav parent #}
{% set active_nav_parent = null %}
{% for item in primary_nav %}
	{% if item.children and (current_path == item.url or current_path starts with (item.url ~ '/')) %}
		{% set active_nav_parent = item %}
	{% endif %}
{% endfor %}
{% set sub_items = active_nav_parent ? active_nav_parent.children : [] %}

{# ── Mobile / tablet sub-nav strip (hidden on lg+) ───────────────────────────── #}
<div class="lg:hidden border-b border-slate-100 bg-white px-4 sm:px-6">
	<nav class="flex gap-1.5 overflow-x-auto py-2.5 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" aria-label="{{ 'Our Commitment navigation'|t }}">
		{% for sub in sub_items %}
			<a href="{{ sub.url }}" class="inline-flex flex-none items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium transition-colors{% if current_path == sub.url %} bg-slate-900 text-white{% else %} text-slate-600 hover:bg-slate-100 hover:text-slate-900{% endif %}">
				<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }}" aria-hidden="true"></i>
				{{ sub.title }}
			</a>
		{% endfor %}
	</nav>
</div>

{# ── Main Content (full-width) ────────────────────────────────────────────────── #}
<section class="mx-auto max-w-7xl px-4 lg:px-8 !bg-white" id="main-content" aria-label="{{ title }}" data-mode="{{ mode }}">
	<div
		class="min-w-0 space-y-5">

		{# ── EDI Intro ───────────────────────────────────────────────────────── #}
		<div class="block-common-content">
			<p class="text-slate-700 text-sm">Since its inception, Canadian University Dubai has been dedicated to fostering a diverse, equitable, and inclusive environment. Our commitment to EDI is a fundamental element of our organizational culture, explicitly embedded in our
				<strong>ASPIRE Core Values</strong>, specifically under
				<strong>Inclusion</strong>,
				<strong>People</strong>, and
				<strong>Respect</strong>. We strive to cultivate a community built on mutual trust and personal dignity, empowering our members to excel as global citizens.</p>
		</div>

		{# ── ASPIRE Core Values ───────────────────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-aspire">
			<h2 id="heading-aspire" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Core Values (ASPIRE)'|t }}</h2>
			<p class="text-slate-500 text-sm mb-4">{{ 'The fundamental elements that drive CUD\'s organizational culture and operations.'|t }}</p>
			<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
				<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
					<div class="flex items-center gap-3 mb-2">
						<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[#b13634]/10 text-sm font-bold text-[#b13634]">A</span>
						<h3 class="text-sm font-semibold text-slate-800">{{ 'Accountability'|t }}</h3>
					</div>
					<p class="text-xs text-slate-600 leading-relaxed">We uphold a culture of accountability, responsibility, and ethical conduct. We are committed to transparency and integrity, valuing honesty in all our actions toward our community and stakeholders.</p>
				</div>
				<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
					<div class="flex items-center gap-3 mb-2">
						<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-emerald-50 text-sm font-bold text-emerald-700">S</span>
						<h3 class="text-sm font-semibold text-slate-800">{{ 'Sustainability'|t }}</h3>
					</div>
					<p class="text-xs text-slate-600 leading-relaxed">We are committed to sustainability, integrating environmental protection, social equity, and economic responsibility into all aspects of our operations. This includes reducing our environmental impact, promoting well-being, advancing responsible resource use, and fostering inclusive growth. Through education, innovation, and community engagement, we aim to drive meaningful impact for a more just, resilient, and sustainable future.</p>
				</div>
				<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
					<div class="flex items-center gap-3 mb-2">
						<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-amber-50 text-sm font-bold text-amber-700">P</span>
						<h3 class="text-sm font-semibold text-slate-800">{{ 'People'|t }}</h3>
					</div>
					<p class="text-xs text-slate-600 leading-relaxed">Our people — students, faculty, and staff — are our greatest asset. We deeply value their contributions, celebrate their potential, and are committed to fostering a supportive and inclusive community that embodies our values and encourages meaningful contributions to our shared mission.</p>
				</div>
				<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
					<div class="flex items-center gap-3 mb-2">
						<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-violet-50 text-sm font-bold text-violet-700">I</span>
						<h3 class="text-sm font-semibold text-slate-800">{{ 'Inclusion'|t }}</h3>
					</div>
					<p class="text-xs text-slate-600 leading-relaxed">We are committed to creating an inclusive academic environment that welcomes all individuals and ideas. By embracing diversity, we enhance our educational experience while empowering our community to excel as global citizens.</p>
				</div>
				<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
					<div class="flex items-center gap-3 mb-2">
						<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sm font-bold text-sky-700">R</span>
						<h3 class="text-sm font-semibold text-slate-800">{{ 'Respect'|t }}</h3>
					</div>
					<p class="text-xs text-slate-600 leading-relaxed">We respect and value every individual, nurturing a culture of mutual trust, openness, and personal dignity in all our interactions. Our commitment to these principles fosters meaningful connections and a cohesive community built on respect.</p>
				</div>
				<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
					<div class="flex items-center gap-3 mb-2">
						<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-slate-100 text-sm font-bold text-slate-700">E</span>
						<h3 class="text-sm font-semibold text-slate-800">{{ 'Excellence'|t }}</h3>
					</div>
					<p class="text-xs text-slate-600 leading-relaxed">Excellence is at the heart of all we do — shaping our academic standards, operational practices, and partnerships. Rooted in the values of Canadian and UAE traditions, it drives us to empower our community to lead with purpose, innovate boldly, and create meaningful global impact.</p>
				</div>
			</div>
		</div>

		{# ── EDI Officer ─────────────────────────────────────────────────────── #}
		
		<div class="block-common-content" aria-labelledby="heading-edi-officer">
		<h2 id="heading-edi-officer" class="text-md md:text-xl font-semibold cud-color-blue mb-4">Equity, Diversity & Inclusion Officer</h2>
			<div class="rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-5 sm:p-6 shadow-sm">
				<div class="flex flex-col sm:flex-row sm:items-start gap-6">
					<div class="shrink-0 flex justify-center sm:justify-start">
						<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/edi-officer.png' }}" alt="{{ 'Ms. Simran Siddiqui — EDI Officer'|t }}" class="w-48 h-48 object-cover rounded-full shadow-md ring-2 ring-slate-200"/>
					</div>
					<div class="flex-1 min-w-0">
						<p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400 mb-1">{{ 'Equality, Diversity &amp; Inclusion Officer'|t }}</p>
						<h2 id="heading-edi-officer" class="text-lg font-semibold text-slate-900">Ms. Simran Siddiqui</h2>
						<p class="text-slate-600 text-sm leading-relaxed mt-2">Ms. Simran Siddiqui heads the counselling office and oversees the EDI and Disability Support offices in CUD. Together with Student Affairs and Human Resources, Ms. Simran ensures all matters of EDI and disability support is properly addressed at all management levels.</p>
						<p class="text-slate-500 text-sm mt-3 italic">{{ 'Schedule an appointment, call, or visit us. We\'re here to support you.'|t }}</p>
						<div class="mt-4 flex flex-col gap-2 text-sm">
							<div class="flex items-center gap-2.5 text-slate-700">
								<i class="fa-solid fa-phone w-4 text-center text-[#b13634]" aria-hidden="true"></i>
								<a href="tel:+97147096292" class="hover:text-[#b13634] transition-colors">+971 4 709 6292</a>
							</div>
							<div class="flex items-center gap-2.5 text-slate-700">
								<i class="fa-solid fa-location-dot w-4 text-center text-[#b13634]" aria-hidden="true"></i>
								<span>{{ 'HUB 1 – 05'|t }}</span>
							</div>
							<div class="flex items-center gap-2.5 text-slate-700">
								<i class="fa-solid fa-envelope w-4 text-center text-[#b13634]" aria-hidden="true"></i>
								<a href="mailto:Simran.Siddiqui@cud.ac.ae" class="hover:text-[#b13634] transition-colors underline underline-offset-2">Simran.Siddiqui@cud.ac.ae</a>
							</div>
							<div class="flex items-center gap-2.5 text-slate-700">
								<i class="fa-solid fa-envelope w-4 text-center text-slate-400" aria-hidden="true"></i>
								<a href="mailto:StudentCounsellor@cud.ac.ae" class="hover:text-[#b13634] transition-colors underline underline-offset-2">StudentCounsellor@cud.ac.ae</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>


		{# ── Mandatory and Continuous Training for Employees ─────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-training">
			<h2 id="heading-training" class="text-md md:text-xl font-semibold cud-color-blue mb-3">{{ 'Mandatory and Continuous Training for Employees on Conduct, Ethics, EDI, and more'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">CUD engages TES Global to provide employees with accessibility to attend and complete a specific course &ldquo;Safeguarding of Young People (Colleges &amp; Universities)&rdquo;, where subjects on harassment and bullying, amongst other important topics, are addressed. Employees must begin and complete these trainings as part of their orientation requirements and are provided with certification once they complete the training course.</p>
			<p class="text-slate-700 text-sm leading-relaxed mb-5">The TES Global platform also allows employees to continuously attend courses such as Bullying and Harassment in the Workplace, Anti-Fraud, Bribery, and Corruption, just to name a few.</p>

			<div id="tc-carousel" aria-label="{{ 'TES Global training courses'|t }}">
				<div class="tc-item flex flex-col gap-3 rounded-xl border border-slate-200 p-5 shadow-sm">
					<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/tes-global-for-employees/sample-of-courses-available-in-tes-global-global.png' }}" alt="{{ 'Sample of Courses Available in TES Global — TES Global course'|t }}" class="w-full h-auto rounded-lg tc-lightbox"/>
					<h3 class="text-sm font-semibold text-slate-800">{{ 'Sample of Courses Available in TES Global'|t }}</h3>
					<p class="text-xs text-slate-600 leading-relaxed">Sample of Courses Available in TES Global.</p>
				</div>

				<div class="tc-item flex flex-col gap-3 rounded-xl border border-slate-200 p-5 shadow-sm">
					<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/tes-global-for-employees/bullying-and-harassment-in-the-workplace.png' }}" alt="{{ 'Bullying and Harassment in the Workplace — TES Global course'|t }}" class="w-full h-auto rounded-lg tc-lightbox"/>
					<h3 class="text-sm font-semibold text-slate-800">{{ 'Bullying and Harassment in the Workplace'|t }}</h3>
					<p class="text-xs text-slate-600 leading-relaxed">A one-module interactive course suitable for everyone in the workplace, including employees, managers, and employers. Covers the law relating to bullying and harassment, what to look for, and where to go for advice and support.</p>
				</div>
				<div class="tc-item flex flex-col gap-3 rounded-xl border border-slate-200 p-5 shadow-sm">
					<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/tes-global-for-employees/anti-fraud-bribery-and-corruption.png' }}" alt="{{ 'Anti-Fraud, Bribery and Corruption — TES Global course'|t }}" class="w-full h-auto rounded-lg tc-lightbox"/>
					<h3 class="text-sm font-semibold text-slate-800">{{ 'Anti-Fraud, Bribery and Corruption'|t }}</h3>
					<p class="text-xs text-slate-600 leading-relaxed">Covers what fraud, bribery, and corruption are, how to spot risk factors, prevention and detection measures, and how to report a suspected fraud. Suitable for anyone looking to expand their awareness of anti-fraud practices.</p>
				</div>
				<div class="tc-item flex flex-col gap-3 rounded-xl border border-slate-200 p-5 shadow-sm">
					<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/tes-global-for-employees/safeguarding-course-information.png' }}" alt="{{ 'Safeguarding Young People — Colleges and Universities — TES Global course'|t }}" class="w-full h-auto rounded-lg tc-lightbox"/>
					<h3 class="text-sm font-semibold text-slate-800">{{ 'Safeguarding Young People — Colleges and Universities'|t }}</h3>
					<p class="text-xs text-slate-600 leading-relaxed">A one-module interactive course for anyone who works with young people in further and higher education. Covers safeguarding, handling suspicions and disclosures of abuse, and how to record and report concerns.</p>
				</div>
			</div>
		</div>

		{# ── Get Involved CTA ─────────────────────────────────────────────────── #}
		<div class="mt-5 rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-4 sm:p-5">
			<div class="flex items-start gap-4">
				<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#b13634]/10 text-[#b13634]">
					<i class="fa-solid fa-handshake text-xl" aria-hidden="true"></i>
				</div>
				<div class="min-w-0 flex-1">
					<p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">{{ 'Get Involved'|t }}</p>
					<p class="mt-1 text-sm leading-relaxed text-slate-700">Interested in contributing to EDI initiatives at CUD? Whether you are a student, faculty member, or staff, there are many ways to engage — from joining community events to partnering with the EDI office on inclusion-related projects. We welcome everyone to be part of building a more equitable and inclusive campus.</p>
					<p class="mt-2 text-sm font-semibold text-[#b13634]">{{ 'Email:'|t }}
						<a href="mailto:edi@cud.ac.ae" class="underline hover:text-[#922c2a]">edi@cud.ac.ae</a>
					</p>
				</div>
			</div>
		</div>

		{% if content %}
			<div class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-sky-700 prose-a:no-underline hover:prose-a:underline">
				{{ content }}
			</div>
		{% endif %}

		{% if sections %}
			<div class="mt-8 space-y-6">
				{% for section in sections %}
					<div class="prose prose-slate max-w-none">{{ section }}</div>
				{% endfor %}
			</div>
		{% endif %}
		
	</div>
</section>

{# ── Desktop floating contextual nav (hidden on mobile/tablet) ───────────────── #}
<section class="hidden lg:block fixed right-0 top-1/2 -translate-y-1/2 z-40 group" aria-label="{{ 'Our Commitment navigation'|t }}">
	<div
		class="flex items-stretch">

		{# Expanded panel — slides in from right edge on hover #}
		<div class="flex flex-col justify-center overflow-hidden bg-white border-y border-l border-slate-200 rounded-l-2xl shadow-xl w-0 opacity-0 group-hover:w-56 group-hover:opacity-100 transition-all duration-300 ease-out">
			<div class="min-w-[14rem] px-4 py-5">
				<p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400 whitespace-nowrap">{{ active_nav_parent ? active_nav_parent.title : 'Navigation'|t }}</p>
				<ul class="space-y-0.5">
					{% for sub in sub_items %}
						<li>
							<a href="{{ sub.url }}" class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors whitespace-nowrap{% if current_path == sub.url %} bg-slate-100 font-semibold text-slate-900{% else %} text-slate-600 hover:bg-slate-50 hover:text-slate-900{% endif %}">
								<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }} w-4 text-center text-xs{% if current_path == sub.url %} text-[#b13634]{% else %} text-slate-400{% endif %}" aria-hidden="true"></i>
								{{ sub.title }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>

		{# Tab strip — always visible on right edge, collapses border-radius on hover #}
		<div class="flex flex-col items-center justify-center gap-2.5 bg-[#b13634] rounded-l-2xl group-hover:rounded-l-none shadow-lg shadow-[#b13634]/30 px-2.5 py-5 min-w-[2.75rem] transition-all duration-300 cursor-default select-none">
			<i class="fa-solid fa-layer-group text-white/90 text-md" aria-hidden="true"></i>
			<div class="w-px h-2 bg-white/30 rounded-full"></div>
			{% for sub in sub_items %}
				<div class="rounded-full transition-colors {% if current_path == sub.url %}w-2 h-2 bg-white{% else %}w-1.5 h-1.5 bg-white/40 hover:bg-white/70{% endif %}" title="{{ sub.title }}"></div>
			{% endfor %}
		</div>

	</div>
</section>