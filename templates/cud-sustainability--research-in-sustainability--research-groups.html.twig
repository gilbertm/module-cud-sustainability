					<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-amber-50 text-amber-600 transition-colors group-hover/link:bg-[#b13634]/10 group-hover/link:text-[#b13634]"><i class="fa-solid fa-puzzle-piece text-sm" aria-hidden="true"></i></span>
					<span class="leading-snug">{{ 'Social Innovation and Sustainability Group'|t }}</span>
					<i class="fa-solid fa-chevron-right ml-auto text-[10px] text-slate-300 transition-colors group-hover/link:text-[#b13634]" aria-hidden="true"></i>
				</a></li>
				<li><a href="/sustainability/research-in-sustainability/research-groups/architecture-and-interior-design#heading-sustainable-construction" class="flex items-center gap-3 rounded-lg border border-slate-100 px-4 py-2.5 text-sm text-slate-700 transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-slate-900 group/link">
					<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-orange-50 text-orange-600 transition-colors group-hover/link:bg-[#b13634]/10 group-hover/link:text-[#b13634]"><i class="fa-solid fa-helmet-safety text-sm" aria-hidden="true"></i></span>
					<span class="leading-snug">{{ 'Sustainable Construction Systems Group'|t }}</span>
					<i class="fa-solid fa-chevron-right ml-auto text-[10px] text-slate-300 transition-colors group-hover/link:text-[#b13634]" aria-hidden="true"></i>
				</a></li>
			</ul>
		</div>

		{# ── School of Engineering, Applied Science and Technology Research Groups #}
		<div class="block-common-content" aria-labelledby="heading-engineering-groups">
			<h2 id="heading-engineering-groups" class="text-md md:text-xl font-semibold cud-color-blue mb-1"><a href="/sustainability/research-in-sustainability/research-groups/school-of-engineering-research" class="hover:underline">{{ 'School of Engineering, Applied Science and Technology Research Groups'|t }} <i class="fa-solid fa-arrow-right text-xs ml-1" aria-hidden="true"></i></a></h2>
			<ul class="space-y-2 mt-2">
				<li><a href="/sustainability/research-in-sustainability/research-groups/school-of-engineering-research#heading-sst" class="flex items-center gap-3 rounded-lg border border-slate-100 px-4 py-2.5 text-sm text-slate-700 transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-slate-900 group/link">
					<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600 transition-colors group-hover/link:bg-[#b13634]/10 group-hover/link:text-[#b13634]"><i class="fa-solid fa-road text-sm" aria-hidden="true"></i></span>
					<span class="leading-snug">{{ 'Safe and Sustainable Transportation Group'|t }}</span>
					<i class="fa-solid fa-chevron-right ml-auto text-[10px] text-slate-300 transition-colors group-hover/link:text-[#b13634]" aria-hidden="true"></i>
				</a></li>
				<li><a href="/sustainability/research-in-sustainability/research-groups/school-of-engineering-research#heading-smai" class="flex items-center gap-3 rounded-lg border border-slate-100 px-4 py-2.5 text-sm text-slate-700 transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-slate-900 group/link">
					<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-violet-50 text-violet-600 transition-colors group-hover/link:bg-[#b13634]/10 group-hover/link:text-[#b13634]"><i class="fa-solid fa-robot text-sm" aria-hidden="true"></i></span>
					<span class="leading-snug">{{ 'Sustainable Medical AI and Digital Health Group'|t }}</span>
					<i class="fa-solid fa-chevron-right ml-auto text-[10px] text-slate-300 transition-colors group-hover/link:text-[#b13634]" aria-hidden="true"></i>
				</a></li>
			</ul>
		</div>

		{# ── Research Group Publications ───────────────────────────────────────── #}
		<div class="block-common-content mt-6" aria-labelledby="heading-publications-cta">
			<a href="/sustainability/research-in-sustainability/research-groups/research-group-publications" class="group/pub block rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-6 shadow-sm transition-all hover:border-[#b13634]/30 hover:shadow-md">
				<div class="flex items-start gap-4">
					<div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-[#b13634]/10 text-[#b13634] transition-colors group-hover/pub:bg-[#b13634] group-hover/pub:text-white">
						<i class="fa-solid fa-book-open-reader text-xl" aria-hidden="true"></i>
					</div>
					<div class="min-w-0 flex-1">
						<h2 id="heading-publications-cta" class="text-md md:text-lg font-semibold text-slate-900 mb-1 group-hover/pub:text-[#b13634] transition-colors">{{ 'Research Group Publications'|t }} <i class="fa-solid fa-arrow-right text-xs ml-1 opacity-0 transition-all group-hover/pub:opacity-100 group-hover/pub:translate-x-1" aria-hidden="true"></i></h2>
						<p class="text-sm text-slate-600 leading-relaxed">{{ 'Browse the full catalogue of peer-reviewed publications across all sustainability research groups &mdash; including work from the Centre for Sustainability & Innovation, Digital Transition, Climate Research Lab, and the Schools of Engineering and Management.'|t }}</p>
					</div>
				</div>
			</a>
		</div>

		{% if content %}
			<div class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-sky-700 prose-a:no-underline hover:prose-a:underline">
				{{ content }}
			</div>
		{% endif %}

		{% if sections %}
			<div class="mt-8 space-y-6">
				{% for section in sections %}
					<div class="prose prose-slate max-w-none">{{ section }}</div>
				{% endfor %}
			</div>
		{% endif %}

	</div>
</section>

{# ── Desktop floating contextual nav (hidden on mobile/tablet) ───────────────── #}
<section class="hidden lg:block fixed right-0 top-1/2 -translate-y-1/2 z-40 group" aria-label="{{ 'Our Commitment navigation'|t }}">
	<div
		class="flex items-stretch">

		{# Expanded panel — slides in from right edge on hover #}
		<div class="flex flex-col justify-center overflow-hidden bg-white border-y border-l border-slate-200 rounded-l-2xl shadow-xl w-0 opacity-0 group-hover:w-56 group-hover:opacity-100 transition-all duration-300 ease-out">
			<div class="min-w-[14rem] px-4 py-5">
				<p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400 whitespace-nowrap">{{ active_nav_parent ? active_nav_parent.title : 'Navigation'|t }}</p>
				<ul class="space-y-0.5">
					{% for sub in sub_items %}
						<li>
							<a href="{{ sub.url }}" class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors whitespace-nowrap{% if current_path == sub.url %} bg-slate-100 font-semibold text-slate-900{% else %} text-slate-600 hover:bg-slate-50 hover:text-slate-900{% endif %}">
								<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }} w-4 text-center text-xs{% if current_path == sub.url %} text-[#b13634]{% else %} text-slate-400{% endif %}" aria-hidden="true"></i>
								{{ sub.title }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>

		{# Tab strip — always visible on right edge, collapses border-radius on hover #}
		<div class="flex flex-col items-center justify-center gap-2.5 bg-[#b13634] rounded-l-2xl group-hover:rounded-l-none shadow-lg shadow-[#b13634]/30 px-2.5 py-5 min-w-[2.75rem] transition-all duration-300 cursor-default select-none">
			<i class="fa-solid fa-layer-group text-white/90 text-md" aria-hidden="true"></i>
			<div class="w-px h-2 bg-white/30 rounded-full"></div>
			{% for sub in sub_items %}
				<div class="rounded-full transition-colors {% if current_path == sub.url %}w-2 h-2 bg-white{% else %}w-1.5 h-1.5 bg-white/40 hover:bg-white/70{% endif %}" title="{{ sub.title }}"></div>
			{% endfor %}
		</div>

	</div>
</section>
