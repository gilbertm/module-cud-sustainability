{#
/**
 * @file
 * Inner-page template for /sustainability/our-commitment/governance.
 *
 * Variables:
 * - title: Page title string.
 * - content: Rendered node content (full view mode).
 * - carousel_items: Optional list of carousel slides.
 * - sections: Optional list of processed-text sections.
 * - primary_nav: Primary navigation array.
 * - secondary_nav: Secondary navigation array.
 * - mode: Display mode string ('main' or 'secondary').
 */
#}

{% set carousel_slides = carousel_items|default([]) %}

{% if carousel_slides %}
	<section class="carousel group relative mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Governance carousel'|t }}">
		<div class="w-full relative overflow-hidden">
			<div class="w-full flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Governance') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}
						<div class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>
					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>
					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}

{# ── Page Header with Breadcrumb ─────────────────────────────────────────────── #}
<section class="bg-white" aria-label="{{ 'Page header'|t }}">
	<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
		<nav class="mb-3 flex items-center gap-1.5 text-xs text-slate-500" aria-label="{{ 'Breadcrumb'|t }}">
			{% for link in breadcrumb %}
				{% if not loop.first %}
					<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
				{% endif %}
				{% if link.url %}
					<a href="{{ link.url }}" class="hover:text-slate-700 transition-colors">{{ link.text }}</a>
				{% else %}
					<span>{{ link.text }}</span>
				{% endif %}
			{% endfor %}
			{% if breadcrumb is not empty %}
				<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
			{% endif %}
			<span class="font-medium text-slate-700">{{ title }}</span>
		</nav>
		<div class="flex items-center gap-3">
			<h1 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{{ title }}</h1>
			{% if edit_url %}
				<a href="{{ edit_url }}" class="shrink-0 rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700" title="{{ 'Edit node'|t }}" aria-label="{{ 'Edit'|t }}">
					<i class="fa-solid fa-pen-to-square text-sm" aria-hidden="true"></i>
				</a>
			{% endif %}
		</div>
	</div>
</section>

{# ── Shared sub-nav data ──────────────────────────────────────────────────────── #}

{# Icon map for all seeded primary nav children, keyed by URL #}
{% set icon_map = {
	'/sustainability/research-in-sustainability/center-for-sustainability-and-innovation': 'fa-flask-vial',
	'/sustainability/research-in-sustainability/research-groups': 'fa-diagram-project'
} %}

{# Derive sub_items from the matching top-level primary nav parent #}
{% set active_nav_parent = null %}
{% for item in primary_nav %}
	{% if item.children and (current_path == item.url or current_path starts with (item.url ~ '/')) %}
		{% set active_nav_parent = item %}
	{% endif %}
{% endfor %}
{% set sub_items = active_nav_parent ? active_nav_parent.children : [] %}

{# ── Mobile / tablet sub-nav strip (hidden on lg+) ───────────────────────────── #}
<div class="lg:hidden border-b border-slate-100 bg-white px-4 sm:px-6">
	<nav class="flex gap-1.5 overflow-x-auto py-2.5 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" aria-label="{{ 'Our Commitment navigation'|t }}">
		{% for sub in sub_items %}
			<a href="{{ sub.url }}" class="inline-flex flex-none items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium transition-colors{% if current_path == sub.url %} bg-slate-900 text-white{% else %} text-slate-600 hover:bg-slate-100 hover:text-slate-900{% endif %}">
				<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }}" aria-hidden="true"></i>
				{{ sub.title }}
			</a>
		{% endfor %}
	</nav>
</div>

{# ── Main Content (full-width) ────────────────────────────────────────────────── #}
<section class="mx-auto max-w-7xl px-4 lg:px-8 !bg-white" id="main-content" aria-label="{{ title }}" data-mode="{{ mode }}">
	<div
		class="min-w-0 space-y-5">


		{# ── 1. Sustainable Urbanism Group ────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-sustainable-urbanism">
			<h2 id="heading-sustainable-urbanism" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Sustainable Urbanism Group'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'The Sustainable Urbanism group focuses on understanding and addressing the complex interactions between climate change, urban environments, and human comfort, with a specific emphasis on desert cities and arid-region contexts. By integrating environmental studies, regenerative design, and urban anthropology, the group develops innovative, practical solutions tailored to extreme climatic conditions, including strategies to mitigate urban heat islands intensified by rapid urbanization and resource-intensive development. Through applied research, design-led experimentation, and partnerships with public and private stakeholders, the group works on climate-responsive urban systems, passive and nature-based cooling strategies, data-informed environmental modelling, and the design of adaptive public spaces that enhance thermal comfort, resilience, and social wellbeing in desert urban environments.'|t }}</p>

			<h3 class="text-base font-semibold text-slate-800 mt-2 mb-2">{{ 'Goals'|t }}</h3>
			<ul class="space-y-1.5 mb-4">
				<li class="flex items-start gap-2">
					<i class="fa-solid fa-circle-check mt-0.5 text-[#b13634]"></i>
					<p class="text-sm leading-relaxed text-slate-700"><strong>{{ 'Research Excellence:'|t }}</strong> {{ 'Produce rigorous and internationally visible research on sustainable urbanism, with a focus on climate-responsive design, liveability, public space, environmental performance, social sustainability, and resilient urban development, particularly in arid and rapidly urbanising contexts.'|t }}</p>
				</li>
				<li class="flex items-start gap-2">
					<i class="fa-solid fa-circle-check mt-0.5 text-[#b13634]"></i>
					<p class="text-sm leading-relaxed text-slate-700"><strong>{{ 'Applied Impact:'|t }}</strong> {{ 'Develop design tools, pilot projects, and stakeholder collaborations that translate research into practical strategies for more sustainable, inclusive, climate-responsive, and liveable cities.'|t }}</p>
				</li>
				<li class="flex items-start gap-2">
					<i class="fa-solid fa-circle-check mt-0.5 text-[#b13634]"></i>
					<p class="text-sm leading-relaxed text-slate-700"><strong>{{ 'Global Engagement:'|t }}</strong> {{ 'Contribute to international conferences, workshops, and interdisciplinary networks addressing sustainable urban transitions, climate adaptation, social wellbeing, and human-centred urban design.'|t }}</p>
				</li>
			</ul>

			<h3 class="text-base font-semibold text-slate-800 mt-2 mb-2">{{ 'Team Leader'|t }}</h3>
			<div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm max-w-md">
				<div class="flex items-center gap-3">
					<div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#b13634]/10">
						<i class="fa-solid fa-user-tie text-[#b13634]"></i>
					</div>
					<div>
						<p class="text-sm font-semibold text-slate-800">{{ 'Dr. Simona Azzali'|t }}</p>
						<a href="mailto:simona.azzali@cud.ac.ae" class="text-xs text-sky-700 hover:underline">simona.azzali@cud.ac.ae</a>
					</div>
				</div>
			</div>
		</div>

		{# ── 2. Social Innovation and Sustainability Group ────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-social-innovation">
			<h2 id="heading-social-innovation" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Social Innovation and Sustainability Group'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'The Social Innovation and Sustainability Group focuses on addressing the interconnected environmental, social, and economic challenges shaping contemporary communities, with particular attention to local cultures, identities, and emerging social practices. By integrating principles of circular economy, inclusive design, and social innovation, the group develops design-driven strategies that respond to climate change while reinforcing cultural specificity, community values, and place-based knowledge. Through applied research, participatory design approaches, and collaborations with public institutions, industry partners, and local communities, the group works on regenerative systems, context-responsive practices, and adaptive environments that reflect evolving ways of living, strengthen social cohesion, and support resilient, culturally grounded futures.'|t }}</p>

			<h3 class="text-base font-semibold text-slate-800 mt-2 mb-2">{{ 'Goals'|t }}</h3>
			<ul class="space-y-1.5 mb-4">
				<li class="flex items-start gap-2">
					<i class="fa-solid fa-circle-check mt-0.5 text-[#b13634]"></i>
					<p class="text-sm leading-relaxed text-slate-700"><strong>{{ 'High-Impact Publications:'|t }}</strong> {{ 'We aim to produce and disseminate rigorous, interdisciplinary research on social innovation and sustainability, contributing to leading journals and advancing knowledge on inclusive design, circular systems, and community-driven environmental solutions.'|t }}</p>
				</li>
				<li class="flex items-start gap-2">
					<i class="fa-solid fa-circle-check mt-0.5 text-[#b13634]"></i>
					<p class="text-sm leading-relaxed text-slate-700"><strong>{{ 'Global Conference Engagement:'|t }}</strong> {{ 'We actively present our work at international conferences, engaging with cross-sector and interdisciplinary communities to exchange insights, foster collaborations, and shape innovative approaches to sustainable and socially responsive design.'|t }}</p>
				</li>
			</ul>

			<h3 class="text-base font-semibold text-slate-800 mt-2 mb-2">{{ 'Team Leader'|t }}</h3>
			<div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm max-w-md">
				<div class="flex items-center gap-3">
					<div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#b13634]/10">
						<i class="fa-solid fa-user-tie text-[#b13634]"></i>
					</div>
					<div>
						<p class="text-sm font-semibold text-slate-800">{{ 'Dr. Sophie Johnson'|t }}</p>
						<a href="mailto:Sophie@cud.ac.ae" class="text-xs text-sky-700 hover:underline">Sophie@cud.ac.ae</a>
					</div>
				</div>
			</div>
		</div>

		{# ── 3. Sustainable Construction Systems Group ────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-sustainable-construction">
			<h2 id="heading-sustainable-construction" class="text-md md:text-xl font-semibold cud-color-blue mb-1">{{ 'Sustainable Construction Systems Group'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">{{ 'The Sustainable Construction Systems Group focuses on advancing innovative, efficient, and environmentally responsible approaches to the design, materialization, and lifecycle of buildings. By integrating building technologies, material science, and circular construction principles, the group develops strategies that reduce environmental impact while enhancing performance, durability, and adaptability. Through applied research, prototyping, and collaborations with industry partners and regulatory bodies, the group works on advanced building systems, sustainable material applications, design for disassembly, and construction methodologies that support resource efficiency, waste reduction, and the transition toward a circular built environment.'|t }}</p>

			<h3 class="text-base font-semibold text-slate-800 mt-2 mb-2">{{ 'Goals'|t }}</h3>
			<ul class="space-y-1.5 mb-4">
				<li class="flex items-start gap-2">
					<i class="fa-solid fa-circle-check mt-0.5 text-[#b13634]"></i>
					<p class="text-sm leading-relaxed text-slate-700"><strong>{{ 'High-Impact Publications:'|t }}</strong> {{ 'We aim to produce and disseminate rigorous, technically grounded research on sustainable construction systems, contributing to leading journals and advancing knowledge on material innovation, construction efficiency, and circular building practices.'|t }}</p>
				</li>
				<li class="flex items-start gap-2">
					<i class="fa-solid fa-circle-check mt-0.5 text-[#b13634]"></i>
					<p class="text-sm leading-relaxed text-slate-700"><strong>{{ 'Global Conference Engagement:'|t }}</strong> {{ 'We actively present our work at international conferences, engaging with academic, professional, and industrial communities to exchange insights, foster collaborations, and shape forward-looking approaches to sustainable construction and building technologies.'|t }}</p>
				</li>
			</ul>

			<h3 class="text-base font-semibold text-slate-800 mt-2 mb-2">{{ 'Team Leader'|t }}</h3>
			<div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm max-w-md">
				<div class="flex items-center gap-3">
					<div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#b13634]/10">
						<i class="fa-solid fa-user-tie text-[#b13634]"></i>
					</div>
					<div>
						<p class="text-sm font-semibold text-slate-800">{{ 'Christine Yogiaman'|t }}</p>
						<a href="mailto:christine.yogiaman@cud.ac.ae" class="text-xs text-sky-700 hover:underline">christine.yogiaman@cud.ac.ae</a>
					</div>
				</div>
			</div>
		</div>

		{% if content %}
			<div class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-sky-700 prose-a:no-underline hover:prose-a:underline">
				{{ content }}
			</div>
		{% endif %}

		{% if sections %}
			<div class="mt-8 space-y-6">
				{% for section in sections %}
					<div class="prose prose-slate max-w-none">{{ section }}</div>
				{% endfor %}
			</div>
		{% endif %}

	</div>
</section>

{# ── Desktop floating contextual nav (hidden on mobile/tablet) ───────────────── #}
<section class="hidden lg:block fixed right-0 top-1/2 -translate-y-1/2 z-40 group" aria-label="{{ 'Our Commitment navigation'|t }}">
	<div
		class="flex items-stretch">

		{# Expanded panel — slides in from right edge on hover #}
		<div class="flex flex-col justify-center overflow-hidden bg-white border-y border-l border-slate-200 rounded-l-2xl shadow-xl w-0 opacity-0 group-hover:w-56 group-hover:opacity-100 transition-all duration-300 ease-out">
			<div class="min-w-[14rem] px-4 py-5">
				<p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400 whitespace-nowrap">{{ active_nav_parent ? active_nav_parent.title : 'Navigation'|t }}</p>
				<ul class="space-y-0.5">
					{% for sub in sub_items %}
						<li>
							<a href="{{ sub.url }}" class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors whitespace-nowrap{% if current_path == sub.url %} bg-slate-100 font-semibold text-slate-900{% else %} text-slate-600 hover:bg-slate-50 hover:text-slate-900{% endif %}">
								<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }} w-4 text-center text-xs{% if current_path == sub.url %} text-[#b13634]{% else %} text-slate-400{% endif %}" aria-hidden="true"></i>
								{{ sub.title }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>

		{# Tab strip — always visible on right edge, collapses border-radius on hover #}
		<div class="flex flex-col items-center justify-center gap-2.5 bg-[#b13634] rounded-l-2xl group-hover:rounded-l-none shadow-lg shadow-[#b13634]/30 px-2.5 py-5 min-w-[2.75rem] transition-all duration-300 cursor-default select-none">
			<i class="fa-solid fa-layer-group text-white/90 text-md" aria-hidden="true"></i>
			<div class="w-px h-2 bg-white/30 rounded-full"></div>
			{% for sub in sub_items %}
				<div class="rounded-full transition-colors {% if current_path == sub.url %}w-2 h-2 bg-white{% else %}w-1.5 h-1.5 bg-white/40 hover:bg-white/70{% endif %}" title="{{ sub.title }}"></div>
			{% endfor %}
		</div>

	</div>
</section>
