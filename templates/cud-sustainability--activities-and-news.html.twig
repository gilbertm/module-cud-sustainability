{#
/**
 * @file
 * Inner-page template for /sustainability/activities-and-news.
 *
 * Variables:
 * - title: Page title string.
 * - content: Rendered node content (full view mode).
 * - carousel_items: Optional list of carousel slides.
 * - sections: Optional list of processed-text sections.
 * - primary_nav: Primary navigation array.
 * - secondary_nav: Secondary navigation array.
 * - mode: Display mode string ('main' or 'secondary').
 */
#}

{% set carousel_slides = carousel_items|default([]) %}

{% if carousel_slides %}
	<section class="carousel group relative mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Governance carousel'|t }}">
		<div class="w-full relative overflow-hidden">
			<div class="w-full flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Governance') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}
						<div class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>
					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>
					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}

{# ── Page Header with Breadcrumb ─────────────────────────────────────────────── #}
<section class="bg-white" aria-label="{{ 'Page header'|t }}">
	<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
		<nav class="mb-3 flex items-center gap-1.5 text-xs text-slate-500" aria-label="{{ 'Breadcrumb'|t }}">
			{% for link in breadcrumb %}
				{% if not loop.first %}
					<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
				{% endif %}
				{% if link.url %}
					<a href="{{ link.url }}" class="hover:text-slate-700 transition-colors">{{ link.text }}</a>
				{% else %}
					<span>{{ link.text }}</span>
				{% endif %}
			{% endfor %}
			{% if breadcrumb is not empty %}
				<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
			{% endif %}
			<span class="font-medium text-slate-700">{{ title }}</span>
		</nav>
		<div class="flex items-center gap-3">
			<h1 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{{ title }}</h1>
			{% if edit_url %}
				<a href="{{ edit_url }}" class="shrink-0 rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700" title="{{ 'Edit node'|t }}" aria-label="{{ 'Edit'|t }}">
					<i class="fa-solid fa-pen-to-square text-sm" aria-hidden="true"></i>
				</a>
			{% endif %}
		</div>
	</div>
</section>

{# ── Shared sub-nav data ──────────────────────────────────────────────────────── #}

{# Icon map for all seeded primary nav children, keyed by URL #}
{% set icon_map = {
	'/sustainability/activities-and-news': 'fa-newspaper',
} %}

{# Derive sub_items from the matching top-level primary nav parent #}
{% set active_nav_parent = null %}
{% for item in primary_nav %}
	{% if item.children and (current_path == item.url or current_path starts with (item.url ~ '/')) %}
		{% set active_nav_parent = item %}
	{% endif %}
{% endfor %}
{% set sub_items = active_nav_parent ? active_nav_parent.children : [] %}

{# ── Mobile / tablet sub-nav strip (hidden on lg+) ───────────────────────────── #}
<div class="lg:hidden border-b border-slate-100 bg-white px-4 sm:px-6">
	<nav class="flex gap-1.5 overflow-x-auto py-2.5 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" aria-label="{{ 'Our Commitment navigation'|t }}">
		{% for sub in sub_items %}
			<a href="{{ sub.url }}" class="inline-flex flex-none items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium transition-colors{% if current_path == sub.url %} bg-slate-900 text-white{% else %} text-slate-600 hover:bg-slate-100 hover:text-slate-900{% endif %}">
				<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }}" aria-hidden="true"></i>
				{{ sub.title }}
			</a>
		{% endfor %}
	</nav>
</div>

{# ── Main Content (full-width) ────────────────────────────────────────────────── #}
<section class="mx-auto max-w-7xl px-4 lg:px-8 !bg-white" id="main-content" aria-label="{{ title }}" data-mode="{{ mode }}">
	<div
		class="min-w-0 space-y-5">

		{# ── Activities & News Intro ──────────────────────────────────────────── #}
		<div class="block-common-content">
			<ul class="grid gap-3 grid-cols-1 lg:grid-cols-2 mb-4 lg:mb-8" role="list">
				<li>

					<a href="/sustainability/activities-and-news#heading-training-main" class="flex items-center gap-3 rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-700 transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-slate-900 group/link">
						<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600 transition-colors group-hover/link:bg-[#b13634]/10 group-hover/link:text-[#b13634]">
							<i class="fa-solid fa-chalkboard-user text-[#b13634] text-base shrink-0" aria-hidden="true"></i>
						</span>
						<span class="leading-snug">{{ 'Mandatory Sustainability Training For Staff and Students'|t }}</span>
						<i class="fa-solid fa-chevron-right ml-auto text-[10px] text-slate-300 transition-colors group-hover/link:text-[#b13634]" aria-hidden="true"></i>
					</a>

				</li>

			</ul>

			<p class="text-slate-700 text-sm leading-relaxed">{{ 'Canadian University Dubai actively drives sustainability through a vibrant programme of events, research milestones, institutional partnerships, and student-led initiatives. Explore our latest activities and news — from landmark MoU signings and award-winning student innovations to campus sustainability programmes and global research contributions.'|t }}</p>
		</div>

		{# ── Upcoming Events ─────────────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-events">
			<h2 id="heading-events" class="text-md md:text-xl font-semibold cud-color-blue mb-4 flex items-center gap-2">
				<i class="fa-solid fa-calendar-days text-[#b13634] text-base shrink-0" aria-hidden="true"></i>
				{{ 'Sustainability Activities &amp; Events'|t }}
			</h2>
			{% set events_list = [
				{ title: 'Design(ed) Visions of Tomorrow | The Future of Human Condition'|t, url: 'https://www.cud.ac.ae/events/designed-visions-tomorrow-future-human-condition', icon: 'fa-lightbulb' },
				{ title: 'Towards a Sustainable Built Environment: Challenges and Opportunities in the UAE'|t, url: 'https://www.linkedin.com/posts/canadian-university-dubai_canadian-university-dubai-recently-hosted-activity-7430129127413911552-YU1-/', icon: 'fa-building' },
				{ title: 'AI for Sustainability Hackathon 2026 | Canadian University Dubai'|t, url: 'https://www.cud.ac.ae/events/ai-sustainability-hackathon-2026', icon: 'fa-robot' },
				{ title: 'AI and Human Health Symposium'|t, url: 'https://www.cud.ac.ae/events/ai-human-health-symposium', icon: 'fa-heart-pulse' },
				{ title: 'Breast Cancer Awareness'|t, url: 'https://www.cud.ac.ae/events/breast-cancer-awareness-0', icon: 'fa-ribbon' },
				{ title: 'Climate Summit 2025'|t, url: 'https://www.cud.ac.ae/events/climate-summit-2025-june-3-4-2025', icon: 'fa-cloud-sun' },
				{ title: 'Launch of CUD Incubator Hub for Entrepreneurship and Innovation'|t, url: 'https://www.cud.ac.ae/events/launch-cud-incubator-hub-entrepreneurship-and-innovation', icon: 'fa-rocket' },
				{ title: 'Sustainability Quest: How to Become a Hero in Saving the Earth!'|t, url: 'https://www.cud.ac.ae/events/sustainability-quest-how-become-hero-saving-earth', icon: 'fa-earth-americas' },
				{ title: 'Climate Change and Tourism Conference'|t, url: 'https://www.cud.ac.ae/events/climate-change-and-tourism-conference', icon: 'fa-mountain-sun' },
			] %}
			<ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3" role="list">
				{% for event in events_list %}
					<li>
						<a href="{{ event.url }}" rel="noopener noreferrer" target="_blank" class="flex items-start gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition-all hover:border-[#b13634]/40 hover:shadow-md group">
							<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[#b13634]/10 text-[#b13634] text-sm mt-0.5">
								<i class="fa-solid {{ event.icon }}" aria-hidden="true"></i>
							</span>
							<span class="text-sm font-medium text-slate-700 group-hover:text-slate-900 leading-snug">{{ event.title }}</span>
						</a>
					</li>
				{% endfor %}
			</ul>
			<div class="mt-5 rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-4 sm:p-5">
				<div class="flex items-start gap-4">
					<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#b13634]/10 text-[#b13634]">
						<i class="fa-solid fa-newspaper text-xl" aria-hidden="true"></i>
					</div>
					<div class="min-w-0 flex-1">
						<p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">{{ 'All CUD Events &amp; News'|t }}</p>
						<p class="mt-1 text-sm leading-relaxed text-slate-700">{{ 'Explore the full listing of CUD sustainability events, activities, and institutional news at the official CUD website.'|t }}</p>
						<a href="https://www.cud.ac.ae/news" class="mt-3 inline-flex items-center gap-2 rounded-lg border border-[#b13634] bg-white px-4 py-2 text-sm font-semibold text-[#b13634] transition-colors hover:bg-[#b13634] hover:text-white" target="_blank" rel="noopener noreferrer">
							{{ 'Visit www.cud.ac.ae/news'|t }}
							<i class="fa-solid fa-arrow-up-right-from-square text-xs" aria-hidden="true"></i>
						</a>
					</div>
				</div>

			</div>
		</div>

		{# ── Sustainability News ──────────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-training-main">
			<h2 id="heading-training-main" class="text-md md:text-xl font-semibold cud-color-blue mb-4 flex items-center gap-2">
				<i class="fa-solid fa-chalkboard-user text-[#b13634] text-base shrink-0" aria-hidden="true"></i>
				{{ 'Mandatory Sustainability Training For Staff and Students'|t }}
			</h2>
			<div class="prose max-w-none text-slate-700 mb-4 lg:mb-8">
				<p class="text-sm font-semibold text-slate-700 leading-relaxed">{{ 'Environmental Sustainability Awareness Presentation for New Faculty, Staff, and Students'|t }}</p>
				<p class="text-sm text-slate-700 leading-relaxed">{{ 'The Centre for Sustainability and Innovation delivers an information program, for new employees and new students Orientation Program on Environmental and Social Sustainability Awareness, focusing on CUD policies related to environmental and social sustainability in August and January of each year.'|t }}</p>
				<p class="text-sm text-slate-700 leading-relaxed">{{ 'The program aims to raise awareness of sustainability initiatives and practices at CUD among new faculty, administrative staff, and students. It also encouraged new employees and students to actively participate in the sustainability initiatives led by the Centre for Sustainability and Innovation.'|t }}</p>
				<p class="text-sm text-slate-700 leading-relaxed">{{ 'For example, this orientation program was held on January 8, 2026 for newcomers of Spring 2026. This program is organized in collaboration with HR Department and Student Services, Purchase Department, and Facilities. The program was delivered by Dr. Chureerat Haq, Manager – Centre for Sustainability and Innovation and Mr. Quraish Alharahsheh, Director of Administration at CUD, as shown in the photos below.'|t }}</p>
			</div>
			{# ── Mandatory Sustainability Training Gallery ───────────────────────────────────── #}
			<div class="mb-4 flex flex-wrap justify-center gap-3 sm:gap-4" aria-label="{{ 'Mandatory Sustainability Training Gallery'|t }}">
				{% for i in 1..2 %}
					<figure class="group overflow-hidden rounded-xl ring-1 ring-slate-900/5 shadow-sm bg-white w-[calc(50%-0.375rem)] lg:w-[calc(25%-0.75rem)]">
						<div class="overflow-hidden lazy-loading relative">
							<span class="image-loader absolute inset-0 flex items-center justify-center bg-white/60 z-10">
								<i class="fa-solid fa-arrow-rotate-right animate-spin text-green-700 text-3xl" aria-hidden="true"></i>
							</span>
							<img src="{{ cud_sustainability_asset_path ~ 'images/activities-news/mandatory-sustainability-training-orientation-0' ~ i ~ '.png' }}" alt="{{ 'Mandatory Sustainability Training For Staff and Students photo'|t }} {{ i }}" class="tc-lightbox w-full h-48 sm:h-56 object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" onload="this.previousElementSibling.style.display='none'">
						</div>
					</figure>
				{% endfor %}
			</div>
			<h2 id="heading-training-for-faculty" class="text-md md:text-xl font-semibold cud-color-blue mb-4 flex items-center gap-2">
				<i class="fa-solid fa-chalkboard-user text-[#b13634] text-base shrink-0" aria-hidden="true"></i>
				{{ 'Training For Faculty'|t }}
			</h2>
			{# ── Training For Faculty Gallery ───────────────────────────────────── #}
			<div class="mb-4 flex flex-wrap justify-center gap-3 sm:gap-4" aria-label="{{ 'Training For Faculty Gallery'|t }}">
				{% for i in 1..2 %}
					<figure class="group overflow-hidden rounded-xl ring-1 ring-slate-900/5 shadow-sm bg-white w-[calc(50%-0.375rem)] lg:w-[calc(25%-0.75rem)]">
						<div class="overflow-hidden lazy-loading relative">
							<span class="image-loader absolute inset-0 flex items-center justify-center bg-white/60 z-10">
								<i class="fa-solid fa-arrow-rotate-right animate-spin text-green-700 text-3xl" aria-hidden="true"></i>
							</span>
							<img src="{{ cud_sustainability_asset_path ~ 'images/activities-news/faculty-training/faculty-training-0' ~ i ~ '.jpg' }}" alt="{{ 'Training For Faculty'|t }} {{ i }}" class="tc-lightbox w-full h-48 sm:h-56 object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" onload="this.previousElementSibling.style.display='none'">
						</div>
					</figure>
				{% endfor %}
			</div>
			<div class="mb-4 text-center justify-center" aria-label="{{ 'Training For Students LinkedIn'|t }}">
				<a href="https://www.linkedin.com/posts/canadian-university-dubai_canadian-university-dubai-proudly-welcomes-activity-7363934141286936577-XBlL?utm_source=share&utm_medium=member_desktop&rcm=ACoAACnwqCgBznzU_eUzox8QLXMrimOfgzs5kbo" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-full border border-[#0A66C2]/30 bg-[#0A66C2]/5 px-2.5 py-1 text-[11px] font-medium text-[#0A66C2] transition-colors hover:bg-[#0A66C2]/10" aria-label="{{ 'View original post on LinkedIn'|t }}">
					<i class="fa-brands fa-linkedin text-[#0A66C2] text-xs" aria-hidden="true"></i>
					{{ 'View on LinkedIn'|t }}
					<i class="fa-solid fa-arrow-up-right-from-square text-[9px] opacity-60" aria-hidden="true"></i>
				</a>

			</div>
		</div>

		{# ── Sustainability News ──────────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-news">
			<h2 id="heading-news" class="text-md md:text-xl font-semibold cud-color-blue mb-4 flex items-center gap-2">
				<i class="fa-solid fa-newspaper text-[#b13634] text-base shrink-0" aria-hidden="true"></i>
				{{ 'Sustainability News'|t }}
			</h2>
			{% set news_items = [
				{
					date: '2026'|t,
					datetime: '2026',
					url: 'https://arabworldleaders.com/dr-aseel-a-takshe-on-how-canadian-university-dubai-cud-is-weaving-sustainability-into-the-fabric-of-academic-life-from-solar-panels-to-syllabi/',
