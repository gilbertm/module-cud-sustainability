					<article class="flex flex-col rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden transition-shadow hover:shadow-md" itemscope itemtype="https://schema.org/NewsArticle" itemprop="itemListElement">
						{% set image_src = item.image %}
						{% if item.image matches '/^(https?:)?\\/\\//' %}
							{% set image_src = item.image %}
						{% elseif item.image starts with '/' %}
							{% set image_src = item.image %}
						{% else %}
							{% set image_src = cud_sustainability_asset_path ~ 'images/activities-news/' ~ item.image %}
						{% endif %}
						<div class="overflow-hidden aspect-video">
							<img src="{{ image_src }}" alt="{{ item.alt }}" loading="lazy" class="w-full h-full object-cover" itemprop="image"/>
						</div>
						<div class="flex flex-col flex-1 p-4 gap-2">
							<div class="flex items-center justify-between gap-2">
								<time datetime="{{ item.datetime }}" class="text-[10px] text-slate-400 tabular-nums" itemprop="datePublished">{{ item.date }}</time>
								<span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-medium text-slate-600">{{ item.tag }}</span>
							</div>
							<h3 class="text-sm font-semibold text-slate-800 leading-snug" itemprop="headline">
								<a href="{{ item.url }}" rel="noopener noreferrer" target="_blank" class="hover:text-[#b13634] transition-colors">{{ item.title }}</a>
							</h3>
							<p class="text-xs text-slate-500 leading-relaxed flex-1" itemprop="description">{{ item.body }}</p>
							<meta itemprop="publisher" content="Canadian University Dubai"/>
							<meta itemprop="url" content="{{ item.url }}"/>
							<a href="{{ item.url }}" rel="noopener noreferrer" target="_blank" class="mt-1 inline-flex items-center gap-1.5 text-xs font-medium text-sky-700 hover:text-[#b13634] transition-colors">
								{{ 'Read more at CUD News'|t }}
								<i class="fa-solid fa-arrow-up-right-from-square text-[10px]" aria-hidden="true"></i>
							</a>
						</div>
					</article>
				{% endfor %}
			</div>
		</div>

		{% if content %}
			<div class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-sky-700 prose-a:no-underline hover:prose-a:underline">
				{{ content }}
			</div>
		{% endif %}

		{% if sections %}
			<div class="mt-8 space-y-6">
				{% for section in sections %}
					<div class="prose prose-slate max-w-none">{{ section }}</div>
				{% endfor %}
			</div>
		{% endif %}

	</div>
</section>

{# ── Desktop floating contextual nav (hidden on mobile/tablet) ───────────────── #}
<section class="hidden lg:block fixed right-0 top-1/2 -translate-y-1/2 z-40 group" aria-label="{{ 'Our Commitment navigation'|t }}">
	<div
		class="flex items-stretch">

		{# Expanded panel — slides in from right edge on hover #}
		<div class="flex flex-col justify-center overflow-hidden bg-white border-y border-l border-slate-200 rounded-l-2xl shadow-xl w-0 opacity-0 group-hover:w-56 group-hover:opacity-100 transition-all duration-300 ease-out">
			<div class="min-w-[14rem] px-4 py-5">
				<p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400 whitespace-nowrap">{{ active_nav_parent ? active_nav_parent.title : 'Navigation'|t }}</p>
				<ul class="space-y-0.5">
					{% for sub in sub_items %}
						<li>
							<a href="{{ sub.url }}" class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors whitespace-nowrap{% if current_path == sub.url %} bg-slate-100 font-semibold text-slate-900{% else %} text-slate-600 hover:bg-slate-50 hover:text-slate-900{% endif %}">
								<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }} w-4 text-center text-xs{% if current_path == sub.url %} text-[#b13634]{% else %} text-slate-400{% endif %}" aria-hidden="true"></i>
								{{ sub.title }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>

		{# Tab strip — always visible on right edge, collapses border-radius on hover #}
		<div class="flex flex-col items-center justify-center gap-2.5 bg-[#b13634] rounded-l-2xl group-hover:rounded-l-none shadow-lg shadow-[#b13634]/30 px-2.5 py-5 min-w-[2.75rem] transition-all duration-300 cursor-default select-none">
			<i class="fa-solid fa-layer-group text-white/90 text-md" aria-hidden="true"></i>
			<div class="w-px h-2 bg-white/30 rounded-full"></div>
			{% for sub in sub_items %}
				<div class="rounded-full transition-colors {% if current_path == sub.url %}w-2 h-2 bg-white{% else %}w-1.5 h-1.5 bg-white/40 hover:bg-white/70{% endif %}" title="{{ sub.title }}"></div>
			{% endfor %}
		</div>

	</div>
</section>
