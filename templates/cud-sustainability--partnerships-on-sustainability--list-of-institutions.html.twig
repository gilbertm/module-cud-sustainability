{#
/**
 * @file
 * Inner-page template for /sustainability/partnerships-on-sustainability/list-of-institutions.
 *
 * Variables:
 * - title: Page title string.
 * - content: Rendered node content (full view mode).
 * - carousel_items: Optional list of carousel slides.
 * - sections: Optional list of processed-text sections.
 * - primary_nav: Primary navigation array.
 * - secondary_nav: Secondary navigation array.
 * - mode: Display mode string ('main' or 'secondary').
 */
#}

{% set carousel_slides = carousel_items|default([]) %}

{% if carousel_slides %}
	<section class="carousel group relative mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Governance carousel'|t }}">
		<div class="w-full relative overflow-hidden">
			<div class="w-full flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Governance') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}
						<div class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>
					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>
					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}

{# ── Page Header with Breadcrumb ─────────────────────────────────────────────── #}
<section class="bg-white" aria-label="{{ 'Page header'|t }}">
	<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
		<nav class="mb-3 flex items-center gap-1.5 text-xs text-slate-500" aria-label="{{ 'Breadcrumb'|t }}">
			{% for link in breadcrumb %}
				{% if not loop.first %}
					<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
				{% endif %}
				{% if link.url %}
					<a href="{{ link.url }}" class="hover:text-slate-700 transition-colors">{{ link.text }}</a>
				{% else %}
					<span>{{ link.text }}</span>
				{% endif %}
			{% endfor %}
			{% if breadcrumb is not empty %}
				<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
			{% endif %}
			<span class="font-medium text-slate-700">{{ title }}</span>
		</nav>
		<div class="flex items-center gap-3">
			<h1 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{{ title }}</h1>
			{% if edit_url %}
				<a href="{{ edit_url }}" class="shrink-0 rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700" title="{{ 'Edit node'|t }}" aria-label="{{ 'Edit'|t }}">
					<i class="fa-solid fa-pen-to-square text-sm" aria-hidden="true"></i>
				</a>
			{% endif %}
		</div>
	</div>
</section>

{# ── Shared sub-nav data ──────────────────────────────────────────────────────── #}

{# Icon map for all seeded primary nav children, keyed by URL #}
{% set icon_map = {
	'/sustainability/partnerships-on-sustainability/list-of-institutions': 'fa-building',
} %}

{# Derive sub_items from the matching top-level primary nav parent #}
{% set active_nav_parent = null %}
{% for item in primary_nav %}
	{% if item.children and (current_path == item.url or current_path starts with (item.url ~ '/')) %}
		{% set active_nav_parent = item %}
	{% endif %}
{% endfor %}
{% set sub_items = active_nav_parent ? active_nav_parent.children : [] %}

{# ── Mobile / tablet sub-nav strip (hidden on lg+) ───────────────────────────── #}
<div class="lg:hidden border-b border-slate-100 bg-white px-4 sm:px-6">
	<nav class="flex gap-1.5 overflow-x-auto py-2.5 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" aria-label="{{ 'Our Commitment navigation'|t }}">
		{% for sub in sub_items %}
			<a href="{{ sub.url }}" class="inline-flex flex-none items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium transition-colors{% if current_path == sub.url %} bg-slate-900 text-white{% else %} text-slate-600 hover:bg-slate-100 hover:text-slate-900{% endif %}">
				<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }}" aria-hidden="true"></i>
				{{ sub.title }}
			</a>
		{% endfor %}
	</nav>
</div>

{# ── Main Content (full-width) ────────────────────────────────────────────────── #}
<section class="mx-auto max-w-7xl px-4 lg:px-8 !bg-white" id="main-content" aria-label="{{ title }}" data-mode="{{ mode }}">
	<div
		class="min-w-0 space-y-5">

		{# ── Partnerships Intro ───────────────────────────────────────────────── #}
		<div class="block-common-content">
			<p class="text-slate-700 text-sm leading-relaxed">Canadian University Dubai has established meaningful partnerships with leading institutions across government, healthcare, research, and academia. These collaborations advance our shared mission of sustainability, social responsibility, and innovation — spanning local UAE partners to international universities and research networks worldwide.</p>
		</div>

		{# ── Partnership Stats ──────────────────────────────────────────────── #}
		<div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
			<div class="rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm">
				<p class="text-2xl font-bold text-[#b13634]">16</p>
				<p class="mt-1 text-xs text-slate-500">{{ 'Partner Institutions'|t }}</p>
			</div>
			<div class="rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm">
				<p class="text-2xl font-bold text-emerald-600">4</p>
				<p class="mt-1 text-xs text-slate-500">{{ 'Sectors'|t }}</p>
			</div>
			<div class="rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm">
				<p class="text-2xl font-bold text-sky-600">5</p>
				<p class="mt-1 text-xs text-slate-500">{{ 'Academic Partners'|t }}</p>
			</div>
			<div class="rounded-xl border border-slate-200 bg-white p-4 text-center shadow-sm">
				<p class="text-2xl font-bold text-violet-600">4</p>
				<p class="mt-1 text-xs text-slate-500">{{ 'Healthcare Partners'|t }}</p>
			</div>
		</div>

		{# ── Partner Data ─────────────────────────────────────────────────────── #}
		{% set partner_categories = [
			{
				label: 'Government & Public Sector'|t,
				icon: 'fa-landmark',
				color: 'bg-[#b13634]/10 text-[#b13634]',
				partners: [
					{ name: 'Dubai Municipality'|t, icon: 'fa-city', desc: 'City-wide urban sustainability, infrastructure, and environmental regulation authority.'|t },
					{ name: 'Authority for Social Contribution (Ma\'an)'|t, icon: 'fa-hands-holding-circle', desc: 'UAE\'s authority championing social contribution and inclusive community development.'|t },
					{ name: 'Canadian Trade Commission'|t, icon: 'fa-handshake', desc: 'Facilitating bilateral trade and institutional cooperation between Canada and the UAE.'|t },
				],
			},
			{
				label: 'Healthcare & Medical'|t,
				icon: 'fa-heart-pulse',
				color: 'bg-rose-50 text-rose-600',
				partners: [
					{ name: 'Emirates Health Economics Society'|t, icon: 'fa-heart-pulse', desc: 'Advancing health economics research, education, and policy in the Emirates.'|t },
					{ name: 'American Hospital Dubai'|t, icon: 'fa-hospital', desc: 'Leading multi-specialty hospital and healthcare provider in Dubai.'|t },
					{ name: 'Hope Abilitation Medical Center'|t, icon: 'fa-hand-holding-heart', desc: 'Specialist rehabilitation and abilitation services for people of determination.'|t },
					{ name: 'uniCare Medical Center'|t, icon: 'fa-user-doctor', desc: 'Comprehensive primary and specialist medical care services across the UAE.'|t },
				],
			},
			{
				label: 'Research, Environment & Conservation'|t,
				icon: 'fa-seedling',
				color: 'bg-emerald-50 text-emerald-700',
				partners: [
					{ name: 'Emirates Park Zoo and Resort'|t, icon: 'fa-paw', desc: 'Abu Dhabi\'s premier zoo committed to wildlife care and biodiversity conservation.'|t },
					{ name: 'Yas SeaWorld Research & Rescue'|t, icon: 'fa-fish', desc: 'Marine research, animal rescue, and ocean conservation on Yas Island.'|t },
					{ name: 'Sustainable Development Research & Training Institute'|t, icon: 'fa-seedling', desc: 'Advancing research and capacity building aligned with sustainable development goals.'|t },
					{ name: 'Climate Institute'|t, icon: 'fa-cloud-sun', desc: 'Dedicated climate research, policy analysis, and environmental advocacy.'|t },
				],
			},
			{
				label: 'Academic & International Networks'|t,
				icon: 'fa-building-columns',
				color: 'bg-sky-50 text-sky-700',
				partners: [
					{ name: 'Silk-Road Universities Network'|t, icon: 'fa-globe', desc: 'International network of universities fostering cooperation along the historic Silk Road corridor.'|t },
					{ name: 'Yunus Centre at Asian Institute of Technology in Thailand'|t, icon: 'fa-graduation-cap', desc: 'Social business and sustainable development research hub based in Bangkok, Thailand.'|t },
					{ name: 'HEC – Montreal in Canada'|t, icon: 'fa-building-columns', desc: 'One of Canada\'s leading business schools, located in Montreal, Quebec.'|t },
					{ name: 'Charles Darwin University in Australia'|t, icon: 'fa-building-columns', desc: 'Australian university with a strong focus on sustainability and regional development.'|t },
					{ name: 'Université de Sherbrooke'|t, icon: 'fa-building-columns', desc: 'Comprehensive research university in Sherbrooke, Quebec, Canada.'|t },
				],
			},
		] %}

		{# ── Partner Grids by Category ─────────────────────────────────────────── #}
		{% for category in partner_categories %}
			<div class="block-common-content" aria-labelledby="heading-cat-{{ loop.index }}">
				<h2 id="heading-cat-{{ loop.index }}" class="text-md md:text-xl font-semibold cud-color-blue mb-3 flex items-center gap-2">
					<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg {# {{ category.color }} #} text-sm">
						<i class="fa-solid {{ category.icon }}" aria-hidden="true"></i>
					</span>
					{{ category.label }}
				</h2>
				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
					{% for partner in category.partners %}
						<div class="flex flex-col gap-3 rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition-shadow hover:shadow-md">
							<div class="flex items-center gap-3">
								{# <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl {{ category.color }} text-lg">
									<i class="fa-solid {{ partner.icon }}" aria-hidden="true"></i>
								</span> #}
								<h3 class="text-sm font-semibold text-slate-800 leading-snug">{{ partner.name }}</h3>
							</div>
							<p class="text-xs text-slate-500 leading-relaxed">{{ partner.desc }}</p>
						</div>
					{% endfor %}
				</div>
			</div>
		{% endfor %}

		{# ── Partnership CTA ──────────────────────────────────────────────────── #}
		<div class="mt-5 rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-4 sm:p-5">
			<div class="flex items-start gap-4">
				<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#b13634]/10 text-[#b13634]">
					<i class="fa-solid fa-handshake text-xl" aria-hidden="true"></i>
				</div>
				<div class="min-w-0 flex-1">
					<p class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">{{ 'Partner With Us'|t }}</p>
					<p class="mt-1 text-sm leading-relaxed text-slate-700">{{ 'Interested in partnering with Canadian University Dubai on sustainability initiatives? We welcome collaborations from academic institutions, government bodies, healthcare providers, and research organisations. Get in touch to explore how we can build a more sustainable future together.'|t }}</p>
					<p class="mt-2 text-sm font-semibold text-[#b13634]">{{ 'Email:'|t }}
						<a href="mailto:partnerships@cud.ac.ae" class="underline hover:text-[#922c2a]">partnerships@cud.ac.ae</a>
					</p>
				</div>
			</div>
		</div>

		{% if content %}
			<div class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-sky-700 prose-a:no-underline hover:prose-a:underline">
				{{ content }}
			</div>
		{% endif %}

		{% if sections %}
			<div class="mt-8 space-y-6">
				{% for section in sections %}
					<div class="prose prose-slate max-w-none">{{ section }}</div>
				{% endfor %}
			</div>
		{% endif %}
		
	</div>
</section>

{# ── Desktop floating contextual nav (hidden on mobile/tablet) ───────────────── #}
<section class="hidden lg:block fixed right-0 top-1/2 -translate-y-1/2 z-40 group" aria-label="{{ 'Our Commitment navigation'|t }}">
	<div
		class="flex items-stretch">

		{# Expanded panel — slides in from right edge on hover #}
		<div class="flex flex-col justify-center overflow-hidden bg-white border-y border-l border-slate-200 rounded-l-2xl shadow-xl w-0 opacity-0 group-hover:w-56 group-hover:opacity-100 transition-all duration-300 ease-out">
			<div class="min-w-[14rem] px-4 py-5">
				<p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400 whitespace-nowrap">{{ active_nav_parent ? active_nav_parent.title : 'Navigation'|t }}</p>
				<ul class="space-y-0.5">
					{% for sub in sub_items %}
						<li>
							<a href="{{ sub.url }}" class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors whitespace-nowrap{% if current_path == sub.url %} bg-slate-100 font-semibold text-slate-900{% else %} text-slate-600 hover:bg-slate-50 hover:text-slate-900{% endif %}">
								<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }} w-4 text-center text-xs{% if current_path == sub.url %} text-[#b13634]{% else %} text-slate-400{% endif %}" aria-hidden="true"></i>
								{{ sub.title }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>

		{# Tab strip — always visible on right edge, collapses border-radius on hover #}
		<div class="flex flex-col items-center justify-center gap-2.5 bg-[#b13634] rounded-l-2xl group-hover:rounded-l-none shadow-lg shadow-[#b13634]/30 px-2.5 py-5 min-w-[2.75rem] transition-all duration-300 cursor-default select-none">
			<i class="fa-solid fa-layer-group text-white/90 text-md" aria-hidden="true"></i>
			<div class="w-px h-2 bg-white/30 rounded-full"></div>
			{% for sub in sub_items %}
				<div class="rounded-full transition-colors {% if current_path == sub.url %}w-2 h-2 bg-white{% else %}w-1.5 h-1.5 bg-white/40 hover:bg-white/70{% endif %}" title="{{ sub.title }}"></div>
			{% endfor %}
		</div>

	</div>
</section>