{#
/**
 * @file
 * Main presentation template for CUD Sustainability pages.
 */
#}

{% set carousel_slides = carousel_items|default([]) %}
{% set research_link_overview = research_home_url|default('/') %}
{% set research_link_strategy = (secondary_nav|default([])|length > 0) ? secondary_nav[0].url : research_link_overview %}
{% set research_link_publications = (primary_nav|default([])|length > 2) ? primary_nav[2].url : research_link_overview %}
{% set research_link_clusters = (primary_nav|default([])|length > 1) ? primary_nav[1].url : research_link_overview %}
{% set research_link_researchers = (secondary_nav|default([])|length > 1) ? secondary_nav[1].url : research_link_overview %}
{% set research_link_sdg = (secondary_nav|default([])|length > 2) ? secondary_nav[2].url : research_link_overview %}
{% set research_link_calendar = research_link_overview %}

{% if carousel_slides %}
	<section class="carousel group relative mb-1 lg:mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Sustainability highlights carousel'|t }}">
		<div class="w-full relative overflow-hidden">
			<div class="w-full flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] x-min-h-[260px] overflow-hidden md:min-h-[360px] lg:min-h-[500px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] x-min-h-[260px] overflow-hidden md:min-h-[360px] lg:min-h-[500px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Sustainability highlight') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}

						<div class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>

					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls hidden md:block">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>

					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>

					<div class="absolute bottom-3 left-1/2 z-10 flex w-[min(92vw,680px)] -translate-x-1/2 items-center gap-2 sm:bottom-6">
						<div class="flex min-w-0 flex-1 items-center gap-3 rounded-full bg-black/35 px-3 py-2 text-white backdrop-blur-md">
							<div class="flex min-w-[2.75rem] justify-end text-xs font-semibold tracking-wider" data-cud-carousel-count>1 /
								{{ carousel_slides|length }}</div>
							<div class="h-1.5 flex-1 overflow-hidden rounded-full bg-white/30">
								<span class="block h-full w-0 rounded-full bg-white" data-cud-carousel-progress-bar></span>
							</div>
							<div class="flex items-center gap-2">
								{% for item in carousel_slides %}
									<button class="h-2 rounded-full transition-all focus:outline-none focus:ring-2 focus:ring-white{% if loop.first %} w-8 bg-white{% else %} w-2 bg-white/50 hover:bg-white/80{% endif %}" data-cud-carousel-dot="{{ loop.index0 }}" aria-label="{{ 'Go to slide @num'|t({'@num': loop.index}) }}"></button>
								{% endfor %}
							</div>
						</div>
						<button class="flex h-9 w-9 flex-none items-center justify-center rounded-full bg-black/35 text-white/70 backdrop-blur-md transition-colors hover:bg-white/15 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/50" data-cud-carousel-toggle aria-label="{{ 'Pause carousel'|t }}" aria-pressed="false">
							<i class="fa-solid fa-pause h-3.5 w-3.5" data-icon-pause aria-hidden="true"></i>
							<i class="fa-solid fa-play h-3.5 w-3.5 hidden" data-icon-play aria-hidden="true"></i>
						</button>
					</div>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}

{# ── Net Zero 2050 & Strategic Alignment article ── #}
<section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-4 lg:py-6" aria-label="{{ 'CUD Statement on UAE Net Zero 2050'|t }}">
	<div
		class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
		{# Hero: image + Net Zero 2050 intro #}
		<div class="grid grid-cols-1 lg:grid-cols-3">
			<div class="h-64 lg:h-full">
				<img src="{{ cud_sustainability_asset_path ~ 'images/canadian-university-dubai-front.jpg' }}" alt="Canadian University Dubai campus front" loading="lazy" class="h-full w-full object-cover">
			</div>
			<div class="p-5 sm:p-7 lg:col-span-2 lg:p-8">
				<h1 class="mt-3 text-2xl font-semibold cud-color-blue sm:text-3xl">{{ 'CUD Statement on UAE Net Zero 2050'|t }}</h1>
				<p class="mt-3 text-sm text-slate-700 leading-relaxed">{{ 'Canadian University Dubai recognizes its responsibility as an institution of higher education to contribute meaningfully to global climate goals. In alignment with the UAE\'s Net Zero by 2050 Strategic Initiative, the university is committed to progressively reducing its greenhouse gas emissions across its operations, curriculum, and research activities.'|t }}</p>
				<p class="mt-3 text-sm text-slate-700 leading-relaxed">{{ 'This commitment is reflected in the integration of sustainability principles into academic programs, the promotion of energy-efficient practices across campus operations, and the preparation of graduates equipped to address environmental challenges in their professional fields.'|t }}</p>
				<p class="mt-3 text-sm text-slate-700 leading-relaxed">{{ 'CUD acknowledges that achieving net zero requires a long-term, institution-wide approach — one that involves students, faculty, staff, and external partners. The university will continue to measure, report, and improve upon its environmental performance, contributing to the broader national and international efforts to limit global temperature rise and build a more sustainable future.'|t }}</p>
		</div>
		</div>
	</div>
</section>

