{# T1 Block 3: Policy and Framework Strip #}
<section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-4 lg:py-6" aria-label="{{ 'Policy Frameworks'|t }}" data-mode="{{ mode }}">
	<div class="mb-6 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
		<div>
			<p class="text-xs font-semibold uppercase tracking-[0.32em] text-slate-600">Institutional Framework</p>
			<h2 class="mt-2 text-2xl font-semibold tracking-tight cud-color-blue sm:text-3xl">Governance and Accountability</h2>
		</div>
	</div>
	<div class="grid gap-5 lg:grid-cols-[1.2fr_0.8fr]">
		<div class="rounded-2xl border-b border-slate-200 bg-white p-6 shadow-[0_10px_28px_rgba(15,23,42,0.07)] lg:p-7">
			<p class="text-sm leading-7 text-slate-700">CUD's sustainability commitment is governed by a Sustainability Council and reinforced by institutional policies spanning environmental stewardship, social equity, operational efficiency, governance transparency, and alignment with international frameworks including ISO 14001, GRI standards, and UN Sustainable Development Goals.</p>

			<div class="mt-6 flex flex-col gap-3 sm:flex-row">
				<a href="{{ research_link_overview }}" class="inline-flex items-center justify-center gap-2 rounded-md border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-900 transition-all duration-200 hover:border-slate-400 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-300 focus:ring-offset-2">
						<span>View All Policies</span>
						<i class="fa-solid fa-arrow-right-long h-4 w-4" aria-hidden="true"></i>
					</a>
					<a href="{{ research_link_strategy }}" class="inline-flex items-center justify-center gap-2 rounded-md bg-[#b13634] px-4 py-2.5 text-sm font-semibold text-white transition-all duration-200 hover:bg-[#982b2a] focus:outline-none focus:ring-2 focus:ring-[#b13634] focus:ring-offset-2">
						<span>Strategic Roadmap</span>
						<i class="fa-solid fa-book-open h-4 w-4" aria-hidden="true"></i>
					</a>
			</div>
		</div>

		<div class="flex flex-col gap-4">
			<div class="rounded-xl border border-slate-200 bg-white p-4">
				<p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Latest Update</p>
				<p class="mt-2 font-medium text-slate-900">Sustainability Policy Framework v2.1</p>
				<p class="mt-1 text-xs text-slate-600">Approved: March 15, 2026 | Review Cycle: Annual</p>
			</div>

			<div class="rounded-xl border border-slate-200 bg-white p-4">
				<p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Compliance</p>
				<p class="mt-2 font-medium text-slate-900">7 International Standards</p>
				<p class="mt-1 text-xs text-slate-600">ISO 14001 • GRI • SASB • UN SDGs</p>
			</div>
			</div>
		</div>
</section>


{# T1 Block 4: Contact and Collaboration CTA #}
<section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-4 lg:py-6" aria-label="{{ 'Collaboration and Contact'|t }}" data-mode="{{ mode }}">
	<div class="mb-6 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
		<div>
			<p class="text-xs font-semibold uppercase tracking-[0.32em] text-slate-600">Get Involved</p>
			<h2 class="mt-2 text-2xl font-semibold tracking-tight cud-color-blue sm:text-3xl">Join Our Sustainability Journey</h2>
		</div>
	</div>
	<div class="grid gap-6 rounded-2xl border-b border-slate-200 bg-white p-6 shadow-[0_10px_28px_rgba(15,23,42,0.07)] lg:grid-cols-[1.2fr_0.8fr] lg:items-center lg:gap-12 lg:p-8">
		<div>
			<p class="mt-4 max-w-2xl text-sm leading-7 text-slate-700">Whether you're a researcher, student, community partner, or colleague, there are meaningful ways to contribute to our sustainability vision. Connect with our team to explore collaboration opportunities, volunteer, or learn more about ongoing initiatives.</p>

			<div class="mt-6 flex flex-col gap-3 sm:flex-row">
				<a href="{{ research_link_researchers }}" class="inline-flex items-center justify-center gap-2 rounded-md bg-sky-600 px-4 py-2.5 text-sm font-semibold text-white shadow-md transition-all duration-200 hover:bg-sky-700 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-sky-400 focus:ring-offset-2">
					<span>Meet the Team</span>
					<i class="fa-solid fa-arrow-right-long h-4 w-4" aria-hidden="true"></i>
				</a>
				<a href="{{ research_link_overview }}" class="inline-flex items-center justify-center gap-2 rounded-md border border-slate-300 bg-white px-4 py-2.5 text-sm font-medium text-slate-900 transition-all duration-200 hover:border-slate-400 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-300 focus:ring-offset-2">
					<span>Contact Us</span>
					<i class="fa-solid fa-envelope h-4 w-4" aria-hidden="true"></i>
				</a>
			</div>
		</div>

		<div class="flex flex-col gap-4">
			<div class="rounded-2xl border border-sky-200 bg-sky-50 p-6">
				<i class="fa-solid fa-handshake h-6 w-6 text-sky-600" aria-hidden="true"></i>
				<p class="mt-3 font-semibold text-slate-900">Partnerships</p>
				<p class="mt-1 text-xs text-slate-700">Industry collaborations and research consortia</p>
			</div>
			<div class="rounded-2xl border border-emerald-200 bg-emerald-50 p-6">
				<i class="fa-solid fa-graduation-cap h-6 w-6 text-emerald-600" aria-hidden="true"></i>
				<p class="mt-3 font-semibold text-slate-900">Student Programs</p>
				<p class="mt-1 text-xs text-slate-700">Internships, projects, and research opportunities</p>
			</div>
		</div>
	</div>
</section>

<section class="mx-auto max-w-7xl px-4 py-8  lg:mb-8 sm:px-6 sm:py-10 lg:px-4 lg:py-6" aria-label="{{ 'Sustainability Navigation'|t }}" data-mode="{{ mode }}">
	<div class="mb-6 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
		<h2 class="text-2xl font-semibold tracking-tight cud-color-blue sm:text-3xl">{{ 'Explore Our Sustainability'|t }}</h2>
	</div>
	<div class="grid gap-4 sm:grid-cols-2">

			{% set nav_links = [
				{ number: '01', label: 'Our Commitment',                sub: 'Vision, mission, and institutional direction',            url: '/sustainability/our-commitment' },
				{ number: '02', label: 'Education',                     sub: 'SDG-integrated curriculum and student learning',         url: '/sustainability/education' },
				{ number: '03', label: 'Research and Innovation',       sub: 'Pillars, groups, and solution-driven research',          url: '/sustainability/research-innovation' },
				{ number: '04', label: 'Campus Operations',             sub: 'Net zero path, energy, water, waste, and infrastructure', url: '/sustainability/campus-operations' },
				{ number: '05', label: 'Governance and Ethics',         sub: 'Council, policies, accountability, and conduct',         url: '/sustainability/governance-ethics' },
				{ number: '06', label: 'Reports and Disclosures',       sub: 'Indicators, evidence, and reporting records',            url: '/sustainability/reports-disclosures' },
				{ number: '07', label: 'News and Stories',              sub: 'Highlights, updates, projects, and announcements',       url: '/sustainability/news' },
				{ number: '08', label: 'SDG Framework',                 sub: 'Priority SDG alignment and institutional mapping',       url: research_link_sdg },
				{ number: '09', label: 'Policies',                      sub: 'Frameworks, standards, and compliance guidance',         url: '/sustainability/policies' },
				{ number: '10', label: 'Sustainability Team',           sub: 'Faculty, council members, and support teams',            url: research_link_researchers },
				{ number: '11', label: 'Collaborate',                   sub: 'Partnership opportunities and engagement channels',      url: '/sustainability/collaborate' },
				{ number: '12', label: 'Contact',                       sub: 'Connect with the sustainability office',                 url: '/sustainability/contact' }
			] %}

			{% for col_links in nav_links|batch(6) %}
				<ul class="list bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
					{% for item in col_links %}
						<li class="list-row group border-b border-slate-100 last:border-b-0 transition-colors duration-150 hover:bg-slate-50">
							<a href="{{ item.url }}" class="flex w-full items-center gap-4 px-5 py-4 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#b13634]">
								<div class="text-3xl font-thin tabular-nums text-slate-300 group-hover:text-[#b13634] transition-colors duration-150 shrink-0 w-10 text-right">{{ item.number }}</div>
								<div class="list-col-grow min-w-0">
									<div class="text-sm font-semibold text-slate-800 group-hover:text-[#172550] truncate">{{ item.label }}</div>
									<div class="text-xs font-medium uppercase tracking-wide text-slate-400 truncate">{{ item.sub }}</div>
								</div>
								<div class="shrink-0 text-slate-300 group-hover:text-[#b13634] transition-colors duration-150">
									<i class="fa-solid fa-arrow-right-long" aria-hidden="true"></i>
								</div>
							</a>
						</li>
					{% endfor %}
				</ul>
			{% endfor %}

	</div>
</section>


