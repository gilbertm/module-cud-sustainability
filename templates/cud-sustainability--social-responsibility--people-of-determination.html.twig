{#
/**
 * @file
 * Inner-page template for /sustainability/our-commitment/governance.
 *
 * Variables:
 * - title: Page title string.
 * - content: Rendered node content (full view mode).
 * - carousel_items: Optional list of carousel slides.
 * - sections: Optional list of processed-text sections.
 * - primary_nav: Primary navigation array.
 * - secondary_nav: Secondary navigation array.
 * - mode: Display mode string ('main' or 'secondary').
 */
#}

{% set carousel_slides = carousel_items|default([]) %}

{% if carousel_slides %}
	<section class="carousel group relative mb-8 w-screen max-w-none -translate-x-1/2 left-1/2" data-cud-carousel data-cud-carousel-autoplay="5600" aria-label="{{ 'Governance carousel'|t }}">
		<div class="w-full relative overflow-hidden">
			<div class="w-full flex transition-transform duration-700 ease-out will-change-transform" data-cud-carousel-track>
				{% for item in carousel_slides %}
					<article class="relative min-w-full" data-cud-carousel-slide>
						{% if item.image %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								{{ item.image }}
							</div>
						{% elseif item.image_url %}
							<div class="cud-sustainability-carousel__frame w-full aspect-[2.6/1] min-h-[280px] overflow-hidden sm:min-h-[340px] lg:min-h-[420px]">
								<img src="{{ item.image_url }}" alt="{{ item.title|default('Governance') }}" loading="lazy" class="h-full w-full object-cover">
							</div>
						{% endif %}
						<div class="carousel-content-overlay absolute inset-0 mx-auto h-full w-full max-w-none">
							{% if item.overlay %}
								{{ item.overlay }}
							{% endif %}
						</div>
					</article>
				{% endfor %}
			</div>

			{% if carousel_slides|length > 1 %}
				<div class="carousel-content-controls">
					<button class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:left-6" data-cud-carousel-prev aria-label="{{ 'Previous slide'|t }}">
						<i class="fa-solid fa-chevron-left h-5 w-5" aria-hidden="true"></i>
					</button>
					<button class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-md bg-slate-950/80 p-2.5 text-slate-100 opacity-0 shadow-xl backdrop-blur-md transition-all duration-500 ease-in-out group-hover:opacity-100 hover:bg-slate-800/90 hover:text-white focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-sky-400 sm:right-6" data-cud-carousel-next aria-label="{{ 'Next slide'|t }}">
						<i class="fa-solid fa-chevron-right h-5 w-5" aria-hidden="true"></i>
					</button>
				</div>
			{% endif %}
		</div>
	</section>
{% endif %}

{# ── Page Header with Breadcrumb ─────────────────────────────────────────────── #}
<section class="bg-white" aria-label="{{ 'Page header'|t }}">
	<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
		<nav class="mb-3 flex items-center gap-1.5 text-xs text-slate-500" aria-label="{{ 'Breadcrumb'|t }}">
			{% for link in breadcrumb %}
				{% if not loop.first %}
					<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
				{% endif %}
				{% if link.url %}
					<a href="{{ link.url }}" class="hover:text-slate-700 transition-colors">{{ link.text }}</a>
				{% else %}
					<span>{{ link.text }}</span>
				{% endif %}
			{% endfor %}
			{% if breadcrumb is not empty %}
				<i class="fa-solid fa-chevron-right text-[9px] text-slate-400" aria-hidden="true"></i>
			{% endif %}
			<span class="font-medium text-slate-700">{{ title }}</span>
		</nav>
		<div class="flex items-center gap-3">
			<h1 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{{ title }}</h1>
			{% if edit_url %}
				<a href="{{ edit_url }}" class="shrink-0 rounded-md p-1.5 text-slate-400 transition-colors hover:bg-slate-100 hover:text-slate-700" title="{{ 'Edit node'|t }}" aria-label="{{ 'Edit'|t }}">
					<i class="fa-solid fa-pen-to-square text-sm" aria-hidden="true"></i>
				</a>
			{% endif %}
		</div>
	</div>
</section>

{# ── Shared sub-nav data ──────────────────────────────────────────────────────── #}

{# Icon map for all seeded primary nav children, keyed by URL #}
{% set icon_map = {
	'/sustainability/social-responsibility/edi': 'fa-handshake',
	'/sustainability/social-responsibility/people-of-determination': 'fa-universal-access',
} %}

{# Derive sub_items from the matching top-level primary nav parent #}
{% set active_nav_parent = null %}
{% for item in primary_nav %}
	{% if item.children and (current_path == item.url or current_path starts with (item.url ~ '/')) %}
		{% set active_nav_parent = item %}
	{% endif %}
{% endfor %}
{% set sub_items = active_nav_parent ? active_nav_parent.children : [] %}

{# ── Mobile / tablet sub-nav strip (hidden on lg+) ───────────────────────────── #}
<div class="lg:hidden border-b border-slate-100 bg-white px-4 sm:px-6">
	<nav class="flex gap-1.5 overflow-x-auto py-2.5 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" aria-label="{{ 'Our Commitment navigation'|t }}">
		{% for sub in sub_items %}
			<a href="{{ sub.url }}" class="inline-flex flex-none items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-medium transition-colors{% if current_path == sub.url %} bg-slate-900 text-white{% else %} text-slate-600 hover:bg-slate-100 hover:text-slate-900{% endif %}">
				<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }}" aria-hidden="true"></i>
				{{ sub.title }}
			</a>
		{% endfor %}
	</nav>
</div>

{# ── Main Content (full-width) ────────────────────────────────────────────────── #}
<section class="mx-auto max-w-7xl px-4 lg:px-8 !bg-white" id="main-content" aria-label="{{ title }}" data-mode="{{ mode }}">
	<div
		class="min-w-0 space-y-5">

		{# ── People of Determination Intro ───────────────────────────────────── #}
		<div class="block-common-content">
			<ul class="grid gap-3 grid-cols-1 lg:grid-cols-2 mb-4 lg:mb-8" role="list">
				<li>

					<a href="/sustainability/social-responsibility/people-of-determination#people-of-determination-main" class="flex items-center gap-3 rounded-lg border border-slate-300 px-4 py-2.5 text-sm text-slate-700 transition-all hover:border-[#b13634]/30 hover:bg-[#b13634]/5 hover:text-slate-900 group/link">
						<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600 transition-colors group-hover/link:bg-[#b13634]/10 group-hover/link:text-[#b13634]">
							<i class="fa-solid fa-people-group text-[#b13634] text-base shrink-0" aria-hidden="true"></i>
						</span>
						<span class="leading-snug">{{ 'People of Determination Accessibility Features on Campus'|t }}</span>
						<i class="fa-solid fa-chevron-right ml-auto text-[10px] text-slate-300 transition-colors group-hover/link:text-[#b13634]" aria-hidden="true"></i>
					</a>

				</li>

			</ul>

			<p class="text-slate-700 text-sm leading-relaxed">Canadian University Dubai is committed to fostering an inclusive and barrier-free learning environment where every individual is empowered to reach their maximum potential. As one of the first universities in the UAE to welcome students with special educational needs, we provide a comprehensive support ecosystem that includes individualized academic accommodations, assistive technology, and dedicated counseling services.</p>
		</div>

		{# ── Disability Support Office ─────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-disability-support">
			<h2 id="heading-disability-support" class="text-md md:text-xl font-semibold cud-color-blue mb-4">{{ 'Disability Support Office'|t }}</h2>
			<div class="rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-5 sm:p-6 shadow-sm">
				<div class="flex flex-col sm:flex-row sm:items-start gap-6">
					<div class="shrink-0 flex justify-center sm:justify-start">
						<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/edi-officer.png' }}" alt="{{ 'Ms. Simran Siddiqui — Disability Support Office'|t }}" class="w-48 h-48 object-cover rounded-full shadow-md ring-2 ring-slate-200"/>
					</div>
					<div class="flex-1 min-w-0">
						<p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400 mb-1">{{ 'Disability Support Office'|t }}</p>
						<h3 class="text-lg font-semibold text-slate-900">Ms. Simran Siddiqui</h3>
						<p class="text-slate-600 text-sm leading-relaxed mt-2">Ms. Simran Siddiqui heads the counselling office and oversees the EDI and Disability Support offices in CUD. Together with Student Affairs and Human Resources, Ms. Simran ensures all matters of EDI and disability support is properly addressed at all management levels.</p>
						<p class="text-slate-500 text-sm mt-3 italic">{{ 'Schedule an appointment, call, or visit us. We\'re here to support you.'|t }}</p>
						<div class="mt-4 flex flex-col gap-2 text-sm">
							<div class="flex items-center gap-2.5 text-slate-700">
								<i class="fa-solid fa-phone w-4 text-center text-[#b13634]" aria-hidden="true"></i>
								<a href="tel:+97147096292" class="hover:text-[#b13634] transition-colors">+971 4 709 6292</a>
							</div>
							<div class="flex items-center gap-2.5 text-slate-700">
								<i class="fa-brands fa-whatsapp w-4 text-center text-emerald-500" aria-hidden="true"></i>
								<a href="https://wa.me/25400739775" class="hover:text-[#b13634] transition-colors">25400 739775</a>
							</div>
							<div class="flex items-center gap-2.5 text-slate-700">
								<i class="fa-solid fa-location-dot w-4 text-center text-[#b13634]" aria-hidden="true"></i>
								<span>{{ 'HUB 1 – 05'|t }}</span>
							</div>
							<div class="flex items-center gap-2.5 text-slate-700">
								<i class="fa-solid fa-envelope w-4 text-center text-[#b13634]" aria-hidden="true"></i>
								<a href="mailto:Simran.Siddiqui@cud.ac.ae" class="hover:text-[#b13634] transition-colors underline underline-offset-2">Simran.Siddiqui@cud.ac.ae</a>
							</div>
							<div class="flex items-center gap-2.5 text-slate-700">
								<i class="fa-solid fa-envelope w-4 text-center text-slate-400" aria-hidden="true"></i>
								<a href="mailto:StudentCounsellor@cud.ac.ae" class="hover:text-[#b13634] transition-colors underline underline-offset-2">StudentCounsellor@cud.ac.ae</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		{# ── Equitable Opportunities for Staff ────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-staff-equity">
			<h2 id="heading-staff-equity" class="text-md md:text-xl font-semibold cud-color-blue mb-3">{{ 'Equitable Opportunities for Staff'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed">Our commitment to inclusion extends beyond the classroom to every member of our workforce. CUD provides a supportive professional environment for staff members of determination, ensuring that our recruitment and employment practices are accessible and equitable. We provide the necessary workplace accommodations and physical infrastructure, including designated parking, specialized elevators, and accessible facilities across our campus, to ensure that all employees can contribute their expertise in a safe and accommodating setting.</p>
		</div>

		{# ── Targeted Supports for Students of Determination ──────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-student-support">
			<h2 id="heading-student-support" class="text-md md:text-xl font-semibold cud-color-blue mb-3">{{ 'Targeted Supports for Students of Determination'|t }}</h2>
			<figure class="my-5 flex flex-col items-center gap-3">
				   <img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/target-supports-graph.png' }}" alt="{{ 'Horizontal bar chart showing enrolment of students of determination at CUD: 85 in 2022–23, 96 in 2023–24, 110 in 2024–25, and 109 in 2025–26'|t }}" class="block w-auto h-auto mx-auto rounded-lg shadow-sm"/>
				   <figcaption class="max-w-lg text-center text-xs text-slate-500 leading-relaxed">
					   <strong class="font-semibold text-slate-700">{{ 'Number of Students of Determination Enrolled in CUD (2022–2026)'|t }}</strong><br/>
					   {{ 'Enrollment by academic year: 85 in 2022–23, 96 in 2023–24, 110 in 2024–25 (peak), and 109 in 2025–26. CUD has seen a steady increase in enrolled students of determination, with a slight decrease projected for 2025–26.'|t }}
				   </figcaption>
			</figure>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">CUD maintains dedicated support for students with disabilities (&ldquo;students of determination&rdquo;). We are committed to fostering an inclusive and safe learning environment for students of determination and students with disabilities.</p>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">Students who have a documented physical, psychological, learning or other challenge are eligible for academic accommodations, determined on a case-by-case basis. These accommodations can include extra time on exams, assistive technology, specialized learning resources, note-taking support or access to a distraction-reduced environment. CUD&rsquo;s approach is individualized and confidential: <a href="https://www.cud.ac.ae/student-life/personal-counselling" class="font-semibold text-sky-700 hover:underline">staff work closely</a> with each student to accommodate their individual needs and ensure they have equal opportunity to reach their maximum potential.</p>
			<p class="text-slate-700 text-sm leading-relaxed">Beyond accommodations, CUD offers formal support programs: as <a href="https://www.cud.ac.ae/news/canadian-university-dubai-chancellor-discusses-actions-inclusion" class="text-sky-700 hover:underline">one alumni interview notes</a>, CUD was <em>&ldquo;among the first universities in the UAE to welcome students with special educational needs&rdquo;</em>, and has &ldquo;supported more than 100 determined students&rdquo; through scholarships, one-on-one tutoring, and a dedicated counselor to provide academic and pastoral care. These combined services &mdash; from admission scholarships to learning support and counseling &mdash; demonstrate CUD&rsquo;s institutional commitment to reducing barriers for disabled students.</p>
		</div>

		{# ── Scholarships for Students of Determination ───────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-scholarships">
			<h2 id="heading-scholarships" class="text-md md:text-xl font-semibold cud-color-blue mb-3">{{ 'Scholarships for Students of Determination'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">We at Canadian University Dubai pledge to provide an inclusive learning environment and to support the cognitive, emotional and creative development of students with disabilities. Special needs may be justified by physical or other disabilities. Students eligible for a Special Needs Scholarship will benefit from a tuition reduction of up to 40%.</p>
			<p class="text-slate-700 text-sm leading-relaxed">For more information, visit <a href="https://www.cud.ac.ae/scholarships" class="font-semibold text-sky-700 hover:underline">www.cud.ac.ae/scholarships</a> or get in touch with <a href="mailto:scholarship@cud.ac.ae" class="text-sky-700 hover:underline">scholarship@cud.ac.ae</a>.</p>
		</div>

		{# ── Career Placements ─────────────────────────────────────────────────── #}
		<div class="block-common-content" aria-labelledby="heading-career-placements">
			<a id="people-of-determination-main" name="people-of-determination-main" class="max-h-[1px] h-[1px] overflow-hidden">&nbsp;</a>
			<h2 id="heading-career-placements" class="text-md md:text-xl font-semibold cud-color-blue mb-3">{{ 'Career Placements'|t }}</h2>
			<p class="text-slate-700 text-sm leading-relaxed mb-3">CUD Career Services remains committed to fostering an inclusive professional environment by bridging the gap between students of determination and the global workforce through targeted partnerships and specialized recruitment initiatives. By collaborating with organizations like I Am Inclusive&mdash;a leading recruitment agency for people of determination&mdash;the office ensures that students with Special Educational Needs (SEN) have direct access to inclusive employers during key events like the CUD Career Fair. While the previously planned Social Enterprise Seminar has been postponed due to regional challenges, the office continues to prioritize these vital connections through alternative engagement strategies. These efforts are further bolstered by the ongoing recruitment of specialized SEN coordination staff, ensuring that every student receives personalized career guidance and accommodation.</p>
			<p class="text-slate-700 text-sm leading-relaxed">While the university is actively scaling its placement tracking for students of determination through these new partnerships, the specific headcount of hired students with disabilities is currently being consolidated as part of the 2026 employability reporting cycle. Moving forward, the implementation of automated platforms will allow for more granular tracking of these success stories to better reflect CUD&rsquo;s commitment to diverse and equitable employment outcomes.</p>
		</div>

		{# ── People of Determination Accessibility Features on Campus ────────── #}
		<div class="block-common-content" aria-labelledby="heading-accessibility-features">
			<h2 id="heading-accessibility-features" class="text-md md:text-xl font-semibold cud-color-blue mb-4">{{ 'People of Determination Accessibility Features on Campus'|t }}</h2>
			{% set accessibility_buildings = [
				{
					title: 'Management Building'|t,
					cards: [
						{ title: 'First-floor accessible toilet'|t, alt: 'Management Building first-floor accessible toilet'|t, images: ['management-building-first-floor-toilet-01-corrected.jpeg', 'management-building-first-floor-toilet-02-corrected.jpeg'] },
						{ title: 'Ground-floor accessible toilet'|t, alt: 'Management Building ground-floor accessible toilet'|t, images: ['management-building-ground-floor-toilet-01-corrected.jpeg', 'management-ground-floor-toilet-02.jpeg'] },
						{ title: 'Clinic wheelchairs'|t, alt: 'Wheelchairs available at the Management Building clinic'|t, images: ['management-building-wheelchairs-at-the-clinic-01-corrected.jpeg'] },
						{ title: 'Backside exit ramp'|t, alt: 'Management Building backside exit ramp'|t, images: ['management-building-ramp-backside-exit-01-corrected.jpeg'] },
						{ title: 'Designated car park'|t, alt: 'Management Building designated parking for people of determination'|t, images: ['management-building-pod-designated-carpark-01-corrected.jpeg'] },
					],
				},
				{
					title: 'HUB Building'|t,
					cards: [
						{ title: 'Ground-floor VIP toilet'|t, alt: 'HUB Building ground-floor VIP accessible toilet'|t, images: ['hub-building-ground-floor-vip-toilet-01-corrected.jpeg', 'hub-building-ground-floor-vip-toilet-02-corrected.jpeg'] },
						{ title: 'Recruitment offices'|t, alt: 'HUB Building recruitment offices accessibility feature'|t, images: ['hub-building-recruitment-offices-01-corrected.jpeg'] },
						{ title: 'New offices entrance'|t, alt: 'Accessible entrance to the new offices in HUB Building'|t, images: ['hub-building-entrance-new-offices-01-corrected.jpeg'] },
						{ title: 'Theatre seating areas'|t, alt: 'Theatre seating accessibility area in HUB Building'|t, images: ['hub-building-theatre-seating-areas-01-corrected.jpeg', 'hub-building-theatre-seating-areas-02-corrected.jpeg'] },
						{ title: 'Designated parking'|t, alt: 'HUB Building designated parking for people of determination'|t, images: ['hub-building-pod-designated-parking-01-corrected.jpeg'] },
						{ title: 'Library first-floor toilet'|t, alt: 'Accessible toilet near the HUB Building library on the first floor'|t, images: ['hub-building-toilet-first-floor-01-corrected.jpeg'] },
						{ title: 'Kitchen-side first-floor toilet'|t, alt: 'Accessible toilet near the HUB Building kitchen on the first floor'|t, images: ['hub-building-toilet-first-floor-near-kitchen-01-corrected.jpeg'] },
						{ title: 'Reception and clinic wheelchairs'|t, alt: 'Wheelchairs available near HUB Building reception and clinic'|t, images: ['hub-building-wheelchair-reception-clinic-01-corrected.jpeg', 'hub-building-wheelchair-reception-clinic-02-corrected.jpeg'] },
						{ title: 'First-floor access elevator'|t, alt: 'HUB Building elevator providing access to the first floor'|t, images: ['hub-building-elevator-access-to-first-floor-01-corrected.jpeg'] },
						{ title: 'Evacuation chairs'|t, alt: 'Evacuation chairs in HUB Building'|t, images: ['hub-building-evacuation-chairs-01-corrected.png'] },
						{ title: 'Library and offices elevator access'|t, alt: 'HUB Building elevator access to the library and offices'|t, images: ['hub-building-elevator-access-to-library-and-offices-01-corrected.jpeg', 'hub-building-elevator-access-to-library-and-offices-02-corrected.png'] },
					],
				},
			] %}

			{% for building in accessibility_buildings %}
				<h3 class="text-base font-semibold text-slate-800 mt-5 mb-3 flex items-center gap-2">
					<i class="fa-solid fa-building text-[#b13634] text-sm" aria-hidden="true"></i>
					{{ building.title }}
				</h3>
				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
					{% for card in building.cards %}
						{% set image_count = card.images|length %}
						{% set image_grid_class = image_count == 4 ? 'grid-cols-4' : 'grid-cols-2' %}
						<div class="flex flex-col gap-2 rounded-xl border border-slate-200 p-3 shadow-sm h-56 sm:h-64 lg:h-72">
							{% if image_count > 1 %}
								<div class="grid {{ image_grid_class }} gap-1.5 overflow-hidden h-28 sm:h-32 lg:h-40">
									{% for image in card.images %}
										<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/accessibility/' ~ image }}" alt="{{ card.alt }}" class="w-full h-full max-h-full object-cover rounded-lg tc-lightbox"/>
									{% endfor %}
								</div>
							{% else %}
								<div class="flex items-center justify-center overflow-hidden h-28 sm:h-32 lg:h-40">
									<img src="{{ cud_sustainability_asset_path ~ 'images/social-responsibility/accessibility/' ~ card.images|first }}" alt="{{ card.alt }}" class="w-full h-full max-h-full object-cover rounded-lg tc-lightbox"/>
								</div>
							{% endif %}
							<p class="text-xs font-medium text-slate-700 text-center">{{ card.title }}</p>
						</div>
					{% endfor %}
				</div>
			{% endfor %}
		</div>

		{% if content %}
			<div class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-sky-700 prose-a:no-underline hover:prose-a:underline">
				{{ content }}
			</div>
		{% endif %}

		{% if sections %}
			<div class="mt-8 space-y-6">
				{% for section in sections %}
					<div class="prose prose-slate max-w-none">{{ section }}</div>
				{% endfor %}
			</div>
		{% endif %}
		
	</div>
</section>

{# ── Desktop floating contextual nav (hidden on mobile/tablet) ───────────────── #}
<section class="hidden lg:block fixed right-0 top-1/2 -translate-y-1/2 z-40 group" aria-label="{{ 'Our Commitment navigation'|t }}">
	<div
		class="flex items-stretch">

		{# Expanded panel — slides in from right edge on hover #}
		<div class="flex flex-col justify-center overflow-hidden bg-white border-y border-l border-slate-200 rounded-l-2xl shadow-xl w-0 opacity-0 group-hover:w-56 group-hover:opacity-100 transition-all duration-300 ease-out">
			<div class="min-w-[14rem] px-4 py-5">
				<p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400 whitespace-nowrap">{{ active_nav_parent ? active_nav_parent.title : 'Navigation'|t }}</p>
				<ul class="space-y-0.5">
					{% for sub in sub_items %}
						<li>
							<a href="{{ sub.url }}" class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm transition-colors whitespace-nowrap{% if current_path == sub.url %} bg-slate-100 font-semibold text-slate-900{% else %} text-slate-600 hover:bg-slate-50 hover:text-slate-900{% endif %}">
								<i class="fa-solid {{ icon_map[sub.url]|default('fa-circle') }} w-4 text-center text-xs{% if current_path == sub.url %} text-[#b13634]{% else %} text-slate-400{% endif %}" aria-hidden="true"></i>
								{{ sub.title }}
							</a>
						</li>
					{% endfor %}
				</ul>
			</div>
		</div>

		{# Tab strip — always visible on right edge, collapses border-radius on hover #}
		<div class="flex flex-col items-center justify-center gap-2.5 bg-[#b13634] rounded-l-2xl group-hover:rounded-l-none shadow-lg shadow-[#b13634]/30 px-2.5 py-5 min-w-[2.75rem] transition-all duration-300 cursor-default select-none">
			<i class="fa-solid fa-layer-group text-white/90 text-md" aria-hidden="true"></i>
			<div class="w-px h-2 bg-white/30 rounded-full"></div>
			{% for sub in sub_items %}
				<div class="rounded-full transition-colors {% if current_path == sub.url %}w-2 h-2 bg-white{% else %}w-1.5 h-1.5 bg-white/40 hover:bg-white/70{% endif %}" title="{{ sub.title }}"></div>
			{% endfor %}
		</div>

	</div>
</section>