}

/**
 * Adds carousel image and overlay fields to the research bundle.
 */
function cud_research_update_10003(): void {
  cud_research_ensure_carousel_fields();
}

/**
 * Adds the sections field to the research bundle.
 */
function cud_research_update_10004(): void {
  cud_research_ensure_sections_field();
}

/**
 * Ensures the research bundle and slug field exist.
 */
function cud_research_ensure_research_bundle(): void {
  $type_id = 'research';

  if (!NodeType::load($type_id)) {
    $type = NodeType::create([
      'type' => $type_id,
      'name' => 'CUD Research',
      'description' => 'Research entries rendered at /research and /research/{slug}.',
      'new_revision' => TRUE,
      'preview_mode' => 1,
      'display_submitted' => FALSE,
    ]);
    $type->save();
  }

  if (!FieldStorageConfig::loadByName('node', 'field_research_slug')) {
    FieldStorageConfig::create([
      'field_name' => 'field_research_slug',
      'entity_type' => 'node',
      'type' => 'string',
      'cardinality' => 1,
      'settings' => [
        'max_length' => 128,
        'is_ascii' => TRUE,
        'case_sensitive' => FALSE,
      ],
      'translatable' => FALSE,
    ])->save();
  }

  if (!FieldConfig::loadByName('node', $type_id, 'field_research_slug')) {
    FieldConfig::create([
      'field_name' => 'field_research_slug',
      'entity_type' => 'node',
      'bundle' => $type_id,
      'label' => 'Research slug',
      'description' => 'Use "main" for /research and unique values for /research/{slug}.',
      'required' => TRUE,
      'settings' => [],
    ])->save();
  }

  $form_display = \Drupal::service('entity_display.repository')
    ->getFormDisplay('node', $type_id, 'default');
  if (!$form_display->getComponent('field_research_slug')) {
    $form_display->setComponent('field_research_slug', [
      'type' => 'string_textfield',
      'weight' => -4,
      'settings' => [
        'size' => 64,
        'placeholder' => 'main',
      ],
    ]);
    $form_display->save();
  }

  $view_display = \Drupal::service('entity_display.repository')
    ->getViewDisplay('node', $type_id, 'default');
  if (!$view_display->getComponent('field_research_slug')) {
    $view_display->setComponent('field_research_slug', [
      'label' => 'hidden',
      'type' => 'string',
      'weight' => 98,
    ]);
    $view_display->save();
  }

  cud_research_ensure_carousel_fields();
  cud_research_ensure_sections_field();
}

/**
 * Adds carousel image and overlay fields to the research bundle.
 */
function cud_research_ensure_carousel_fields(): void {
  $type_id = 'research';

  if (!FieldStorageConfig::loadByName('node', 'field_research_carousel_images')) {
    FieldStorageConfig::create([
      'field_name' => 'field_research_carousel_images',
      'entity_type' => 'node',
      'type' => 'entity_reference',
      'cardinality' => FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED,
      'settings' => ['target_type' => 'media'],
    ])->save();
  }

  if (!FieldConfig::loadByName('node', $type_id, 'field_research_carousel_images')) {
    FieldConfig::create([
      'field_name' => 'field_research_carousel_images',
      'entity_type' => 'node',
      'bundle' => $type_id,
      'label' => 'Carousel images',
      'required' => FALSE,
      'settings' => [
        'handler' => 'default:media',
        'handler_settings' => ['target_bundles' => ['image' => 'image']],
      ],
    ])->save();
  }

  if (!FieldStorageConfig::loadByName('node', 'field_research_carousel_content')) {
    FieldStorageConfig::create([
      'field_name' => 'field_research_carousel_content',
      'entity_type' => 'node',
      'type' => 'text_long',
      'cardinality' => FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED,
    ])->save();
  }

  if (!FieldConfig::loadByName('node', $type_id, 'field_research_carousel_content')) {
    FieldConfig::create([
      'field_name' => 'field_research_carousel_content',
      'entity_type' => 'node',
      'bundle' => $type_id,
      'label' => 'Carousel slide overlays',
      'required' => FALSE,
      'description' => 'HTML overlay per slide, paired by position with carousel images.',
      'settings' => [],
    ])->save();
  }

  $form_display = \Drupal::service('entity_display.repository')
    ->getFormDisplay('node', $type_id, 'default');
  $needs_save = FALSE;

  if (!$form_display->getComponent('field_research_carousel_images')) {
    $form_display->setComponent('field_research_carousel_images', [
      'type' => 'media_library_widget',
      'weight' => 5,
    ]);
    $needs_save = TRUE;
  }

  if (!$form_display->getComponent('field_research_carousel_content')) {
    $form_display->setComponent('field_research_carousel_content', [
      'type' => 'text_textarea',
      'weight' => 6,
      'settings' => ['rows' => 3],
    ]);
    $needs_save = TRUE;
  }

  if ($needs_save) {
    $form_display->save();
  }
}

/**
 * Adds the sections field to the research bundle.
 */
function cud_research_ensure_sections_field(): void {
  $type_id = 'research';
  $field_name = 'field_research_sections';

  if (!FieldStorageConfig::loadByName('node', $field_name)) {
    FieldStorageConfig::create([
      'field_name' => $field_name,
      'entity_type' => 'node',
      'type' => 'text_long',
      'cardinality' => FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED,
    ])->save();
  }

  if (!FieldConfig::loadByName('node', $type_id, $field_name)) {
    FieldConfig::create([
      'field_name' => $field_name,
      'entity_type' => 'node',
      'bundle' => $type_id,
      'label' => 'Sections',
      'required' => FALSE,
      'description' => 'Full HTML sections printed in order on the page. Add as many as needed.',
      'settings' => [],
    ])->save();
  }

  $form_display = \Drupal::service('entity_display.repository')
    ->getFormDisplay('node', $type_id, 'default');
  if (!$form_display->getComponent($field_name)) {
    $form_display->setComponent($field_name, [
      'type' => 'text_textarea',
      'weight' => 10,
      'settings' => ['rows' => 8],
    ]);
    $form_display->save();
  }

  $view_display = \Drupal::service('entity_display.repository')
    ->getViewDisplay('node', $type_id, 'default');
  if (!$view_display->getComponent($field_name)) {
    $view_display->setComponent($field_name, [
      'label' => 'hidden',
      'type' => 'text_default',
      'weight' => 10,
    ]);
    $view_display->save();
  }
}

/**
 * Creates a starter published research entry for /research.
 */
function cud_research_create_main_entry(): void {
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $existing = $node_storage->loadByProperties([
    'type' => 'research',
    'field_research_slug' => 'main',
  ]);

  if (!empty($existing)) {
    return;
  }

  $node = Node::create([
    'type' => 'research',
    'title' => 'Research Overview',
    'status' => 1,
    'field_research_slug' => 'main',
  ]);
  $node->save();
}

/**
 * Creates the CUD Research navigation menus with starter link items.
 */
function cud_research_update_10005(): void {
  cud_research_ensure_menus();
}

/**
 * Ensures the CUD Research primary and secondary menus exist with starter items.
 */
function cud_research_ensure_menus(): void {
  $menu_definitions = [
    'cud-research-primary' => 'CUD Research Primary',
    'cud-research-secondary' => 'CUD Research Secondary',
  ];

  foreach ($menu_definitions as $id => $label) {
    if (!Menu::load($id)) {
      Menu::create([
        'id' => $id,
        'label' => $label,
        'description' => $label . ' navigation menu.',
      ])->save();
    }
  }

  if (!\Drupal::moduleHandler()->moduleExists('menu_link_content')) {
    return;
  }

  $starter_items = [
    'cud-research-primary' => [
      ['title' => 'Research Home', 'uri' => 'internal:/research'],
      ['title' => 'Research Topics', 'uri' => 'internal:/research/topics'],
      ['title' => 'Publications', 'uri' => 'internal:/research/publications'],
    ],
    'cud-research-secondary' => [
      ['title' => 'About Research', 'uri' => 'internal:/research/about'],
      ['title' => 'Partnerships', 'uri' => 'internal:/research/partnerships'],
      ['title' => 'Contact', 'uri' => 'internal:/research/contact'],
    ],
  ];

  $mlc_storage = \Drupal::entityTypeManager()->getStorage('menu_link_content');
  foreach ($starter_items as $menu_name => $items) {
    $existing = $mlc_storage->loadByProperties(['menu_name' => $menu_name]);
    if (!empty($existing)) {
      continue;
    }
    foreach ($items as $weight => $item) {
      MenuLinkContent::create([
        'title' => $item['title'],
        'link' => ['uri' => $item['uri']],
        'menu_name' => $menu_name,
        'weight' => $weight,
        'enabled' => TRUE,
      ])->save();
    }
  }
}
