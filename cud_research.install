<?php

declare(strict_types=1);

use Drupal\Core\Field\FieldStorageDefinitionInterface;
use Drupal\field\Entity\FieldConfig;
use Drupal\field\Entity\FieldStorageConfig;
use Drupal\menu_link_content\Entity\MenuLinkContent;
use Drupal\node\Entity\Node;
use Drupal\node\Entity\NodeType;
use Drupal\system\Entity\Menu;

/**
 * Implements hook_install().
 */
function cud_research_install(): void {
  cud_research_ensure_research_bundle();
  cud_research_create_main_entry();
  cud_research_ensure_menus();
}

/**
 * Implements hook_uninstall().
 */
function cud_research_uninstall(): void {
  $type_id = 'research';
  $entity_type_manager = \Drupal::entityTypeManager();

  // 1. Delete all research nodes so no orphaned rows remain in node* tables.
  $node_storage = $entity_type_manager->getStorage('node');
  $query = \Drupal::entityQuery('node')
    ->condition('type', $type_id);
  if (method_exists($query, 'accessCheck')) {
    $query->accessCheck(FALSE);
  }
  $nids = $query->execute();
  if ($nids) {
    $node_storage->delete($node_storage->loadMultiple($nids));
  }

  // 2. Delete field instances then field storage for each field.
  $fields_to_remove = [
    'field_research_slug',
    'field_research_carousel_images',
    'field_research_carousel_content',
    'field_research_sections',
  ];

  foreach ($fields_to_remove as $field_name) {
    $instance = FieldConfig::loadByName('node', $type_id, $field_name);
    if ($instance) {
      $instance->delete();
    }

    // Only drop the storage table when no other bundles use this field.
    $remaining = $entity_type_manager
      ->getStorage('field_config')
      ->loadByProperties(['entity_type' => 'node', 'field_name' => $field_name]);
    if (empty($remaining)) {
      $storage = FieldStorageConfig::loadByName('node', $field_name);
      if ($storage) {
        $storage->delete();
        // Purge any residual field data rows the delete may have queued.
        field_purge_batch(100);
      }
    }
  }

  // 3. Delete navigation menu items and menus.
  if (\Drupal::moduleHandler()->moduleExists('menu_link_content')) {
    $mlc_storage = $entity_type_manager->getStorage('menu_link_content');
    foreach (['cud-research-primary', 'cud-research-secondary'] as $menu_name) {
      $links = $mlc_storage->loadByProperties(['menu_name' => $menu_name]);
      if (!empty($links)) {
        $mlc_storage->delete($links);
      }
    }
  }
  foreach (['cud-research-primary', 'cud-research-secondary'] as $menu_name) {
    $menu = Menu::load($menu_name);
    if ($menu) {
      $menu->delete();
    }
  }

  // 4. Delete the node type itself.
  $type = NodeType::load($type_id);
  if ($type) {
    $type->delete();
  }
}

/**
 * Adds the CUD Research content type and slug field for existing installs.
 */
function cud_research_update_8001(): void {
  cud_research_update_10001();
}

