<?php

declare(strict_types=1);

/**
 * @file
 * Theme hooks for CUD Sustainability.
 */

/**
 * Implements hook_theme().
 */
function cud_sustainability_theme(array $existing, string $type, string $theme, string $path): array {
  return [
    'html__cud_sustainability' => [
      'base hook' => 'html',
      'template' => 'html--cud-sustainability',
    ],
    'page__cud_sustainability' => [
      'base hook' => 'page',
      'template' => 'page--cud-sustainability',
    ],
    'off_canvas_page_wrapper__cud_sustainability' => [
      'base hook' => 'off_canvas_page_wrapper',
      'template' => 'off-canvas-page-wrapper--cud-sustainability',
    ],
    // Base theme hook. All variants below inherit these variables.
    'cud_sustainability' => [
      'variables' => [
        'title' => NULL,
        'content' => NULL,
        'variant' => 'normal',
        'carousel_items' => [],
        'sections' => [],
        'primary_nav' => [],
        'secondary_nav' => [],
      ],
      'template' => 'cud-sustainability',
    ],
    // ── Variant templates (suggestion hooks) ──────────────────────────────────
    // Named *exactly* as Drupal suggestion machine names so the registry can
    // find them. Template filenames follow the -- double-dash convention:
    //   hook __part → template --part  (__ ↔ --)
    //   single _    → single -
    //
    // Main landing page: /sustainability (slug = 'main')
    'cud_sustainability__main' => [
      'base hook' => 'cud_sustainability',
      'template' => 'cud-sustainability--main',
    ],
    // Generic inner page fallback (empty slug / no dedicated template)
    'cud_sustainability__normal' => [
      'base hook' => 'cud_sustainability',
      'template' => 'cud-sustainability--normal',
    ],
    // /sustainability/our-commitment/governance
    'cud_sustainability__our_commitment__governance' => [
      'base hook' => 'cud_sustainability',
      'template' => 'cud-sustainability--our-commitment--governance',
    ]
  ];
}

/**
 * Implements hook_theme_suggestions_cud_sustainability().
 *
 * Template selection follows Drupal's native path-based suggestion convention,
 * the same principle used for page--node--1.html.twig and page--front.html.twig.
 *
 * Rules (evaluated from the current request path):
 *   /sustainability                          → cud-sustainability--main.html.twig
 *   /sustainability/our-commitment/governance → cud-sustainability--our-commitment--governance.html.twig
 *                                               with cud-sustainability--normal.html.twig as fallback
 *   /sustainability/*                        → cud-sustainability--normal.html.twig
 *
 * Suggestion machine name convention:
 *   Each URL path segment maps to a '__' separator (= '--' in filename).
 *   Dashes within a segment stay as single underscores (= single dashes).
 *   e.g. /sustainability/our-commitment/governance
 *        → cud_sustainability__our_commitment__governance
 *        → cud-sustainability--our-commitment--governance.html.twig
 */
function cud_sustainability_theme_suggestions_cud_sustainability(array $variables): array {
  // Derive template from the URL path, exactly as Drupal does for page templates.
  $request = \Drupal::requestStack()->getCurrentRequest();
  $path = $request ? trim($request->getPathInfo(), '/') : 'sustainability';

  $suggestions = [];

  if ($path === 'sustainability') {
    $suggestions[] = 'cud_sustainability__main';
    return $suggestions;
  }

  if (strpos($path, 'sustainability/') === 0) {
    $sub = substr($path, strlen('sustainability/'));
    // Segments after 'sustainability/' become '__'-joined machine name parts.
    $segments = explode('/', strtolower($sub));
    $machine_parts = array_map(static function (string $seg): string {
      return preg_replace('/[^a-z0-9]+/', '_', $seg);
    }, $segments);
    $specific_hook = 'cud_sustainability__' . implode('__', $machine_parts);

    // Always include 'normal' first so it acts as the fallback template;
    // the specific hook at higher priority wins when its template file exists.
    $suggestions[] = 'cud_sustainability__normal';
    if ($specific_hook !== 'cud_sustainability__normal') {
      $suggestions[] = $specific_hook;
    }

    return $suggestions;
  }

  // Any other path under this module: use normal.
  $suggestions[] = 'cud_sustainability__normal';

  return $suggestions;
}

/**
 * Implements hook_route_alter().
 *
 * Forces CUD Sustainability to own /sustainability paths by disabling conflicting routes
 * from other modules/themes when this module is enabled.
 */
function cud_sustainability_route_alter(\Symfony\Component\Routing\RouteCollection $collection): void {
  foreach ($collection->all() as $route_name => $route) {
    if (cud_sustainability_starts_with($route_name, 'cud_sustainability.')) {
      continue;
    }

    $path = $route->getPath();
    if ($path === NULL || $path === '') {
      continue;
    }

    if (!cud_sustainability_is_overridden_path($path)) {
      continue;
    }

    // Make conflicting routes impossible to match while preserving their
    // definitions for debugging/inspection.
    $route->setRequirement('_access', 'FALSE');
  }
}

/**
 * Determines if a route path conflicts with CUD Sustainability public paths.
 */
function cud_sustainability_is_overridden_path(string $path): bool {
  return $path === '/sustainability' || cud_sustainability_starts_with($path, '/sustainability/');
}

/**
 * Polyfill-safe prefix check for Drupal 8.x/PHP 7 compatibility.
 */
function cud_sustainability_starts_with(string $haystack, string $prefix): bool {
  if ($prefix === '') {
    return TRUE;
  }

  return strpos($haystack, $prefix) === 0;
}

/**
 * Implements hook_theme_suggestions_html_alter().
 */
function cud_sustainability_theme_suggestions_html_alter(array &$suggestions, array $variables): void {
  if (!cud_sustainability_is_route()) {
    return;
  }

  $suggestions[] = 'html__cud_sustainability';
}

/**
 * Implements hook_theme_suggestions_page_alter().
 */
function cud_sustainability_theme_suggestions_page_alter(array &$suggestions, array $variables): void {
  if (!cud_sustainability_is_route()) {
    return;
  }

  $suggestions[] = 'page__cud_sustainability';
}

