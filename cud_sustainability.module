}

/**
 * Implements hook_preprocess_page().
 */
function cud_sustainability_preprocess_page(array &$variables): void {
  if (!cud_sustainability_is_route()) {
    return;
  }

  $request = \Drupal::requestStack()->getCurrentRequest();
  $variables['primary_nav'] = cud_sustainability_menu_items('cud-sustainability-primary');
  $variables['secondary_nav'] = cud_sustainability_menu_items('cud-sustainability-secondary');
  $variables['research_mode'] = cud_sustainability_resolve_mode();
  $variables['research_site_name'] = (string) \Drupal::config('system.site')->get('name');
  $variables['research_home_url'] = \Drupal\Core\Url::fromRoute('<front>')->toString();
  $variables['research_logo_url'] = cud_sustainability_resolve_logo_url();
  $variables['research_search_action'] = \Drupal\Core\Url::fromRoute('cud_sustainability.search')->toString();
  $variables['research_search_query'] = $request ? trim((string) $request->query->get('q', '')) : '';
  $contact_url = trim((string) \Drupal::config('cud_sustainability.settings')->get('contact_url'));
  $variables['research_contact_url'] = $contact_url !== '' ? $contact_url : '/sustainability/contact';

  // When any /sustainability or /sustainability/* URL is served via an aliased
  // Drupal node (route name entity.node.canonical instead of cud_sustainability.*),
  // replace page.content with the path-specific cud_sustainability theme so that
  // the correct content template is always used:
  //   /sustainability                        → cud-sustainability--main.html.twig
  //   /sustainability/our-commitment/governance → cud-sustainability--our-commitment--governance.html.twig
  //   /sustainability/*                     → cud-sustainability--normal.html.twig (fallback)
  $route_name = \Drupal::routeMatch()->getRouteName();
  if ($request && !str_starts_with((string) $route_name, 'cud_sustainability.')) {
    $path = $request->getPathInfo();
    $theme_hook = cud_sustainability_path_to_theme_hook($path);
    if ($theme_hook !== NULL) {
      $entity_type_manager = \Drupal::entityTypeManager();
      $node_storage = $entity_type_manager->getStorage('node');
      $matched_node = NULL;

      // For entity.node.canonical routes (aliased nodes), the node is already
      // a route parameter — use it directly without any field lookup.
      $route_node_candidate = \Drupal::routeMatch()->getParameter('node');
      if ($route_node_candidate instanceof \Drupal\node\NodeInterface
        && $route_node_candidate->bundle() === 'sustainability'
        && $route_node_candidate->isPublished()) {
        $matched_node = $route_node_candidate;
      }
      else {
        // Fall back to resolving the current path via the alias manager.
        $alias_manager = \Drupal::service('path_alias.manager');
        $system_path = $alias_manager->getPathByAlias($path);
        if (preg_match('#^/node/(\d+)$#', $system_path, $m)) {
          $alias_candidate = $node_storage->load((int) $m[1]);
          if ($alias_candidate instanceof \Drupal\node\NodeInterface
            && $alias_candidate->bundle() === 'sustainability'
            && $alias_candidate->isPublished()) {
            $matched_node = $alias_candidate;
          }
        }
      }

      $cache_tags = ['node_list'];
      $title = '';
      $content = ['#markup' => ''];
      $carousel_items = [];
      if ($matched_node) {
        $title = $matched_node->label();
        $content = $entity_type_manager->getViewBuilder('node')->view($matched_node, 'full');
        $cache_tags = $matched_node->getCacheTags();
        /** @var \Drupal\cud_sustainability\Controller\SustainabilityController $controller */
        $controller = \Drupal::classResolver()->getInstanceFromDefinition(\Drupal\cud_sustainability\Controller\SustainabilityController::class);
        $carousel_items = $controller->getCarouselItems($matched_node);
      }

      // Fallback: if matched_node is still NULL, try the route parameter
      // directly (handles unpublished previews or edge cases where the node
      // is not yet published but the editor is previewing the page).
      if ($title === '') {
        $route_node = \Drupal::routeMatch()->getParameter('node');
        if ($route_node instanceof \Drupal\node\NodeInterface) {
          $title = $route_node->label();
          if ($content === ['#markup' => '']) {
            $content = $entity_type_manager->getViewBuilder('node')->view($route_node, 'full');
            $cache_tags = $route_node->getCacheTags();
          }
        }
      }

      $variables['page']['content'] = [
        '#theme' => $theme_hook,
        '#title' => $title,
        '#content' => $content,
        '#variant' => cud_sustainability_path_to_variant($path),
        '#carousel_items' => $carousel_items,
        '#sections' => [],
        '#primary_nav' => cud_sustainability_menu_items('cud-sustainability-primary'),
        '#secondary_nav' => cud_sustainability_menu_items('cud-sustainability-secondary'),
        '#cache' => [
          'tags' => $cache_tags,
          'contexts' => ['url.path'],
        ],
      ];
    }
  }
}

/**
 * Implements hook_preprocess_cud_sustainability().
 *
 * Populates the breadcrumb variable using Drupal's breadcrumb service so all
 * cud_sustainability template variants receive dynamic, route-aware breadcrumb
 * links instead of hardcoded values.
 */
function cud_sustainability_preprocess_cud_sustainability(array &$variables): void {
  $breadcrumb_obj = \Drupal::service('breadcrumb')->build(\Drupal::routeMatch());
  // Normalize each Link object to a plain array so templates can simply check
  // link.url for truthiness. Non-routable links (<nolink>, <none>) and links
  // whose route cannot be converted to a URL get an empty url so they render
  // as plain text instead of hyperlinks.
  $alias_manager = \Drupal::service('path_alias.manager');
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');

  $links = [];
  foreach ($breadcrumb_obj->getLinks() as $link) {
    $url_obj = $link->getUrl();
    $href = '';
    try {
      $route_name = $url_obj->isRouted() ? $url_obj->getRouteName() : '';
      if (!in_array($route_name, ['<nolink>', '<none>', ''], TRUE)) {
        $href = $url_obj->toString();
      }
    }
    catch (\Exception $e) {
      $href = '';
    }

    // For /sustainability/* breadcrumb segments, only keep the link when the
    // path is backed by a real published node. Intermediate path fragments
    // (e.g. /sustainability/our-commitment) that have no corresponding node
    // are demoted to plain text so they are not misleadingly clickable.
    if ($href !== '' && (
      $href === '/sustainability' || str_starts_with($href, '/sustainability/')
    )) {
      $system_path = $alias_manager->getPathByAlias($href);
      if (preg_match('#^/node/(\d+)$#', $system_path, $m)) {
        $n = $node_storage->load((int) $m[1]);
        if (!$n || !$n->isPublished()) {
          $href = '';
        }
      }
      else {
        // Path did not resolve to a node — not clickable.
        $href = '';
      }
    }

    $links[] = ['text' => (string) $link->getText(), 'url' => $href];
  }
  $variables['breadcrumb'] = $links;

  // Provide an edit URL when the current user can edit the node, so templates
  // can render an admin-only edit shortcut beside the page title.
  $node = \Drupal::routeMatch()->getParameter('node');
  if ($node instanceof \Drupal\node\NodeInterface && $node->access('update')) {
    $variables['edit_url'] = \Drupal\Core\Url::fromRoute('entity.node.edit_form', ['node' => $node->id()])->toString();
  }

  // Provide the current path as a reliable PHP-sourced variable so templates
  // can use it for active-state detection without relying on app.request in
  // Twig, which may return '/' when rendering via sub-requests.
  $req = \Drupal::requestStack()->getMasterRequest() ?? \Drupal::requestStack()->getCurrentRequest();
  $variables['current_path'] = $req ? $req->getPathInfo() : '/';

  // Safety net: if #title was not passed or was empty (e.g. slug lookup missed
  // the node), try to resolve the title from the actual route node or Drupal's
  // title_resolver so the h1 and breadcrumb trailing crumb are never blank.
  if (empty($variables['title'])) {
    $node = \Drupal::routeMatch()->getParameter('node');
    if ($node instanceof \Drupal\node\NodeInterface) {
      $variables['title'] = $node->label();
    }
    else {
      $request = \Drupal::requestStack()->getCurrentRequest();
      $route = \Drupal::routeMatch()->getRouteObject();
      if ($request && $route) {
        $resolved = \Drupal::service('title_resolver')->getTitle($request, $route);
        if (!empty($resolved)) {
          $variables['title'] = is_array($resolved)
            ? (string) \Drupal::service('renderer')->renderPlain($resolved)
            : (string) $resolved;
        }
      }
    }
  }
}

/**
 * Implements hook_preprocess_html().
 */
function cud_sustainability_preprocess_html(array &$variables): void {
  if (!cud_sustainability_is_route()) {
    return;
  }

  $variables['attributes']['class'][] = 'cud-sustainability-route';
}

/**
 * Implements hook_block_access().
 *
 * Hides the system breadcrumb block on all CUD Sustainability routes so that
 * individual page templates can render their own custom breadcrumbs without
 * a duplicate Drupal-managed breadcrumb appearing in page.content.
 */
function cud_sustainability_block_access(\Drupal\block\Entity\Block $block, string $operation, \Drupal\Core\Session\AccountInterface $account): \Drupal\Core\Access\AccessResultInterface {
  if ($operation === 'view' && cud_sustainability_is_route()) {
    $plugin_id = $block->getPluginId();
    if ($plugin_id === 'system_breadcrumb_block') {
      return \Drupal\Core\Access\AccessResult::forbidden()->addCacheTags($block->getCacheTags())->addCacheContexts(['route']);
    }
  }

  return \Drupal\Core\Access\AccessResult::neutral();
}

/**
 * Implements hook_page_alter().
 *
 * Removes Drupal's off-canvas page wrapper on sustainability routes so output does
 * not include the dialog-off-canvas-main-canvas container.
 */
function cud_sustainability_page_alter(array &$page): void {
  if (!cud_sustainability_is_route() || empty($page['#theme_wrappers'])) {
    return;
  }

  if (isset($page['#theme_wrappers']['off_canvas_page_wrapper'])) {
    unset($page['#theme_wrappers']['off_canvas_page_wrapper']);
  }
}

/**
 * Implements hook_page_attachments_alter().
 *
 * Removes active-theme libraries from sustainability routes so the custom module
 * shell is not restyled or scripted by the site theme.
 */
function cud_sustainability_page_attachments_alter(array &$attachments): void {
  if (!cud_sustainability_should_strip_theme_assets() || empty($attachments['#attached']['library'])) {
    return;
  }

  $theme_library_prefixes = cud_sustainability_theme_library_prefixes();
  $attachments['#attached']['library'] = array_values(array_filter(
    $attachments['#attached']['library'],
    static function ($library) use ($theme_library_prefixes): bool {
      if (!is_string($library)) {
        return TRUE;
      }

      foreach ($theme_library_prefixes as $prefix) {
        if (strpos($library, $prefix) === 0) {
          return FALSE;
        }
      }

      return TRUE;
    }
  ));
}

/**
 * Implements hook_css_alter().
 */
function cud_sustainability_css_alter(array &$css, \Drupal\Core\Asset\AttachedAssetsInterface $assets): void {
  if (!cud_sustainability_should_strip_theme_assets()) {
    return;
  }

  foreach ($css as $key => $item) {
    if (!empty($item['data']) && is_string($item['data']) && cud_sustainability_is_theme_asset($item['data'])) {
      unset($css[$key]);
    }
  }
}

/**
 * Implements hook_js_alter().
 */
function cud_sustainability_js_alter(array &$javascript, \Drupal\Core\Asset\AttachedAssetsInterface $assets): void {
  if (!cud_sustainability_should_strip_theme_assets()) {
    return;
  }

  foreach ($javascript as $key => $item) {
    if (!empty($item['data']) && is_string($item['data']) && cud_sustainability_is_theme_asset($item['data'])) {
      unset($javascript[$key]);
    }
  }
}

/**
 * Determines whether the current route is a CUD sustainability route.
 *
 * Detects both module-owned routes (by route name) and aliased Drupal content
 * at /sustainability paths. Path aliases are resolved by PathProcessorAlias
 * before routing, so an aliased node at e.g. /sustainability/something will
 * have route name entity.node.canonical, not cud_sustainability.*. We detect
 * these by checking $request->getPathInfo(), which always returns the original
 * browser URL regardless of alias resolution.
 */
function cud_sustainability_is_route(): bool {
  $route_name = \Drupal::routeMatch()->getRouteName();

  if (str_starts_with((string) $route_name, 'cud_sustainability.')) {
    return TRUE;
  }

  // Also match aliased content served under /sustainability/* by checking the
  // original request path (unaffected by PathProcessorAlias).
  $request = \Drupal::requestStack()->getCurrentRequest();
  if ($request) {
    $path = $request->getPathInfo();
    if ($path === '/sustainability' || str_starts_with($path, '/sustainability/')) {
      return TRUE;
    }
  }

  return FALSE;
}

/**
 * Determines whether theme assets should be stripped for the current request.
 */
function cud_sustainability_should_strip_theme_assets(): bool {
  if (!cud_sustainability_is_route()) {
    return FALSE;
  }

  // Keep admin styling/scripts intact for administrative users and routes.
  if (cud_sustainability_is_admin_context()) {
    return FALSE;
  }

  return TRUE;
}

/**
 * Determines if current request should preserve admin-side assets.
 */
function cud_sustainability_is_admin_context(): bool {
  $route_match = \Drupal::routeMatch();
  $route = $route_match->getRouteObject();
  if ($route && $route->getOption('_admin_route')) {
    return TRUE;
  }

  $request = \Drupal::requestStack()->getCurrentRequest();
  if ($request && strpos($request->getPathInfo(), '/admin') === 0) {
    return TRUE;
  }

  $account = \Drupal::currentUser();
  return $account->hasPermission('access administration pages');
}

/**
 * Returns library prefixes for the active theme and all of its base themes.
 *
 * @return string[]
 *   Library prefixes such as theme_name/.
 */
function cud_sustainability_theme_library_prefixes(): array {
  $active_theme = \Drupal::theme()->getActiveTheme();
  $prefixes = [$active_theme->getName() . '/'];

  foreach ($active_theme->getBaseThemeExtensions() as $base_theme_name => $extension) {
    $prefixes[] = $base_theme_name . '/';
  }

  return array_values(array_unique($prefixes));
}

/**
 * Determines whether an asset file belongs to the active theme tree.
 */
function cud_sustainability_is_theme_asset(string $asset_path): bool {
  $active_theme = \Drupal::theme()->getActiveTheme();
  $theme_paths = [$active_theme->getPath() . '/'];

  foreach ($active_theme->getBaseThemeExtensions() as $extension) {
    $theme_paths[] = $extension->getPath() . '/';
  }

  foreach (array_unique($theme_paths) as $theme_path) {
    if (strpos($asset_path, $theme_path) === 0) {
      return TRUE;
    }
  }

  return FALSE;
}

/**
 * Returns enabled menu items for page-level sustainability navigation, with one
 * level of children for megamenu rendering.
 *
 * @return list<array{title: string, url: string, active: bool, children: list<array{title: string, url: string, active: bool}>}>
 */
function cud_sustainability_menu_items(string $menu_name): array {
  $parameters = new \Drupal\Core\Menu\MenuTreeParameters();
  $parameters->setMaxDepth(2)->onlyEnabledLinks();

  $menu_tree = \Drupal::service('menu.link_tree');
  $tree = $menu_tree->load($menu_name, $parameters);
  $tree = $menu_tree->transform($tree, [
    ['callable' => 'menu.default_tree_manipulators:generateIndexAndSort'],
  ]);

  $request = \Drupal::requestStack()->getCurrentRequest();
  $current_path = $request ? $request->getPathInfo() : '/';
  $items = [];

  foreach ($tree as $element) {
    if ($element->access instanceof \Drupal\Core\Access\AccessResultInterface && $element->access->isForbidden()) {
      continue;
    }

    $url = $element->link->getUrlObject()->toString();
    $children = [];

    foreach ($element->subtree as $child_element) {
      if ($child_element->access instanceof \Drupal\Core\Access\AccessResultInterface && $child_element->access->isForbidden()) {
        continue;
      }
      $child_url = $child_element->link->getUrlObject()->toString();
      $children[] = [
        'title' => $child_element->link->getTitle(),
        'url' => $child_url,
        'active' => rtrim($child_url, '/') === rtrim($current_path, '/'),
      ];
    }

    $is_active = rtrim($url, '/') === rtrim($current_path, '/');
    if (!$is_active) {
      foreach ($children as $child) {
        if ($child['active']) {
          $is_active = TRUE;
          break;
        }
      }
    }

    $items[] = [
      'title' => $element->link->getTitle(),
      'url' => $url,
      'active' => $is_active,
      'children' => $children,
    ];
  }

  return $items;
}

/**
 * Derives the variant string from a /sustainability request path.
 *
 * /sustainability                        → 'main'
 * /sustainability/our-commitment/governance → 'our-commitment--governance'
 * /sustainability/foo                    → 'foo'
 * anything else                         → 'normal'
 */
function cud_sustainability_path_to_variant(string $path, bool $as_array = FALSE) {
  $path = trim($path, '/');

  // If exactly /sustainability, only 'main' variant.
  if ($path === 'sustainability') {
    if ($as_array) {
      return ['main'];
    }
    return 'main';
  }

  // If under /sustainability, return all parent/grandparent variants.
  if (strpos($path, 'sustainability/') === 0) {
    $sub = substr($path, strlen('sustainability/'));
    $segments = explode('/', strtolower($sub));
    $variants = [];
    for ($i = count($segments); $i > 0; $i--) {
      $parent_segments = array_slice($segments, 0, $i);
      $variants[] = implode('--', $parent_segments);
    }
    if ($as_array) {
      return $variants;
    }
    // Return most specific variant as string for legacy usage.
    return $variants[0] ?? 'normal';
  }

  // Fallback: only 'normal'.
  if ($as_array) {
    return ['normal'];
  }
  return 'normal';
}

/**
 * Derives the slug portion for node lookup from a /sustainability request path.
 *
 * /sustainability               → 'main'
 * /sustainability/foo/bar       → 'foo/bar'
 */
function cud_sustainability_path_to_slug(string $path): string {
  $path = trim($path, '/');

  if ($path === 'sustainability') {
    return 'main';
  }

  if (strpos($path, 'sustainability/') === 0) {
    return substr($path, strlen('sustainability/'));
  }

  return '';
}

/**
 * Converts a /sustainability request path to its registered theme hook name.
 *
 * Fallback logic:
 *   - For a path like /sustainability/a/b/c, generates hooks for all parent/grandparent variants:
 *       1. cud_sustainability__a__b__c (most specific)
 *       2. cud_sustainability__a__b
 *       3. cud_sustainability__a
 *   - Returns the first hook that exists in the theme registry.
 *   - Falls back to cud_sustainability__normal if no parent hooks exist.
 *
 * Special cases:
 *   - /sustainability → cud_sustainability__main
 *   - Anything else not under /sustainability → cud_sustainability__normal
 *
 * Mirrors variantToThemeHook() in SustainabilityController.
 *
 * @param string $path
 *   The request path (e.g., /sustainability/our-commitment/governance).
 *
 * @return string|null
 *   The theme hook name to use, or NULL if not under /sustainability.
 */
function cud_sustainability_path_to_theme_hook(string $path): ?string {
  $variant = cud_sustainability_path_to_variant(trim($path, '/'), TRUE);

  // Debug info array
  $debug = [];
  $debug['path'] = $path;
  $debug['variants'] = $variant;

  // Always check for 'main' and 'normal' as special cases.
  if (is_array($variant) && count($variant) && $variant[0] === 'main') {
    $debug['hook'] = 'cud_sustainability__main';
    $debug['reason'] = 'variant is main';
    \Drupal::logger('cud_sustainability')->debug('<pre>' . print_r($debug, TRUE) . '</pre>');
    return 'cud_sustainability__main';
  }

  $registry = \Drupal::service('theme.registry')->get();
  $hooks_tried = [];
  if (is_array($variant)) {
    foreach ($variant as $v) {
      if ($v === 'normal') {
        continue;
      }
      $parts = explode('--', strtolower($v));
      $machine_parts = array_map(static function (string $p): string {
        return preg_replace('/[^a-z0-9]+/', '_', $p);
      }, $parts);
      $hook = 'cud_sustainability__' . implode('__', $machine_parts);
      $hooks_tried[] = $hook;
      if (isset($registry[$hook])) {
        $debug['hook'] = $hook;
        $debug['reason'] = 'using fallback parent hook';
        $debug['hooks_tried'] = $hooks_tried;
        \Drupal::logger('cud_sustainability')->debug('<pre>' . print_r($debug, TRUE) . '</pre>');
        return $hook;
      }
    }
  }

  // Fallback to normal if no parent hooks exist.
  $debug['hook'] = 'cud_sustainability__normal';
  $debug['reason'] = 'no parent hooks found, falling back to normal';
  $debug['hooks_tried'] = $hooks_tried;
  \Drupal::logger('cud_sustainability')->debug('<pre>' . print_r($debug, TRUE) . '</pre>');
  return 'cud_sustainability__normal';
}

/**
 * Resolves requested display mode from the query string.
 */
function cud_sustainability_resolve_mode(): string {
  $request = \Drupal::requestStack()->getCurrentRequest();
  $mode = $request ? (string) $request->query->get('mode', 'main') : 'main';
  $mode = strtolower(trim($mode));

  return in_array($mode, ['main', 'secondary'], TRUE) ? $mode : 'main';
}

/**
 * Resolves logo URL with priority: module image -> theme logo -> NULL.
 */
function cud_sustainability_resolve_logo_url(): ?string {
  $filename = trim((string) \Drupal::config('cud_sustainability.settings')->get('logo_filename'));

  if ($filename !== '') {
    $filename = basename($filename);
    $relative = \Drupal::service('extension.list.module')->getPath('cud_sustainability') . '/assets/images/' . $filename;
    $absolute = DRUPAL_ROOT . '/' . $relative;

    if (is_file($absolute)) {
      return base_path() . $relative;
    }
  }

  $theme_logo = (string) theme_get_setting('logo.url');

  return $theme_logo !== '' ? $theme_logo : NULL;
}

