/**
 * Seeds an unpublished sustainability node (owned by user 1) for every page
 * defined in cud_sustainability_nav_pages(). Skips aliases that already
 * resolve to an existing node. Tags are auto-derived from the alias path
 * segments (dashes replaced with spaces, title-cased) and created in the
 * 'tags' vocabulary if they do not already exist. Safe to run multiple times.
 */
function cud_sustainability_seed_nodes(): void {
  $alias_manager = \Drupal::service('path_alias.manager');
  $alias_storage = \Drupal::entityTypeManager()->getStorage('path_alias');

  foreach (cud_sustainability_nav_pages() as $page) {
    $alias = $page['alias'];

    // Skip if this alias already resolves to an existing node.
    $system_path = $alias_manager->getPathByAlias($alias);
    if (preg_match('#^/node/\d+$#', $system_path)) {
      continue;
    }

    // Derive tags from path segments, skipping the root 'sustainability' segment.
    // e.g. /sustainability/our-commitment/governance → ['Our Commitment', 'Governance']
    $segments = array_values(array_filter(explode('/', $alias)));
    array_shift($segments);
    $tag_ids = [];
    foreach ($segments as $seg) {
      $tag_ids[] = ['target_id' => cud_sustainability_get_or_create_tag(ucwords(str_replace('-', ' ', $seg)))];
    }

    $node = Node::create([
      'type'       => 'sustainability',
      'title'      => $page['title'],
      'status'     => 0,
      'uid'        => 1,
      'field_tags' => $tag_ids,
    ]);
    $node->save();

    $alias_storage->create([
      'path'     => '/node/' . $node->id(),
      'alias'    => $alias,
      'langcode' => 'und',
    ])->save();
  }
}

/**
 * Returns the tid of an existing 'tags' term matching $label, creating it if absent.
 */
function cud_sustainability_get_or_create_tag(string $label): int {
  $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $existing = $term_storage->loadByProperties(['vid' => 'tags', 'name' => $label]);
  if (!empty($existing)) {
    return (int) reset($existing)->id();
  }
  $term = $term_storage->create(['vid' => 'tags', 'name' => $label]);
  $term->save();
  return (int) $term->id();
}

/**
 * Ensures the CUD Sustainability primary and secondary menus exist with starter items.
 */
function cud_sustainability_ensure_menus(): void {
  $menu_definitions = [
    'cud-sustainability-primary' => 'CUD Sustainability Primary',
    'cud-sustainability-secondary' => 'CUD Sustainability Secondary',
  ];

  foreach ($menu_definitions as $id => $label) {
    if (!Menu::load($id)) {
      Menu::create([
        'id' => $id,
        'label' => $label,
        'description' => $label . ' navigation menu.',
      ])->save();
    }
  }

  if (!\Drupal::moduleHandler()->moduleExists('menu_link_content')) {
    return;
  }

  $mlc_storage = \Drupal::entityTypeManager()->getStorage('menu_link_content');

  // Group nav pages by menu; skip content-only entries (menu === NULL).
  $by_menu = [];
  foreach (cud_sustainability_nav_pages() as $page) {
    if ($page['menu'] === NULL) {
      continue;
    }
    $by_menu[$page['menu']][] = $page;
  }

  foreach ($by_menu as $menu_name => $items) {
    // Build a set of URIs already present in this menu so we can skip
    // individual links that exist while still creating any that are missing.
    // This is per-link idempotent (matches the per-alias guard in seed_nodes).
    $existing_uris = [];
    foreach ($mlc_storage->loadByProperties(['menu_name' => $menu_name]) as $link) {
      /** @var \Drupal\menu_link_content\Entity\MenuLinkContent $link */
      $existing_uris[$link->link->uri] = 'menu_link_content:' . $link->uuid();
    }

    // First pass: create top-level items and collect their plugin IDs so child
    // items can reference them as parents.
    $parent_ids = [];
    foreach ($items as $item) {
      if ($item['parent_key'] !== NULL) {
        continue;
      }
      $uri = 'internal:' . $item['alias'];
      if (isset($existing_uris[$uri])) {
        // Already exists — capture its plugin ID for child items.
        $parent_ids[$item['title']] = $existing_uris[$uri];
        continue;
      }
      $link = MenuLinkContent::create([
        'title'     => $item['title'],
        'link'      => ['uri' => $uri],
        'menu_name' => $menu_name,
        'weight'    => $item['weight'],
        'enabled'   => FALSE,
      ]);
      $link->save();
      $parent_ids[$item['title']] = 'menu_link_content:' . $link->uuid();
    }
    // Second pass: create child items with parent references.
    foreach ($items as $item) {
      if ($item['parent_key'] === NULL) {
        continue;
      }
      $uri = 'internal:' . $item['alias'];
      if (isset($existing_uris[$uri])) {
        continue;
      }
      MenuLinkContent::create([
        'title'     => $item['title'],
        'link'      => ['uri' => $uri],
        'menu_name' => $menu_name,
        'weight'    => $item['weight'],
        'parent'    => $parent_ids[$item['parent_key']] ?? '',
        'enabled'   => FALSE,
      ])->save();
    }
  }
}
