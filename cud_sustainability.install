<?php

declare(strict_types=1);

use Drupal\Core\Field\FieldStorageDefinitionInterface;
use Drupal\field\Entity\FieldConfig;
use Drupal\field\Entity\FieldStorageConfig;
use Drupal\menu_link_content\Entity\MenuLinkContent;
use Drupal\node\Entity\Node;
use Drupal\node\Entity\NodeType;
use Drupal\system\Entity\Menu;

/**
 * Implements hook_install().
 */
function cud_sustainability_install(): void {
  cud_sustainability_ensure_sustainability_bundle();
  cud_sustainability_create_main_entry();
  cud_sustainability_seed_nodes();
  cud_sustainability_ensure_menus();
}

/**
 * Implements hook_uninstall().
 */
function cud_sustainability_uninstall(): void {
  // Soft-delete all sustainability nodes: unpublish and transfer ownership to
  // user 1 so content is preserved and recoverable via Drupal admin.
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');

  $query = \Drupal::entityQuery('node')
    ->condition('type', 'sustainability')
    ->accessCheck(FALSE);
  $nids = $query->execute();

  foreach ($nids as $nid) {
    $node = $node_storage->load($nid);
    if (!$node) {
      continue;
    }
    $node->setUnpublished();
    $node->setOwnerId(1);
    $node->setRevisionUserId(1);
    $node->setNewRevision(FALSE);
    $node->save();
  }

  // Fields, menus, and the bundle are intentionally left in place so that
  // content remains accessible and the module can be re-enabled cleanly.
}

/**
 * Ensures the full module setup is in sync for existing installs.
 *
 * Idempotent: safe to run multiple times. Covers bundle, fields, main node,
 * and navigation menus in one pass.
 */
function cud_sustainability_update_10001(): void {
  cud_sustainability_ensure_sustainability_bundle();
  cud_sustainability_ensure_extra_fields();
  cud_sustainability_create_main_entry();
  cud_sustainability_seed_nodes();
  cud_sustainability_ensure_menus();
}

/**
 * Ensures the sustainability bundle and slug field exist.
 */
function cud_sustainability_ensure_sustainability_bundle(): void {
  $type_id = 'sustainability';

  if (!NodeType::load($type_id)) {
    $type = NodeType::create([
      'type' => $type_id,
      'name' => 'CUD Sustainability',
      'description' => 'Sustainability entries rendered at /sustainability and /sustainability/{slug}.',
      'new_revision' => TRUE,
      'preview_mode' => 1,
      'display_submitted' => FALSE,
    ]);
    $type->save();
  }

  cud_sustainability_ensure_carousel_fields();
  cud_sustainability_ensure_extra_fields();

  // Enable the standard body field on the sustainability bundle.
  $node_type = NodeType::load($type_id);
  if ($node_type && !FieldConfig::loadByName('node', $type_id, 'body')) {
    node_add_body_field($node_type);
  }
}

/**
 * Enables tags, image, and file attachment fields on the sustainability bundle.
 */
function cud_sustainability_ensure_extra_fields(): void {
  $type_id     = 'sustainability';
  $display_repo = \Drupal::service('entity_display.repository');

  // ── 1. Tags (standard field_tags → tags vocabulary) ──────────────────────
  if (!FieldStorageConfig::loadByName('node', 'field_tags')) {
    FieldStorageConfig::create([
      'field_name'  => 'field_tags',
      'entity_type' => 'node',
      'type'        => 'entity_reference',
      'cardinality' => FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED,
      'settings'    => ['target_type' => 'taxonomy_term'],
    ])->save();
  }
  if (!FieldConfig::loadByName('node', $type_id, 'field_tags')) {
    FieldConfig::create([
      'field_name'  => 'field_tags',
      'entity_type' => 'node',
      'bundle'      => $type_id,
      'label'       => 'Tags',
      'required'    => FALSE,
      'settings'    => [
        'handler'          => 'default:taxonomy_term',
        'handler_settings' => ['target_bundles' => ['tags' => 'tags']],
      ],
    ])->save();
  }

  // ── 2. Image (standard field_image) ──────────────────────────────────────
  if (!FieldStorageConfig::loadByName('node', 'field_image')) {
    FieldStorageConfig::create([
      'field_name'  => 'field_image',
      'entity_type' => 'node',
      'type'        => 'image',
      'cardinality' => 1,
    ])->save();
  }
  if (!FieldConfig::loadByName('node', $type_id, 'field_image')) {
    FieldConfig::create([
      'field_name'  => 'field_image',
      'entity_type' => 'node',
      'bundle'      => $type_id,
      'label'       => 'Image',
      'required'    => FALSE,
      'settings'    => [
        'file_extensions'    => 'png gif jpg jpeg webp',
        'file_directory'     => 'sustainability/images',
        'alt_field'          => TRUE,
        'alt_field_required' => FALSE,
        'title_field'        => FALSE,
      ],
    ])->save();
  }

  // ── 3. File attachments (PDF/doc, field_sust_files) ───────────────────────
  if (!FieldStorageConfig::loadByName('node', 'field_sust_files')) {
    FieldStorageConfig::create([
      'field_name'  => 'field_sust_files',
      'entity_type' => 'node',
      'type'        => 'file',
      'cardinality' => FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED,
    ])->save();
  }
  if (!FieldConfig::loadByName('node', $type_id, 'field_sust_files')) {
    FieldConfig::create([
      'field_name'  => 'field_sust_files',
      'entity_type' => 'node',
      'bundle'      => $type_id,
      'label'       => 'Attachments',
      'required'    => FALSE,
      'description' => 'Upload PDFs or documents to link from the body.',
      'settings'    => [
        'file_extensions'   => 'pdf doc docx',
        'file_directory'    => 'sustainability/attachments',
        'description_field' => TRUE,
      ],
    ])->save();
  }

  // ── Form display ──────────────────────────────────────────────────────────
  $form_display = $display_repo->getFormDisplay('node', $type_id, 'default');
  $needs_save   = FALSE;

  if (!$form_display->getComponent('field_tags')) {
    $form_display->setComponent('field_tags', [
      'type'   => 'entity_reference_autocomplete_tags',
      'weight' => 20,
    ]);
    $needs_save = TRUE;
  }
  if (!$form_display->getComponent('field_image')) {
    $form_display->setComponent('field_image', [
      'type'   => 'image_image',
      'weight' => 25,
    ]);
    $needs_save = TRUE;
  }
  if (!$form_display->getComponent('field_sust_files')) {
    $form_display->setComponent('field_sust_files', [
      'type'   => 'file_generic',
      'weight' => 30,
    ]);
    $needs_save = TRUE;
  }
  if ($needs_save) {
    $form_display->save();
  }
}

/**
 * Adds carousel image and overlay fields to the sustainability bundle.
 */
function cud_sustainability_ensure_carousel_fields(): void {
  $type_id = 'sustainability';

  if (!FieldStorageConfig::loadByName('node', 'field_sust_carousel_images')) {
    FieldStorageConfig::create([
      'field_name' => 'field_sust_carousel_images',
      'entity_type' => 'node',
      'type' => 'entity_reference',
      'cardinality' => FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED,
      'settings' => ['target_type' => 'media'],
    ])->save();
  }

  if (!FieldConfig::loadByName('node', $type_id, 'field_sust_carousel_images')) {
    FieldConfig::create([
      'field_name' => 'field_sust_carousel_images',
      'entity_type' => 'node',
      'bundle' => $type_id,
      'label' => 'Carousel images',
      'required' => FALSE,
      'settings' => [
        'handler' => 'default:media',
        'handler_settings' => ['target_bundles' => ['image' => 'image']],
      ],
    ])->save();
  }

  if (!FieldStorageConfig::loadByName('node', 'field_sust_carousel_content')) {
    FieldStorageConfig::create([
      'field_name' => 'field_sust_carousel_content',
      'entity_type' => 'node',
      'type' => 'text_long',
      'cardinality' => FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED,
    ])->save();
  }

  if (!FieldConfig::loadByName('node', $type_id, 'field_sust_carousel_content')) {
    FieldConfig::create([
      'field_name' => 'field_sust_carousel_content',
      'entity_type' => 'node',
      'bundle' => $type_id,
      'label' => 'Carousel slide overlays',
      'required' => FALSE,
      'description' => 'HTML overlay per slide, paired by position with carousel images.',
      'settings' => [],
    ])->save();
  }

  $form_display = \Drupal::service('entity_display.repository')
    ->getFormDisplay('node', $type_id, 'default');
  $needs_save = FALSE;

  if (!$form_display->getComponent('field_sust_carousel_images')) {
    $form_display->setComponent('field_sust_carousel_images', [
      'type' => 'media_library_widget',
      'weight' => 5,
    ]);
    $needs_save = TRUE;
  }

  if (!$form_display->getComponent('field_sust_carousel_content')) {
    $form_display->setComponent('field_sust_carousel_content', [
      'type' => 'text_textarea',
      'weight' => 6,
      'settings' => ['rows' => 3],
    ]);
    $needs_save = TRUE;
  }

  if ($needs_save) {
    $form_display->save();
  }
}

/**
 * Creates a starter published sustainability entry for /sustainability.
 */
function cud_sustainability_create_main_entry(): void {
  // Check whether a sustainability node is already aliased at /sustainability.
  $alias_manager = \Drupal::service('path_alias.manager');
  $system_path = $alias_manager->getPathByAlias('/sustainability');
  if (preg_match('#^/node/(\d+)$#', $system_path, $m)) {
    $node_storage = \Drupal::entityTypeManager()->getStorage('node');
    $existing = $node_storage->load((int) $m[1]);
    if ($existing && $existing->bundle() === 'sustainability' && $existing->isPublished()) {
      return;
    }
  }

  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $node = Node::create([
    'type' => 'sustainability',
    'title' => 'Sustainability Overview',
    'status' => 1,
  ]);
  $node->save();

  // Create the canonical path alias /sustainability → /node/{nid}.
  \Drupal::entityTypeManager()->getStorage('path_alias')->create([
    'path' => '/node/' . $node->id(),
    'alias' => '/sustainability',
    'langcode' => 'und',
  ])->save();
}

